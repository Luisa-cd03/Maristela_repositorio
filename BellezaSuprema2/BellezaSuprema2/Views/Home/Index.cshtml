@{
    ViewBag.Title = "Panel Cliente";
    Layout = null;

    var proximasCitas  = ViewBag.ProximasCitas  as List<BellezaSuprema2.Models.CitaModel> ?? new List<BellezaSuprema2.Models.CitaModel>();
    var historialCitas = ViewBag.HistorialCitas as List<BellezaSuprema2.Models.CitaModel> ?? new List<BellezaSuprema2.Models.CitaModel>();
    var favoritos      = ViewBag.Favoritos      as List<BellezaSuprema2.Models.FavoritoModel> ?? new List<BellezaSuprema2.Models.FavoritoModel>();
    long totalCitas    = ViewBag.TotalCitas ?? 0;
    string nombre      = ViewBag.Nombre ?? "Cliente";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel Cliente — Belleza Suprema</title>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        :root {
            --cream: #f5f0eb; --white: #ffffff;
            --pink: #e0006e; --pink-dark: #b8005a; --pink-light: #fce8f3;
            --ink: #1a1118; --ink-2: #4a3f47; --ink-3: #8a7a85;
            --border: #e8e0e5;
            --green: #059669; --blue: #2563eb; --red: #e11d48; --orange: #ea580c;
            --radius-xl: 24px; --radius-lg: 16px; --radius-md: 10px; --radius-sm: 6px;
            --shadow-sm: 0 1px 4px rgba(26,17,24,0.06);
            --shadow-md: 0 4px 20px rgba(26,17,24,0.08);
            --t: 0.2s ease;
        }
        body { font-family:'Plus Jakarta Sans',sans-serif; background:var(--cream); color:var(--ink); min-height:100vh; -webkit-font-smoothing:antialiased; }

        /* NAVBAR */
        .navbar { position:sticky; top:0; z-index:100; background:var(--white); border-bottom:1px solid var(--border); height:64px; padding:0 40px; display:flex; align-items:center; justify-content:space-between; }
        .nav-left { display:flex; align-items:center; gap:12px; text-decoration:none; }
        .nav-logo { width:36px; height:36px; background:var(--ink); border-radius:8px; display:flex; align-items:center; justify-content:center; }
        .nav-logo svg { color:white; }
        .nav-brand { font-size:16px; font-weight:800; color:var(--ink); letter-spacing:-0.3px; }
        .nav-right { display:flex; align-items:center; gap:8px; }
        .btn-ghost { padding:8px 18px; border-radius:var(--radius-md); border:1.5px solid var(--border); background:transparent; color:var(--ink-2); font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; font-weight:600; cursor:pointer; text-decoration:none; transition:var(--t); display:flex; align-items:center; gap:6px; }
        .btn-ghost:hover { border-color:var(--ink); color:var(--ink); text-decoration:none; }
        .btn-primary { padding:9px 20px; border-radius:var(--radius-md); border:none; background:var(--pink); color:white; font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; font-weight:700; cursor:pointer; text-decoration:none; transition:var(--t); display:flex; align-items:center; gap:6px; }
        .btn-primary:hover { background:var(--pink-dark); color:white; text-decoration:none; transform:translateY(-1px); box-shadow:0 4px 14px rgba(224,0,110,0.30); }

        /* HERO */
        .hero { background:var(--pink); padding:64px 40px 0; display:flex; align-items:flex-end; justify-content:space-between; gap:32px; overflow:hidden; min-height:260px; }
        .hero-text { max-width:580px; padding-bottom:52px; }
        .hero-pill { display:inline-flex; align-items:center; gap:6px; background:rgba(255,255,255,0.18); border:1px solid rgba(255,255,255,0.30); border-radius:20px; padding:5px 14px; font-size:12px; font-weight:600; color:rgba(255,255,255,0.9); letter-spacing:0.5px; margin-bottom:20px; }
        .hero-pill span { width:6px; height:6px; background:rgba(255,255,255,0.8); border-radius:50%; }
        .hero-title { font-size:clamp(32px,5vw,52px); font-weight:800; color:white; line-height:1.05; letter-spacing:-1.5px; margin-bottom:16px; }
        .hero-sub { font-size:15px; color:rgba(255,255,255,0.80); font-weight:400; line-height:1.6; margin-bottom:28px; max-width:440px; }
        .hero-actions { display:flex; align-items:center; gap:12px; flex-wrap:wrap; }
        .btn-hero-white { padding:13px 28px; background:white; color:var(--pink); border:none; border-radius:var(--radius-md); font-family:'Plus Jakarta Sans',sans-serif; font-size:14px; font-weight:700; cursor:pointer; text-decoration:none; transition:var(--t); display:flex; align-items:center; gap:7px; }
        .btn-hero-white:hover { transform:translateY(-2px); box-shadow:0 6px 20px rgba(0,0,0,0.15); color:var(--pink-dark); text-decoration:none; }
        .btn-hero-outline { padding:13px 28px; background:transparent; color:white; border:2px solid rgba(255,255,255,0.5); border-radius:var(--radius-md); font-family:'Plus Jakarta Sans',sans-serif; font-size:14px; font-weight:600; cursor:pointer; text-decoration:none; transition:var(--t); }
        .btn-hero-outline:hover { border-color:white; background:rgba(255,255,255,0.10); color:white; text-decoration:none; }
        .hero-img { flex-shrink:0; align-self:flex-end; }
        .hero-img svg { width:200px; height:220px; opacity:0.92; }

        /* ALERTAS */
        .alerts { padding:20px 40px 0; max-width:1160px; margin:0 auto; }
        .alert { padding:12px 18px; border-radius:var(--radius-md); margin-bottom:12px; font-size:13px; font-weight:600; display:flex; align-items:center; gap:8px; animation:fadeDown 0.35s ease both; }
        .alert-success { background:#ecfdf5; color:#065f46; border:1px solid #a7f3d0; }
        .alert-danger  { background:#fff1f2; color:#9f1239; border:1px solid #fecdd3; }

        /* CONTENIDO */
        .content { max-width:1160px; margin:0 auto; padding:36px 40px 80px; }

        /* STATS — 4 tarjetas para mostrar más info */
        .stats-row { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; margin-bottom:24px; }
        .stat-card { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); padding:20px 22px; display:flex; align-items:center; justify-content:space-between; box-shadow:var(--shadow-sm); transition:var(--t); animation:fadeUp 0.4s ease both; }
        .stat-card:hover { box-shadow:var(--shadow-md); transform:translateY(-2px); }
        .stat-card:nth-child(2) { animation-delay:.06s; }
        .stat-card:nth-child(3) { animation-delay:.12s; }
        .stat-card:nth-child(4) { animation-delay:.18s; }
        .stat-label { font-size:11px; font-weight:700; color:var(--ink-3); text-transform:uppercase; letter-spacing:1px; margin-bottom:6px; }
        .stat-num { font-size:42px; font-weight:800; color:var(--ink); letter-spacing:-2px; line-height:1; }
        .stat-icon { width:44px; height:44px; border-radius:var(--radius-md); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
        .stat-icon.pink  { background:var(--pink-light); }
        .stat-icon.pink svg  { color:var(--pink); }
        .stat-icon.green { background:#ecfdf5; }
        .stat-icon.green svg { color:var(--green); }
        .stat-icon.blue  { background:#eff6ff; }
        .stat-icon.blue svg  { color:var(--blue); }
        .stat-icon.orange{ background:#fff7ed; }
        .stat-icon.orange svg{ color:var(--orange); }

        /* SECCIÓN */
        .section-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; animation:fadeUp 0.4s 0.1s ease both; }
        .section-title  { font-size:18px; font-weight:800; color:var(--ink); letter-spacing:-0.3px; }

        /* TABLA */
        .citas-wrap { background:var(--white); border:1px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow-sm); animation:fadeUp 0.4s 0.15s ease both; }
        .tabs { display:flex; border-bottom:1px solid var(--border); padding:0 24px; gap:4px; }
        .tab-btn { padding:14px 16px 13px; font-family:'Plus Jakarta Sans',sans-serif; font-size:13px; font-weight:700; color:var(--ink-3); background:none; border:none; border-bottom:2px solid transparent; margin-bottom:-1px; cursor:pointer; transition:var(--t); }
        .tab-btn.active { color:var(--pink); border-bottom-color:var(--pink); }
        .tab-btn:hover:not(.active) { color:var(--ink-2); }
        .tab-content { display:none; }
        .tab-content.active { display:block; }

        table { width:100%; border-collapse:collapse; }
        thead tr { border-bottom:1px solid var(--border); }
        th { padding:12px 24px; text-align:left; font-size:11px; font-weight:700; color:var(--ink-3); text-transform:uppercase; letter-spacing:1px; }
        td { padding:15px 24px; font-size:14px; font-weight:500; color:var(--ink); border-bottom:1px solid #f0eaee; }
        tbody tr:last-child td { border-bottom:none; }
        tbody tr:hover { background:#fdf8fb; }
        td:first-child { font-weight:700; }

        /* BADGES — estado */
        .badge { display:inline-flex; align-items:center; gap:5px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; }
        .badge::before { content:''; width:5px; height:5px; border-radius:50%; background:currentColor; }

        /* ── Estados exactos de la BD ── */
        .badge-pendiente  { background:#ecfdf5; color:#059669; }   /* verde */
        .badge-confirmada { background:#eff6ff; color:#2563eb; }   /* azul  */
        .badge-finalizada { background:#f0f9ff; color:#0284c7; }   /* azul cielo */
        .badge-cancelada  { background:#fff1f2; color:#e11d48; }   /* rojo */
        .badge-vencida    { background:#fff7ed; color:#ea580c; }   /* naranja */

        td.precio { font-weight:700; color:var(--pink); }
        .btn-cancelar { display:inline-flex; align-items:center; gap:5px; padding:6px 14px; background:#fff1f2; color:#e11d48; border:1px solid #fecdd3; border-radius:var(--radius-sm); font-family:'Plus Jakarta Sans',sans-serif; font-size:12px; font-weight:700; cursor:pointer; transition:var(--t); }
        .btn-cancelar:hover { background:#ffe4e8; border-color:#fca5a5; }

        .empty { padding:56px 20px; text-align:center; }
        .empty-icon { width:52px; height:52px; background:var(--pink-light); border-radius:50%; display:flex; align-items:center; justify-content:center; margin:0 auto 14px; }
        .empty-icon svg { color:var(--pink); }
        .empty h4 { font-size:15px; font-weight:700; color:var(--ink); margin-bottom:4px; }
        .empty p  { font-size:13px; color:var(--ink-3); }

        /* FAB */
        .fab { position:fixed; bottom:28px; right:28px; width:50px; height:50px; background:var(--pink); border-radius:50%; display:flex; align-items:center; justify-content:center; font-size:20px; color:white; text-decoration:none; box-shadow:0 4px 16px rgba(224,0,110,0.35); transition:var(--t); z-index:50; }
        .fab:hover { transform:scale(1.1); background:var(--pink-dark); }

        /* FAVORITOS */
        .favs-section  { margin-top:0; padding-bottom:80px; }
        .favs-header   { display:flex; align-items:center; justify-content:space-between; margin-bottom:16px; }
        .favs-title    { display:flex; align-items:center; gap:8px; font-size:18px; font-weight:800; color:var(--ink); letter-spacing:-0.3px; }
        .favs-title svg { color:var(--pink); }
        .favs-badge    { display:inline-flex; align-items:center; justify-content:center; min-width:20px; height:20px; padding:0 6px; background:var(--pink); color:white; border-radius:10px; font-size:11px; font-weight:800; }
        .favs-grid     { display:grid; grid-template-columns:repeat(auto-fill,minmax(200px,1fr)); gap:14px; }
        .fav-card      { background:var(--white); border:1.5px solid var(--border); border-radius:var(--radius-lg); overflow:hidden; box-shadow:var(--shadow-sm); display:flex; flex-direction:column; transition:transform var(--t),box-shadow var(--t); animation:fadeUp .35s ease both; }
        .fav-card:hover { transform:translateY(-3px); box-shadow:var(--shadow-md); }
        .fav-img        { height:110px; overflow:hidden; }
        .fav-img img    { width:100%; height:100%; object-fit:cover; display:block; transition:transform .35s ease; }
        .fav-card:hover .fav-img img { transform:scale(1.05); }
        .fav-body  { padding:12px 14px; flex:1; }
        .fav-name  { font-size:13px; font-weight:800; color:var(--ink); margin-bottom:3px; line-height:1.3; }
        .fav-meta  { font-size:11px; color:var(--ink-3); font-weight:500; }
        .fav-footer { padding:0 14px 12px; display:flex; gap:6px; }
        .btn-fav-agendar { flex:1; padding:8px; background:var(--pink); color:white; border:none; border-radius:var(--radius-sm); font-family:'Plus Jakarta Sans',sans-serif; font-size:12px; font-weight:700; cursor:pointer; transition:background var(--t); text-decoration:none; display:flex; align-items:center; justify-content:center; }
        .btn-fav-agendar:hover { background:var(--pink-dark); color:white; text-decoration:none; }
        .btn-fav-remove { width:32px; height:32px; border:1.5px solid #fecdd3; background:#fff1f2; border-radius:var(--radius-sm); display:flex; align-items:center; justify-content:center; cursor:pointer; transition:var(--t); flex-shrink:0; }
        .btn-fav-remove:hover { background:#fecdd3; }
        .btn-fav-remove svg { color:#e11d48; }
        .favs-empty { text-align:center; padding:40px 20px; background:var(--white); border:1.5px dashed var(--border); border-radius:var(--radius-lg); }
        .favs-empty svg { color:var(--border); margin-bottom:10px; }
        .favs-empty p  { font-size:13px; color:var(--ink-3); }

        /* ANIMACIONES */
        @@keyframes fadeUp   { from { opacity:0; transform:translateY(16px); } to { opacity:1; transform:translateY(0); } }
        @@keyframes fadeDown { from { opacity:0; transform:translateY(-10px); } to { opacity:1; transform:translateY(0); } }

        /* RESPONSIVE */
        @@media (max-width:900px) { .stats-row { grid-template-columns:1fr 1fr; } }
        @@media (max-width:680px) {
            .navbar { padding:0 16px; }
            .hero   { padding:40px 16px 0; flex-direction:column; }
            .hero-img { display:none; }
            .content  { padding:24px 16px 60px; }
            .alerts   { padding:16px 16px 0; }
            .stats-row { grid-template-columns:1fr 1fr; }
            th:nth-child(3),td:nth-child(3) { display:none; }
            .favs-grid { grid-template-columns:repeat(2,1fr); }
        }
    </style>
</head>
<body>
    @* Token oculto para fetch() POST *@
    <div id="af-holder" style="display:none">@Html.AntiForgeryToken()</div>

    @* NAVBAR *@
    <nav class="navbar">
        <a class="nav-left" href="@Url.Action("Index","Home")">
            <div class="nav-logo">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                    <path d="M9.64 7.64A3.5 3.5 0 1 0 5.5 11c.55 0 1.08-.13 1.55-.36L9 12.59l-2 2A3.5 3.5 0 1 0 9.5 17c0-.69-.2-1.33-.55-1.88L11 13.06l4.59 4.58c.36.36.86.36 1.22 0l.17-.17c.36-.36.36-.86 0-1.22L9.64 7.64z"/>
                </svg>
            </div>
            <span class="nav-brand">Belleza Suprema</span>
        </a>
        <div class="nav-right">
            <a href="@Url.Action("CambiarContrasena","Home")" class="btn-ghost">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                Contraseña
            </a>
            <a href="@Url.Action("Logout","Account")" class="btn-ghost">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                Salir
            </a>
        </div>
    </nav>

    @* HERO *@
    <section class="hero">
        <div class="hero-text">
            <div class="hero-pill"><span></span> Bienvenida, @nombre</div>
            <h1 class="hero-title">Tu agenda de<br />belleza personal</h1>
            <p class="hero-sub">Gestiona tus citas, revisa tu historial y reserva nuevos servicios en segundos.</p>
            <div class="hero-actions">
                <a href="@Url.Action("AgendarCita","Home")" class="btn-hero-white">
                    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Nueva cita
                </a>
                <a href="#citas" class="btn-hero-outline">Ver mis citas</a>
            </div>
        </div>
        <div class="hero-img">
            <svg viewBox="0 0 220 240" fill="none" xmlns="http://www.w3.org/2000/svg">
                <g transform="rotate(-15 80 200)">
                    <rect x="72" y="60" width="16" height="120" rx="8" fill="rgba(255,255,255,0.15)"/>
                    <rect x="74" y="58" width="12" height="14" rx="3" fill="rgba(255,255,255,0.3)"/>
                    <ellipse cx="80" cy="52" rx="14" ry="32" fill="rgba(255,255,255,0.20)"/>
                    <ellipse cx="80" cy="36" rx="10" ry="18" fill="rgba(255,255,255,0.28)"/>
                    <rect x="76" y="175" width="8" height="30" rx="4" fill="rgba(255,255,255,0.35)"/>
                </g>
                <g transform="rotate(10 150 200)">
                    <rect x="138" y="50" width="22" height="140" rx="11" fill="rgba(255,255,255,0.12)"/>
                    <rect x="141" y="47" width="16" height="16" rx="4" fill="rgba(255,255,255,0.25)"/>
                    <ellipse cx="149" cy="40" rx="20" ry="38" fill="rgba(255,255,255,0.18)"/>
                    <ellipse cx="149" cy="20" rx="14" ry="22" fill="rgba(255,255,255,0.26)"/>
                    <rect x="143" y="185" width="12" height="36" rx="6" fill="rgba(255,255,255,0.30)"/>
                </g>
            </svg>
        </div>
    </section>

    @* ALERTAS *@
    @if (TempData["Exito"] != null || TempData["Error"] != null)
    {
        <div class="alerts">
            @if (TempData["Exito"] != null)
            {
                <div class="alert alert-success">
                    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                    @TempData["Exito"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    @TempData["Error"]
                </div>
            }
        </div>
    }

    @* CONTENIDO *@
    <div class="content" id="citas">

        @* ── 4 contadores corregidos ── *@
        @{
            int citasFinalizadas = historialCitas.Count(c => c.Estado == "Finalizada");
            int citasCanceladas  = historialCitas.Count(c => c.Estado == "Cancelada");
        }
        <div class="stats-row">
            <div class="stat-card">
                <div>
                    <div class="stat-label">Próximas citas</div>
                    <div class="stat-num">@proximasCitas.Count</div>
                </div>
                <div class="stat-icon pink">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
            </div>
            <div class="stat-card">
                <div>
                    <div class="stat-label">Total de citas</div>
                    <div class="stat-num">@totalCitas</div>
                </div>
                <div class="stat-icon blue">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
            </div>
            <div class="stat-card">
                <div>
                    <div class="stat-label">Finalizadas</div>
                    <div class="stat-num">@citasFinalizadas</div>
                </div>
                <div class="stat-icon green">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24"><path d="M20 6L9 17l-5-5"/></svg>
                </div>
            </div>
            <div class="stat-card">
                <div>
                    <div class="stat-label">Canceladas</div>
                    <div class="stat-num">@citasCanceladas</div>
                </div>
                <div class="stat-icon orange">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                </div>
            </div>
        </div>

        <div class="section-header">
            <h2 class="section-title">Mis citas</h2>
            <a href="@Url.Action("AgendarCita","Home")" class="btn-primary">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Agendar nueva
            </a>
        </div>

        <div class="citas-wrap">
            <div class="tabs">
                <button class="tab-btn active" onclick="switchTab('proximas',this)">
                    Próximas
                    @if (proximasCitas.Count > 0) { <span style="margin-left:6px;background:var(--pink);color:white;border-radius:10px;padding:1px 7px;font-size:11px;">@proximasCitas.Count</span> }
                </button>
                <button class="tab-btn" onclick="switchTab('historial',this)">Historial</button>
            </div>

            @* TAB PRÓXIMAS *@
            <div id="tab-proximas" class="tab-content active">
                @if (proximasCitas.Count > 0)
                {
                    <table>
                        <thead><tr><th>Servicio</th><th>Fecha</th><th>Hora</th><th>Estado</th><th>Acción</th></tr></thead>
                        <tbody>
                            @foreach (var c in proximasCitas)
                            {
                                <tr>
                                    <td>@c.ServicioNombre</td>
                                    <td>@c.Fecha</td>
                                    <td>@c.HoraInicio – @c.HoraFin</td>
                                    <td>
                                        @{ string estadoCls = (c.Estado ?? "pendiente").ToLower(); }
                                        <span class="badge badge-@estadoCls">@c.Estado</span>
                                    </td>
                                    <td>
                                        @if (c.Estado == "Pendiente" || c.Estado == "Confirmada")
                                        {
                                            using (Html.BeginForm("CancelarCita", "Home", FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="citaId" value="@c.Id" />
                                                <button type="submit" class="btn-cancelar" onclick="return confirm('¿Confirmas la cancelación?')">
                                                    <svg width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                                                    Cancelar
                                                </button>
                                            }
                                        }
                                        else
                                        {
                                            <span style="font-size:12px;color:var(--ink-3);">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty">
                        <div class="empty-icon"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg></div>
                        <h4>Sin citas próximas</h4>
                        <p>Agenda un servicio para verte increíble</p>
                    </div>
                }
            </div>

            @* TAB HISTORIAL *@
            <div id="tab-historial" class="tab-content">
                @if (historialCitas.Count > 0)
                {
                    <table>
                        <thead><tr><th>Servicio</th><th>Fecha</th><th>Hora</th><th>Estado</th><th>Precio</th></tr></thead>
                        <tbody>
                            @foreach (var c in historialCitas)
                            {
                                string estadoCls2 = (c.Estado ?? "").ToLower();
                                <tr>
                                    <td>@c.ServicioNombre</td>
                                    <td>@c.Fecha</td>
                                    <td>@c.HoraInicio</td>
                                    <td><span class="badge badge-@estadoCls2">@c.Estado</span></td>
                                    <td class="precio">$@c.Precio.ToString("N0")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="empty">
                        <div class="empty-icon"><svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div>
                        <h4>Sin historial aún</h4>
                        <p>Tus citas completadas aparecerán aquí</p>
                    </div>
                }
            </div>
        </div>
    </div>

    @* FAVORITOS *@
    <div class="content" style="padding-top:0">
        <div class="favs-section">
            <div class="favs-header">
                <div class="favs-title">
                    <svg width="18" height="18" fill="#e0006e" stroke="#e0006e" stroke-width="1.5" viewBox="0 0 24 24">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                    Mis Favoritos
                    <span class="favs-badge">@favoritos.Count</span>
                </div>
                <a href="@Url.Action("AgendarCita","Home")" class="btn-ghost" style="font-size:12px;padding:6px 14px">Ver todos los servicios</a>
            </div>

            @if (favoritos.Count > 0)
            {
                <div class="favs-grid" id="favsGrid">
                    @{ int fi = 0; }
                    @foreach (var fav in favoritos)
                    {
                        <div class="fav-card" id="favcard-@fav.ServicioId" style="animation-delay:@(fi * 50)ms">
                            <div class="fav-img">
                                <img src="@fav.FotoUrl" alt="@fav.ServicioNombre" loading="lazy" onerror="this.style.display='none'" />
                            </div>
                            <div class="fav-body">
                                <div class="fav-name">@fav.ServicioNombre</div>
                                <div class="fav-meta">@fav.DuracionMin min &nbsp;·&nbsp; $@fav.Precio.ToString("N0")</div>
                            </div>
                            <div class="fav-footer">
                                <a href="@Url.Action("AgendarCita","Home")" class="btn-fav-agendar">Agendar</a>
                                <button class="btn-fav-remove" onclick="quitarFav(this,@fav.ServicioId)" title="Quitar de favoritos">
                                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                                    </svg>
                                </button>
                            </div>
                        </div>
                        fi++;
                    }
                </div>
            }
            else
            {
                <div class="favs-empty" id="favsEmpty">
                    <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                        <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                    </svg>
                    <p>Aún no tienes favoritos. Presiona el &#x1F497; en cualquier servicio para guardarlo aquí.</p>
                </div>
            }
        </div>
    </div>

    <a href="#" class="fab" title="Soporte">💬</a>

    <script>
        var afHolder = document.getElementById('af-holder');
        var AFTOKEN  = afHolder ? afHolder.querySelector('input[name=__RequestVerificationToken]').value : '';

        function quitarFav(btn, servicioId) {
            btn.disabled = true; btn.style.opacity = '0.4';
            fetch('@Url.Action("ToggleFavorito","Home")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: '__RequestVerificationToken=' + encodeURIComponent(AFTOKEN)
                    + '&servicioId=' + servicioId + '&fotoUrl='
            })
            .then(function(r) { return r.json(); })
            .then(function(d) {
                if (d.ok && !d.esFavorito) {
                    var card = document.getElementById('favcard-' + servicioId);
                    if (card) {
                        card.style.transition = 'opacity .3s ease, transform .3s ease';
                        card.style.opacity = '0'; card.style.transform = 'scale(0.88)';
                        setTimeout(function() {
                            card.remove();
                            var badge = document.querySelector('.favs-badge');
                            if (badge) badge.textContent = Math.max(0, parseInt(badge.textContent || '0') - 1);
                            var grid = document.getElementById('favsGrid');
                            if (grid && grid.querySelectorAll('.fav-card').length === 0)
                                grid.outerHTML = '<div class="favs-empty"><p>Ya no tienes favoritos.</p></div>';
                        }, 300);
                    }
                } else { btn.disabled = false; btn.style.opacity = '1'; }
            })
            .catch(function() { btn.disabled = false; btn.style.opacity = '1'; });
        }

        function switchTab(name, btn) {
            document.querySelectorAll('.tab-content').forEach(function(el) { el.classList.remove('active'); });
            document.querySelectorAll('.tab-btn').forEach(function(el) { el.classList.remove('active'); });
            document.getElementById('tab-' + name).classList.add('active');
            btn.classList.add('active');
        }
    </script>
</body>
</html>
