@{
    ViewBag.Title = "Panel Cliente";
    Layout = null;

    var proximasCitas = ViewBag.ProximasCitas as List<BellezaSuprema2.Models.CitaModel> ?? new List<BellezaSuprema2.Models.CitaModel>();
    var historialCitas = ViewBag.HistorialCitas as List<BellezaSuprema2.Models.CitaModel> ?? new List<BellezaSuprema2.Models.CitaModel>();
    long totalCitas = ViewBag.TotalCitas ?? 0;
    string nombre = ViewBag.Nombre ?? "Cliente";
    string genero = ViewBag.Genero ?? "F";   // "M" = masculino, "F" = femenino
    string saludo = genero == "M" ? "Bienvenido" : "Bienvenida";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Panel Cliente — Belleza Suprema</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *, *::before, *::after {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        :root {
            --cream: #faf7f4;
            --white: #ffffff;
            --pink: #e0006e;
            --pink-dark: #b0005a;
            --pink-light: #fce8f3;
            --pink-faint: #fff5f9;
            --ink: #1a0e14;
            --ink-2: #5a4450;
            --ink-3: #9e8895;
            --border: #ede4e9;
            --green: #059669;
            --blue: #2563eb;
            --orange: #ea580c;
            --radius-xl: 20px;
            --radius-lg: 16px;
            --radius-md: 11px;
            --radius-sm: 7px;
            --shadow-sm: 0 1px 4px rgba(26,14,20,0.06);
            --shadow-md: 0 6px 28px rgba(26,14,20,0.10);
            --t: 0.22s ease;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--cream);
            color: var(--ink);
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
        }

        /* ─── NAVBAR ─── */
        .navbar {
            position: sticky;
            top: 0;
            z-index: 100;
            background: rgba(255,255,255,0.96);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border-bottom: 1px solid var(--border);
            height: 64px;
            padding: 0 36px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .nav-left {
            display: flex;
            align-items: center;
            gap: 10px;
            text-decoration: none;
        }

        .nav-logo {
            width: 36px;
            height: 36px;
            background: var(--pink);
            border-radius: 9px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .nav-logo svg {
                color: white;
            }

        .nav-brand {
            font-size: 15px;
            font-weight: 700;
            color: var(--ink);
            letter-spacing: -0.2px;
        }

        .nav-right {
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .btn-ghost {
            padding: 8px 16px;
            border-radius: var(--radius-md);
            border: 1.5px solid var(--border);
            background: transparent;
            color: var(--ink-2);
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: var(--t);
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .btn-ghost:hover {
                border-color: var(--ink);
                color: var(--ink);
                text-decoration: none;
            }

        .btn-primary {
            padding: 9px 20px;
            border-radius: var(--radius-md);
            border: none;
            background: var(--pink);
            color: white;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 700;
            cursor: pointer;
            text-decoration: none;
            transition: var(--t);
            display: flex;
            align-items: center;
            gap: 6px;
        }

            .btn-primary:hover {
                background: var(--pink-dark);
                color: white;
                text-decoration: none;
                transform: translateY(-1px);
                box-shadow: 0 4px 14px rgba(224,0,110,0.30);
            }

        /* ─── HERO WRAPPER ─── */
        .hero-wrapper {
            padding: 16px 36px 0;
        }

        /* ─── HERO BANNER ─── */
        .hero-banner {
            border-radius: var(--radius-xl);
            background: linear-gradient(115deg, #ff0080 0%, #e0006e 50%, #c400b8 100%);
            padding: 48px 56px;
            position: relative;
            overflow: hidden;
            min-height: 230px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

            .hero-banner::before {
                content: '';
                position: absolute;
                top: -80px;
                right: -80px;
                width: 320px;
                height: 320px;
                background: rgba(255,255,255,0.08);
                border-radius: 50%;
            }

            .hero-banner::after {
                content: '';
                position: absolute;
                bottom: -100px;
                right: 100px;
                width: 240px;
                height: 240px;
                background: rgba(255,255,255,0.05);
                border-radius: 50%;
            }

        .hero-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            background: rgba(255,255,255,0.20);
            border: 1px solid rgba(255,255,255,0.32);
            border-radius: 20px;
            padding: 5px 14px;
            font-size: 12px;
            font-weight: 600;
            color: rgba(255,255,255,0.94);
            letter-spacing: 0.3px;
            margin-bottom: 18px;
            width: fit-content;
            position: relative;
            z-index: 1;
        }

        .hero-pill-dot {
            width: 7px;
            height: 7px;
            background: white;
            border-radius: 50%;
        }

        .hero-title {
            font-size: clamp(28px, 4vw, 52px);
            font-weight: 800;
            color: white;
            line-height: 1.05;
            letter-spacing: -1.5px;
            margin-bottom: 12px;
            position: relative;
            z-index: 1;
        }

        .hero-sub {
            font-size: 15px;
            color: rgba(255,255,255,0.82);
            font-weight: 400;
            line-height: 1.65;
            max-width: 500px;
            position: relative;
            z-index: 1;
        }

        /* ─── SERVICE STRIP ─── */
        .services-strip-outer {
            padding: 0 36px;
            overflow: hidden;
            position: relative;
        }

            .services-strip-outer::before,
            .services-strip-outer::after {
                content: '';
                position: absolute;
                top: 0;
                bottom: 0;
                width: 70px;
                z-index: 2;
                pointer-events: none;
            }

            .services-strip-outer::before {
                left: 36px;
                background: linear-gradient(to right, var(--cream) 20%, transparent);
            }

            .services-strip-outer::after {
                right: 36px;
                background: linear-gradient(to left, var(--cream) 20%, transparent);
            }

        .services-strip {
            overflow: hidden;
        }

        .strip-track {
            display: flex;
            gap: 12px;
            padding: 16px 0;
            animation: stripScroll 60s linear infinite; /* más lento: 36s → 60s */
            width: max-content;
            will-change: transform;
        }

            .strip-track:hover {
                animation-play-state: paused;
            }

        @@keyframes stripScroll {
            0% {
                transform: translateX(0);
            }

            100% {
                transform: translateX(-50%);
            }
        }

        .svc-tile {
            position: relative;
            width: 240px;
            height: 155px;
            border-radius: var(--radius-lg);
            overflow: hidden;
            flex-shrink: 0;
            cursor: pointer;
            box-shadow: 0 2px 10px rgba(26,14,20,0.10);
            transition: transform var(--t), box-shadow var(--t);
        }

            .svc-tile:hover {
                transform: translateY(-5px) scale(1.015);
                box-shadow: var(--shadow-md);
            }

            .svc-tile img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
                transition: transform 0.5s ease;
            }

            .svc-tile:hover img {
                transform: scale(1.09);
            }

        .svc-tile-overlay {
            position: absolute;
            inset: 0;
            background: linear-gradient(to top, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.05) 55%);
        }

        .svc-tile-label {
            position: absolute;
            bottom: 12px;
            left: 14px;
            font-size: 13px;
            font-weight: 700;
            color: white;
            text-shadow: 0 1px 6px rgba(0,0,0,0.45);
        }

        /* ─── ALERTS ─── */
        .alerts {
            padding: 20px 36px 0;
        }

        .alert {
            padding: 12px 18px;
            border-radius: var(--radius-md);
            margin-bottom: 12px;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 8px;
            animation: fadeDown 0.35s ease both;
        }

        .alert-success {
            background: #ecfdf5;
            color: #065f46;
            border: 1px solid #a7f3d0;
        }

        .alert-danger {
            background: #fff1f2;
            color: #9f1239;
            border: 1px solid #fecdd3;
        }

        /* ─── CONTENT ─── */
        .content {
            padding: 32px 36px 80px;
        }

        /* ─── STATS ─── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(4,1fr);
            gap: 14px;
            margin-bottom: 28px;
        }

        .stat-card {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 20px 22px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            box-shadow: var(--shadow-sm);
            transition: var(--t);
            animation: fadeUp 0.4s ease both;
        }

            .stat-card:hover {
                box-shadow: var(--shadow-md);
                transform: translateY(-2px);
            }

            .stat-card:nth-child(2) {
                animation-delay: .06s;
            }

            .stat-card:nth-child(3) {
                animation-delay: .12s;
            }

            .stat-card:nth-child(4) {
                animation-delay: .18s;
            }

        .stat-label {
            font-size: 10px;
            font-weight: 700;
            color: var(--ink-3);
            text-transform: uppercase;
            letter-spacing: 1.2px;
            margin-bottom: 6px;
        }

        .stat-num {
            font-size: 42px;
            font-weight: 800;
            color: var(--ink);
            letter-spacing: -2px;
            line-height: 1;
        }

        .stat-icon {
            width: 44px;
            height: 44px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

            .stat-icon.pink {
                background: var(--pink-light);
            }

                .stat-icon.pink svg {
                    color: var(--pink);
                }

            .stat-icon.green {
                background: #ecfdf5;
            }

                .stat-icon.green svg {
                    color: var(--green);
                }

            .stat-icon.blue {
                background: #eff6ff;
            }

                .stat-icon.blue svg {
                    color: var(--blue);
                }

            .stat-icon.orange {
                background: #fff7ed;
            }

                .stat-icon.orange svg {
                    color: var(--orange);
                }

        /* ─── SECTION HEADER ─── */
        .section-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
            animation: fadeUp 0.4s 0.1s ease both;
        }

        .section-title {
            font-size: 18px;
            font-weight: 800;
            color: var(--ink);
            letter-spacing: -0.3px;
        }

        /* ─── TABLE WRAP ─── */
        .citas-wrap {
            background: var(--white);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            animation: fadeUp 0.4s 0.15s ease both;
        }

        .tabs {
            display: flex;
            border-bottom: 1px solid var(--border);
            padding: 0 24px;
            gap: 4px;
        }

        .tab-btn {
            padding: 14px 16px 13px;
            font-family: 'DM Sans', sans-serif;
            font-size: 13px;
            font-weight: 700;
            color: var(--ink-3);
            background: none;
            border: none;
            border-bottom: 2px solid transparent;
            margin-bottom: -1px;
            cursor: pointer;
            transition: var(--t);
        }

            .tab-btn.active {
                color: var(--pink);
                border-bottom-color: var(--pink);
            }

            .tab-btn:hover:not(.active) {
                color: var(--ink-2);
            }

        .tab-content {
            display: none;
        }

            .tab-content.active {
                display: block;
            }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        thead tr {
            border-bottom: 1px solid var(--border);
            background: #fdf8fb;
        }

        th {
            padding: 11px 24px;
            text-align: left;
            font-size: 10px;
            font-weight: 700;
            color: var(--ink-3);
            text-transform: uppercase;
            letter-spacing: 1.2px;
        }

        td {
            padding: 15px 24px;
            font-size: 14px;
            font-weight: 500;
            color: var(--ink);
            border-bottom: 1px solid #f4edf1;
        }

        tbody tr:last-child td {
            border-bottom: none;
        }

        tbody tr:hover {
            background: var(--pink-faint);
        }

        td:first-child {
            font-weight: 700;
        }

        .badge {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 3px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
        }

            .badge::before {
                content: '';
                width: 5px;
                height: 5px;
                border-radius: 50%;
                background: currentColor;
            }

        .badge-pendiente {
            background: #ecfdf5;
            color: #059669;
        }

        .badge-confirmada {
            background: #eff6ff;
            color: #2563eb;
        }

        .badge-finalizada {
            background: #f0f9ff;
            color: #0284c7;
        }

        .badge-cancelada {
            background: #fff1f2;
            color: #e11d48;
        }

        .badge-vencida {
            background: #fff7ed;
            color: #ea580c;
        }

        td.precio {
            font-weight: 700;
            color: var(--pink);
        }

        .btn-cancelar {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 6px 14px;
            background: #fff1f2;
            color: #e11d48;
            border: 1px solid #fecdd3;
            border-radius: var(--radius-sm);
            font-family: 'DM Sans', sans-serif;
            font-size: 12px;
            font-weight: 700;
            cursor: pointer;
            transition: var(--t);
        }

            .btn-cancelar:hover {
                background: #ffe4e8;
                border-color: #fca5a5;
            }

        .empty {
            padding: 56px 20px;
            text-align: center;
        }

        .empty-icon {
            width: 52px;
            height: 52px;
            background: var(--pink-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 14px;
        }

            .empty-icon svg {
                color: var(--pink);
            }

        .empty h4 {
            font-size: 15px;
            font-weight: 700;
            color: var(--ink);
            margin-bottom: 4px;
        }

        .empty p {
            font-size: 13px;
            color: var(--ink-3);
        }

        /* ─── FAB ─── */
        .fab {
            position: fixed;
            bottom: 28px;
            right: 28px;
            width: 50px;
            height: 50px;
            background: var(--pink);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: white;
            text-decoration: none;
            box-shadow: 0 4px 16px rgba(224,0,110,0.35);
            transition: var(--t);
            z-index: 50;
        }

            .fab:hover {
                transform: scale(1.1);
                background: var(--pink-dark);
            }

        /* ─── ANIMATIONS ─── */
        @@keyframes fadeUp {
            from {
                opacity: 0;
                transform: translateY(16px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeDown {
            from {
                opacity: 0;
                transform: translateY(-10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* ─── RESPONSIVE ─── */
        @@media (max-width:900px) {
            .stats-row {
                grid-template-columns: 1fr 1fr;
            }
        }

        @@media (max-width:680px) {
            .navbar {
                padding: 0 16px;
            }

            .hero-wrapper {
                padding: 12px 16px 0;
            }

            .hero-banner {
                padding: 32px 24px;
            }

            .services-strip-outer {
                padding: 0 16px;
            }

                .services-strip-outer::before {
                    left: 16px;
                }

                .services-strip-outer::after {
                    right: 16px;
                }

            .content {
                padding: 24px 16px 60px;
            }

            .alerts {
                padding: 16px 16px 0;
            }

            .stats-row {
                grid-template-columns: 1fr 1fr;
            }

            th:nth-child(3), td:nth-child(3) {
                display: none;
            }

            .svc-tile {
                width: 180px;
                height: 120px;
            }
        }
    </style>
</head>
<body>
    @* Token oculto para fetch() POST *@
    <div id="af-holder" style="display:none">@Html.AntiForgeryToken()</div>

    @* ─── NAVBAR ─── *@
    <nav class="navbar">
        <a class="nav-left" href="@Url.Action("Index","Home")">
            <div class="nav-logo">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                    <path d="M9.64 7.64A3.5 3.5 0 1 0 5.5 11c.55 0 1.08-.13 1.55-.36L9 12.59l-2 2A3.5 3.5 0 1 0 9.5 17c0-.69-.2-1.33-.55-1.88L11 13.06l4.59 4.58c.36.36.86.36 1.22 0l.17-.17c.36-.36.36-.86 0-1.22L9.64 7.64z" />
                </svg>
            </div>
            <span class="nav-brand">Belleza Suprema</span>
        </a>
        <div class="nav-right">
            <a href="@Url.Action("Logout","Account")" class="btn-ghost">
                <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" /><polyline points="16 17 21 12 16 7" /><line x1="21" y1="12" x2="9" y2="12" /></svg>
                Salir
            </a>
        </div>
    </nav>

    @* ─── HERO BANNER ─── *@
    <div class="hero-wrapper">
        <div class="hero-banner">
            <div class="hero-pill">
                <span class="hero-pill-dot"></span>
                @saludo, @nombre
            </div>
            <h1 class="hero-title">Tu agenda de<br />belleza personal</h1>
            <p class="hero-sub">Gestiona tus citas, revisa tu historial y reserva nuevos servicios en segundos.</p>
        </div>
    </div>

    @* ─── TIRA DE SERVICIOS ANIMADA ─── *@
    <div class="services-strip-outer">
        <div class="services-strip">
            <div class="strip-track">

                <!-- ── SET 1 ── -->
                <div class="svc-tile">
                    <img src="https://images.unsplash.com/photo-1604654894610-df63bc536371?w=480&q=80&auto=format&fit=crop" alt="Manicura" loading="lazy" />
                    <div class="svc-tile-overlay"></div>
                    <span class="svc-tile-label">Manicura</span>
                </div>
                <div class="svc-tile">
                    <img src="https://images.unsplash.com/photo-1487412947147-5cebf100ffc2?w=480&q=80&auto=format&fit=crop" alt="Maquillaje" loading="lazy" />
                    <div class="svc-tile-overlay"></div>
                    <span class="svc-tile-label">Maquillaje</span>
                </div>
                <div class="svc-tile">
                    <img src="https://images.unsplash.com/photo-1544161515-4ab6ce6db874?w=480&q=80&auto=format&fit=crop" alt="Masajes" loading="lazy" />
                    <div class="svc-tile-overlay"></div>
                    <span class="svc-tile-label">Masajes</span>
                </div>
                <div class="svc-tile">
                    <img src="https://images.unsplash.com/photo-1570172619644-dfd03ed5d881?w=480&q=80&auto=format&fit=crop" alt="Tratamientos Faciales" loading="lazy" />
                    <div class="svc-tile-overlay"></div>
                    <span class="svc-tile-label">Tratamientos Faciales</span>
                </div>
                <div class="svc-tile">
                    <img src="https://images.unsplash.com/photo-1522337360788-8b13dee7a37e?w=480&q=80&auto=format&fit=crop" alt="Peinados" loading="lazy" />
                    <div class="svc-tile-overlay"></div>
                    <span class="svc-tile-label">Peinados</span>
                </div>
                <div class="svc-tile">
                    <img src="https://images.unsplash.com/photo-1519014816548-bf5fe059798b?w=480&q=80&auto=format&fit=crop" alt="Depilación" loading="lazy" />
                    <div class="svc-tile-overlay"></div>
                    <span class="svc-tile-label">Depilación</span>
                </div>
                <div class="svc-tile">
                    <img src="https://images.unsplash.com/photo-1560066984-138dadb4c035?w=480&q=80&auto=format&fit=crop" alt="Pedicura" loading="lazy" />
                    <div class="svc-tile-overlay"></div>
                    <span class="svc-tile-label">Pedicura</span>
                </div>
                <div class="svc-tile">
                    <img src="https://images.unsplash.com/photo-1527799820374-dcf8d9d4a388?w=480&q=80&auto=format&fit=crop" alt="Cejas y Pestañas" loading="lazy" />
                    <div class="svc-tile-overlay"></div>
                    <span class="svc-tile-label">Cejas y Pestañas</span>
                </div>
                <div class="svc-tile">
                    <img src="https://images.unsplash.com/photo-1626015449625-408edf40e0ae?w=480&q=80&auto=format&fit=crop" alt="Colorimetría" loading="lazy" />
                    <div class="svc-tile-overlay"></div>
                    <span class="svc-tile-label">Colorimetría</span>
                </div>
                <div class="svc-tile">
                    <img src="https://images.unsplash.com/photo-1531383074173-4fc98b9f8994?w=480&q=80&auto=format&fit=crop" alt="Spa" loading="lazy" />
