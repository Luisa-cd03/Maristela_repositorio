                (usuario && usuario.Telefono ? ' · ' + usuario.Telefono : '') + '</div>' +
                '<div style="margin-top:6px;display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.15);padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700">' +
                '⭐ Fidelización: ' + fidel +
                '</div>' +
                '</div>' +
                '</div>' +
                '</div>' +
