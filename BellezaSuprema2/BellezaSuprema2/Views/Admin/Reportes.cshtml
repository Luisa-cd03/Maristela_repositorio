// ════════════════════════════════════════
function poblarClienteSelect() {
    var sel=document.getElementById('cli-select');
    if(sel.options.length>1) return; // ya poblado
    var clientes=[];
    _usuarios.filter(function(u){return u.Role==='Cliente'||!u.Role;}).forEach(function(u){
        if(u.Nombre && clientes.indexOf(u.Nombre)===-1) clientes.push(u.Nombre);
    });
    clientes.sort().forEach(function(n){
        var o=document.createElement('option'); o.value=o.textContent=n; sel.appendChild(o);
    });
}

function clienteSeleccionar() {
    var nombre=document.getElementById('cli-select').value;
    if(!nombre){
        document.getElementById('cli-perfil').innerHTML='<div class="empty"><svg fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg><p>Seleccione un cliente de la lista.</p></div>';
        return;
    }
    var usuario=_usuarios.find(function(u){return u.Nombre===nombre;});
    var citas=_citas.filter(function(c){return c.NombreCliente&&c.NombreCliente.toLowerCase()===nombre.toLowerCase();});
    var totGast=citas.filter(function(c){return c.Estado==='Finalizada';}).reduce(function(s,c){return s+(c.Precio||0);},0);
    var canc=citas.filter(function(c){return c.Estado==='Cancelada';}).length;
    var smap={};
    citas.forEach(function(c){if(c.ServicioNombre) smap[c.ServicioNombre]=(smap[c.ServicioNombre]||0)+1;});
    var favServ=Object.keys(smap).sort(function(a,b){return smap[b]-smap[a];})[0]||'—';
    var ultVisita=citas.filter(function(c){return c.Estado==='Finalizada';}).sort(function(a,b){return b.Fecha.localeCompare(a.Fecha);})[0];
    var fidel=citas.length>=8?'Alta':citas.length>=3?'Media':'Baja';
    var fidelColor=fidel==='Alta'?'#059669':fidel==='Media'?'#d97706':'#dc2626';

    document.getElementById('cli-perfil').innerHTML =
        '<div class="dash-hero" style="margin-bottom:16px">'+
          '<div style="display:flex;align-items:center;gap:16px">'+
            '<div style="width:52px;height:52px;border-radius:50%;background:rgba(255,255,255,.2);border:2px solid rgba(255,255,255,.4);display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:800;color:#fff;flex-shrink:0">'+
              (nombre[0]||'?').toUpperCase()+'</div>'+
            '<div>'+
              '<div style="font-size:20px;font-weight:700">'+nombre+'</div>'+
              '<div style="font-size:12px;opacity:.8">'+(usuario?usuario.Email||'':'')+
              (usuario&&usuario.Telefono?' · '+usuario.Telefono:'')+'</div>'+
              '<div style="margin-top:6px;display:inline-flex;align-items:center;gap:5px;background:rgba(255,255,255,.15);padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700">'+
                '⭐ Fidelización: '+fidel+
              '</div>'+
            '</div>'+
          '</div>'+
        '</div>'+
        '<div class="kpi-grid">'+
          '<div class="kpi-card"><div class="kpi-left"><div class="kpi-label">Total Citas</div><div class="kpi-value" style="color:#7c3aed">'+citas.length+'</div><div class="kpi-sub">'+canc+' cancelaciones</div></div></div>'+
          '<div class="kpi-card"><div class="kpi-left"><div class="kpi-label">Total Gastado</div><div class="kpi-value" style="color:#059669;font-size:18px">$'+totGast.toLocaleString('es-CO')+'</div></div></div>'+
          '<div class="kpi-card"><div class="kpi-left"><div class="kpi-label">Servicio Favorito</div><div class="kpi-value" style="font-size:14px">'+favServ+'</div><div class="kpi-sub">Última visita: '+(ultVisita?ultVisita.Fecha:'N/A')+'</div></div></div>'+
        '</div>'+
        '<div class="card"><div class="card-title">Historial de Citas</div>'+
          '<div class="table-wrap">'+
            '<table class="rep-tbl"><thead><tr><th>Fecha</th><th>Servicio</th><th>Estado</th><th>Precio</th></tr></thead>'+
            '<tbody>'+citas.sort(function(a,b){return b.Fecha.localeCompare(a.Fecha);}).map(function(c){
                return '<tr><td>'+c.Fecha+'</td><td>'+c.ServicioNombre+'</td>'+
                    '<td><span class="badge badge-'+badgeCls(c.Estado)+'">'+c.Estado+'</span></td>'+
                    '<td>$'+Number(c.Precio||0).toLocaleString('es-CO')+'</td></tr>';
              }).join('')+
            '</tbody></table>'+
          '</div>'+
        '</div>';
}

// ════════════════════════════════════════
// EXPORTAR CSV
// ════════════════════════════════════════
function exportarCSV() {
    if(!_citas.length){ toast('Sin datos para exportar','err'); return; }
    var cab=['NombreCliente','ServicioNombre','Fecha','HoraInicio','Precio','Estado'];
    var rows=_citas.map(function(c){
        return [c.NombreCliente,c.ServicioNombre,c.Fecha,c.HoraInicio,c.Precio,c.Estado]
               .map(function(v){return '"'+(v||'')+'"';}).join(',');
    });
    var csv=[cab.join(',')].concat(rows).join('\n');
    var blob=new Blob(['\uFEFF'+csv],{type:'text/csv;charset=utf-8;'});
    var a=document.createElement('a'); a.href=URL.createObjectURL(blob);
    a.download='Belleza_Suprema_'+_paginaActual+'_'+fmtF(new Date())+'.csv'; a.click();
    toast('CSV descargado ✅','ok');
}

