function exportarPDF() {
    var btn=document.getElementById('btn-pdf-main');
    btn.textContent='⏳ Generando...'; btn.disabled=true;
    setTimeout(function(){
        try{ _buildPDF(); }catch(e){ toast('Error PDF: '+e.message,'err'); }
        btn.innerHTML='<svg width="13" height="13" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Exportar PDF';
        btn.disabled=false;
    },150);
}

function _buildPDF(){
    var doc=new window.jspdf.jsPDF({orientation:'portrait',unit:'mm',format:'a4'});
    var W=210, H=297;
    var ahora=new Date();
    var fecha=ahora.toLocaleDateString('es-CO',{day:'2-digit',month:'long',year:'numeric'});
    var pageNames={dashboard:'Dashboard General',citas:'Citas Agendadas',
        comparativa:'Comparativa de Reservas',servicios:'Reporte de Servicios',
        ganancias:'Reporte de Ganancias',proximas:'Próximas Citas',clientes:'Clientes'};
    var pNombre=pageNames[_paginaActual]||'Reporte';

    // PORTADA
    doc.setFillColor(232,0,107); doc.rect(0,0,W,70,'F');
    doc.setFillColor(124,58,237); doc.rect(0,45,W,25,'F');
    // Logo
    doc.setFillColor(255,255,255); doc.setGlobalAlpha(.15);
    doc.roundedRect(14,12,22,22,4,4,'F'); doc.setGlobalAlpha(1);
    doc.setFontSize(13); doc.setTextColor(255,255,255); doc.setFont('helvetica','bold');
    doc.text('BS',25,26,{align:'center'});
    doc.setFontSize(20); doc.text('Beauty Salon',42,22);
    doc.setFontSize(9); doc.setFont('helvetica','normal'); doc.setTextColor(255,210,230);
    doc.text('Sistema de Reportes Administrativos',42,30);
    doc.setDrawColor(255,255,255); doc.setGlobalAlpha(.3); doc.line(14,34,W-14,34); doc.setGlobalAlpha(1);
    doc.setFontSize(24); doc.setTextColor(255,255,255); doc.setFont('helvetica','bold');
    doc.text(pNombre,14,52);
    doc.setFontSize(9); doc.setFont('helvetica','normal'); doc.setTextColor(220,190,255);
    doc.text('Generado el '+fecha,14,63);

    // Cuerpo portada
    doc.setFillColor(244,245,247); doc.rect(0,70,W,H-70,'F');
    doc.setFontSize(11); doc.setFont('helvetica','bold'); doc.setTextColor(17,24,39);
    doc.text('Resumen de Datos',14,88);
    doc.setFillColor(232,0,107); doc.rect(14,90,20,1,'F');

    // KPIs en portada
    var kpi=_kpi||{};
    var kpis=[[' Total Citas',kpi.TotalCitas||0],[' Finalizadas',kpi.CitasFinalizadas||0],
               [' Pendientes',kpi.CitasPendientes||0],[' Canceladas',kpi.CitasCanceladas||0]];
    var cw=(W-28)/4;
    doc.setFillColor(255,255,255); doc.setDrawColor(230,225,245); doc.setLineWidth(.4);
    doc.roundedRect(14,95,W-28,36,3,3,'FD');
    kpis.forEach(function(k,i){
        var x=14+i*cw+cw/2;
        doc.setFontSize(20); doc.setFont('helvetica','bold'); doc.setTextColor(232,0,107);
        doc.text(String(k[1]),x,112,{align:'center'});
        doc.setFontSize(8); doc.setFont('helvetica','normal'); doc.setTextColor(156,163,175);
        doc.text(k[0],x,120,{align:'center'});
        if(i<3){doc.setDrawColor(230,225,245); doc.line(14+(i+1)*cw,98,14+(i+1)*cw,128);}
    });

    // Gráficas
    doc.setFontSize(11); doc.setFont('helvetica','bold'); doc.setTextColor(17,24,39);
    doc.text('Análisis Visual',14,148);
    doc.setFillColor(232,0,107); doc.rect(14,150,20,1,'F');

    var canvasMap={
        dashboard:['d-chart-estados','d-chart-servicios','d-chart-ingresos'],
        citas:['c-chart-estado','c-chart-evol'],
        comparativa:['comp-chart-mensual','comp-chart-reservas'],
        servicios:['serv-chart-pastel','serv-chart-ingresos'],
        ganancias:['gan-chart-evol','gan-chart-comp'],
        proximas:[],clientes:[]
    };
    var yPos=155;
    (canvasMap[_paginaActual]||[]).slice(0,2).forEach(function(id){
        var c=document.getElementById(id); if(!c) return;
        try{
            var img=c.toDataURL('image/png',.9);
            var iw=85, ih=55;
            doc.setFillColor(255,255,255); doc.setDrawColor(230,225,245); doc.roundedRect(14,yPos,iw+4,ih+8,3,3,'FD');
            doc.addImage(img,'PNG',16,yPos+4,iw,ih);
            yPos+=ih+14;
        }catch(e){}
    });

    // Pie portada
    doc.setFillColor(232,0,107); doc.rect(0,H-14,W,14,'F');
    doc.setFontSize(8); doc.setTextColor(255,200,220);
    doc.text('Beauty Salon · Sistema de Reportes · Confidencial',W/2,H-6,{align:'center'});

    // PÁGINA 2 — TABLA DE DATOS
    doc.addPage();
    doc.setFillColor(232,0,107); doc.rect(0,0,W,14,'F');
    doc.setFontSize(9); doc.setFont('helvetica','bold'); doc.setTextColor(255,255,255);
    doc.text('Beauty Salon · '+pNombre,14,9); doc.text('Página 2',W-14,9,{align:'right'});
    doc.setFontSize(13); doc.setFont('helvetica','bold'); doc.setTextColor(17,24,39);
    doc.text('Detalle de Datos',14,26);
    doc.setFillColor(232,0,107); doc.rect(14,28,20,1,'F');

    var tData=_getTablaData(_paginaActual);
    if(tData.rows.length){
        doc.autoTable({
            startY:33, head:[tData.cols], body:tData.rows,
            styles:{font:'helvetica',fontSize:8,cellPadding:4,lineColor:[230,225,245],lineWidth:.3},
            headStyles:{fillColor:[232,0,107],textColor:[255,255,255],fontStyle:'bold',fontSize:8.5,halign:'center'},
            alternateRowStyles:{fillColor:[249,250,251]},
            columnStyles:{0:{fontStyle:'bold'}},
            margin:{top:20,bottom:18,left:14,right:14},
            didDrawPage:function(){
                doc.setFillColor(232,0,107); doc.rect(0,0,W,14,'F');
                doc.setFontSize(9); doc.setFont('helvetica','bold'); doc.setTextColor(255,255,255);
                doc.text('Beauty Salon · '+pNombre,14,9);
                doc.text('Página '+doc.internal.getNumberOfPages(),W-14,9,{align:'right'});
                doc.setFillColor(232,0,107); doc.rect(0,H-14,W,14,'F');
                doc.setFontSize(8); doc.setTextColor(255,200,220);
                doc.text('Beauty Salon · Confidencial',W/2,H-6,{align:'center'});
            }
        });
    }

    doc.save('BeautySalon_'+pNombre.replace(/ /g,'_')+'_'+fmtF(ahora)+'.pdf');
    toast('✅ PDF generado correctamente','ok');
}

function _getTablaData(p){
    switch(p){
        case 'citas': case 'dashboard':
            return{cols:['Cliente','Servicio','Fecha','Hora','Precio','Estado'],
                   rows:_citas.map(function(c){return[c.NombreCliente||'—',c.ServicioNombre||'—',c.Fecha||'—',c.HoraInicio||'—','$'+Number(c.Precio||0).toLocaleString('es-CO'),c.Estado||'—'];})};
        case 'servicios':{
            var smap={};
            _citas.forEach(function(c){var n=c.ServicioNombre||'—';if(!smap[n])smap[n]={c:0,i:0};smap[n].c++;if(c.Estado==='Finalizada')smap[n].i+=(c.Precio||0);});
            var tot=Object.values(smap).reduce(function(s,x){return s+x.c;},0);
            return{cols:['Servicio','Citas','Ingresos','% Part.'],
                   rows:Object.entries(smap).sort(function(a,b){return b[1].c-a[1].c;}).map(function(e){
                       return[e[0],e[1].c,'$'+e[1].i.toLocaleString('es-CO'),tot>0?(e[1].c/tot*100).toFixed(1)+'%':'0%'];
                   })};
        }
        case 'ganancias':{
            var mmap={};
            _citas.forEach(function(c){if(!c.Fecha)return;var m=c.Fecha.substring(0,7);if(!mmap[m])mmap[m]={i:0,f:0};if(c.Estado==='Finalizada'){mmap[m].i+=(c.Precio||0);mmap[m].f++;}});
            return{cols:['Mes','Ingresos','Citas','Ticket'],
                   rows:Object.keys(mmap).sort().map(function(m){var d=mmap[m];return[MESES_ES[parseInt(m.split('-')[1])-1]+' '+m.split('-')[0],'$'+d.i.toLocaleString('es-CO'),d.f,'$'+(d.f>0?Math.round(d.i/d.f):0).toLocaleString('es-CO')];})};
        }
        default:
            return{cols:['Campo','Valor'],rows:[['Sin datos','—']]};
    }
}

// ════════════════════════════════════════
// UTILS
// ════════════════════════════════════════
function mkChart(id, tipo, data, options) {
    if(_charts[id]){_charts[id].destroy();}
    var el=document.getElementById(id); if(!el) return;
    var base={responsive:true,maintainAspectRatio:false,
        plugins:{legend:{labels:{font:{family:"'DM Sans'",size:11},boxWidth:12}}},
        scales:tipo!=='doughnut'&&tipo!=='pie'?{
            x:{grid:{color:'#f3f4f6',lineWidth:.8},ticks:{font:{family:"'DM Sans'",size:11}}},
            y:{grid:{color:'#f3f4f6',lineWidth:.8},ticks:{font:{family:"'DM Sans'",size:11}}}
        }:undefined};
    var merged=mergeDeep(base, options||{});
    _charts[id]=new Chart(el,{type:tipo,data:data,options:merged});
}

function mergeDeep(target,source){
    var out=Object.assign({},target);
    if(isObj(target)&&isObj(source)){
        Object.keys(source).forEach(function(k){
            if(isObj(source[k])){if(!target[k]) out[k]={};out[k]=mergeDeep(target[k],source[k]);}
            else out[k]=source[k];
        });
    }
    return out;
}
function isObj(o){return o&&typeof o==='object'&&!Array.isArray(o);}
function setEl(id,v){var el=document.getElementById(id);if(el) el.textContent=v;}
function badgeCls(e){return{Pendiente:'pend',Confirmada:'conf',Finalizada:'fin',Cancelada:'canc'}[e]||'pend';}
function fmtF(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function toast(msg,tipo){var t=document.getElementById('rep-toast');t.textContent=msg;t.className='rep-toast '+(tipo||'ok');t.style.display='block';clearTimeout(t._t);t._t=setTimeout(function(){t.style.display='none';},3500);}

// Arrancar
window.addEventListener('DOMContentLoaded', cargarTodo);</script>
