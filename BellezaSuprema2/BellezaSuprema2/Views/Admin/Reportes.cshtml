            var favServ = Object.keys(smap).sort(function (a, b) { return smap[b] - smap[a]; })[0] || '—';
            var ultVisita = citas.filter(function (c) { return c.Estado === 'Finalizada'; }).sort(function (a, b) { return b.Fecha.localeCompare(a.Fecha); })[0];
