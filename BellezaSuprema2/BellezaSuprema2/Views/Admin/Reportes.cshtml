                '<div class="kpi-card"><div class="kpi-left"><div class="kpi-label">Total Citas</div><div class="kpi-value" style="color:#7c3aed">' + citas.length + '</div><div class="kpi-sub">' + canc + ' cancelaciones</div></div></div>' +
                '<div class="kpi-card"><div class="kpi-left"><div class="kpi-label">Total Gastado</div><div class="kpi-value" style="color:#059669;font-size:18px">$' + totGast.toLocaleString('es-CO') + '</div></div></div>' +
                '<div class="kpi-card"><div class="kpi-left"><div class="kpi-label">Servicio Favorito</div><div class="kpi-value" style="font-size:14px">' + favServ + '</div><div class="kpi-sub">Última visita: ' + (ultVisita ? ultVisita.Fecha : 'N/A') + '</div></div></div>' +
                '</div>' +
