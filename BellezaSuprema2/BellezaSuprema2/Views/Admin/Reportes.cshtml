    <div class="rep-toast" id="rep-toast"></div>
    <script>
        // ═══════════════════════════════════════════════════════════════
        // REPORTES AVANZADOS — Beauty Salon
        // Endpoints: GET /Admin/GetCitas, /Admin/GetTodosUsuarios, /Admin/GetReportes
        // ═══════════════════════════════════════════════════════════════

        var _citas = [], _usuarios = [], _kpi = null;
        var _cargado = false;
        var _charts = {};
        var _paginaActual = 'dashboard';
        var MESES_ES = ['Enero', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];
        var COLORES = ['#e8006b', '#7c3aed', '#2563eb', '#059669', '#d97706', '#dc2626', '#0891b2', '#7c3aed', '#ea580c'];

        // ── Navegación ──────────────────────────────────────────────
        function navGo(pagina, btn) {
            document.querySelectorAll('.nav-item').forEach(function (b) { b.classList.remove('active'); });
            if (btn) btn.classList.add('active');
            document.querySelectorAll('.page').forEach(function (p) { p.classList.remove('active'); });
            document.getElementById('page-' + pagina).classList.add('active');
            _paginaActual = pagina;
            var titles = {
                dashboard: 'Dashboard General', citas: 'Citas Agendadas',
                comparativa: 'Comparativa de Reservas', servicios: 'Reporte de Servicios',
                ganancias: 'Reporte de Ganancias', proximas: 'Próximas Citas', clientes: 'Clientes'
            };
            document.getElementById('topbar-title').textContent = titles[pagina] || 'Reportes';
            if (!_cargado) { cargarTodo(); return; }
            renderPagina(pagina);
        }

        // ── Carga de datos ───────────────────────────────────────────
        function cargarTodo() {
            Promise.all([
                fetch('/Admin/GetCitas').then(function (r) { return r.json(); }),
                fetch('/Admin/GetTodosUsuarios').then(function (r) { return r.json(); }),
                fetch('/Admin/GetReportes').then(function (r) { return r.json(); })
            ]).then(function (res) {
                _citas = res[0];
                _usuarios = res[1];
                _kpi = res[2];
                // ── DEBUG: ver estados que llegan del servidor ──
                var estados = {};
                _citas.forEach(function (c) { estados[c.Estado] = (estados[c.Estado] || 0) + 1; });
                console.log('[Reportes] Citas cargadas:', _citas.length, '| Por estado:', estados);
                // ── fin debug ──
                _cargado = true;
                poblarFiltros();
                renderPagina(_paginaActual);
            }).catch(function (err) {
                console.error('Error cargando datos:', err);
                toast('Error al conectar con el servidor.', 'err');
            });
        }

        function renderPagina(p) {
            if (p === 'dashboard') renderDashboard();
            else if (p === 'citas') citasFiltrar();
            else if (p === 'comparativa') renderComparativa();
            else if (p === 'servicios') renderServicios();
            else if (p === 'ganancias') renderGanancias();
            else if (p === 'proximas') proximasFiltrar();
            else if (p === 'clientes') poblarClienteSelect();
        }

        function poblarFiltros() {
            var servs = [];
            _citas.forEach(function (c) { if (c.ServicioNombre && servs.indexOf(c.ServicioNombre) === -1) servs.push(c.ServicioNombre); });
            var sel = document.getElementById('c-servicio');
            servs.forEach(function (s) { var o = document.createElement('option'); o.value = o.textContent = s; sel.appendChild(o); });
        }

        // ════════════════════════════════════════
        // DASHBOARD
        // ════════════════════════════════════════
        function renderDashboard() {
            var kpi = _kpi || {};
            var t = kpi.TotalCitas || 0;
            var fin = kpi.CitasFinalizadas || 0;
            var ing = kpi.IngresosEstimados || 0;
            var ticket = fin > 0 ? Math.round(ing / fin) : 0;

            setEl('d-total', t);
            setEl('d-fin', fin);
            setEl('d-ingresos', '$' + (ing / 1000).toFixed(0) + 'K');
            setEl('d-ticket', '$' + (ticket / 1000).toFixed(1) + 'K');
            setEl('d-tasa-asist', t > 0 ? (fin / t * 100).toFixed(1) + '%' : '0%');
            setEl('d-tasa-canc', t > 0 ? ((kpi.CitasCanceladas || 0) / t * 100).toFixed(1) + '%' : '0%');
            // Clientes únicos
            var uniqs = {};
            _citas.forEach(function (c) { if (c.NombreCliente) uniqs[c.NombreCliente] = 1; });
            setEl('d-clientes', Object.keys(uniqs).length);

            mkChart('d-chart-estados', 'doughnut', {
                labels: ['Finalizada', 'Pendiente', 'Cancelada', 'Confirmada'],
                datasets: [{
                    data: [fin, kpi.CitasPendientes || 0, kpi.CitasCanceladas || 0,
                        Math.max(0, t - fin - (kpi.CitasPendientes || 0) - (kpi.CitasCanceladas || 0))],
                    backgroundColor: ['#059669', '#d97706', '#dc2626', '#2563eb'], borderWidth: 0, hoverOffset: 6
                }]
            }, { plugins: { legend: { position: 'right', labels: { font: { size: 11 }, boxWidth: 12 } } } });

            // Servicios más solicitados (top 5)
            var smap = {};
            _citas.forEach(function (c) { if (c.ServicioNombre) smap[c.ServicioNombre] = (smap[c.ServicioNombre] || 0) + 1; });
            var tops = Object.entries(smap).sort(function (a, b) { return b[1] - a[1]; }).slice(0, 5);
            mkChart('d-chart-servicios', 'bar', {
                labels: tops.map(function (x) { return x[0]; }),
                datasets: [{ data: tops.map(function (x) { return x[1]; }), backgroundColor: '#e8006b', borderRadius: 6, borderSkipped: false }]
            }, { plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } }, y: { grid: { color: '#f3f4f6' } } } });

            // Evolución ingresos mensual
            var mmap = {};
            _citas.forEach(function (c) {
                if (!c.Fecha) return;
                var m = c.Fecha.substring(0, 7);
                if (!mmap[m]) mmap[m] = { ingresos: 0 };
                if (c.Estado === 'Finalizada') mmap[m].ingresos += (c.Precio || 0);
            });
            var meses = Object.keys(mmap).sort();
            mkChart('d-chart-ingresos', 'line', {
                labels: meses.map(function (m) { return MESES_ES[parseInt(m.split('-')[1]) - 1]; }),
                datasets: [{
                    label: 'Ingresos', data: meses.map(function (m) { return mmap[m].ingresos; }),
                    borderColor: '#059669', backgroundColor: 'rgba(5,150,105,0.08)', tension: 0.4, fill: true,
                    pointBackgroundColor: '#059669', pointRadius: 5
                }]
            }, { scales: { y: { ticks: { callback: function (v) { return '$' + (v / 1000).toFixed(0) + 'K'; } } } } });
        }

        // ════════════════════════════════════════
        // CITAS
        // ════════════════════════════════════════
        function citasRangoChange() {
            var v = document.getElementById('c-rango').value;
            document.getElementById('c-custom-desde-wrap').style.display = v === 'custom' ? '' : 'none';
            document.getElementById('c-custom-hasta-wrap').style.display = v === 'custom' ? '' : 'none';
        }

        function citasFiltrar() {
            var rango = document.getElementById('c-rango').value;
            var estado = document.getElementById('c-estado').value;
            var serv = document.getElementById('c-servicio').value;
            var hoy = new Date();
            var hoyStr = hoy.getFullYear() + '-' + String(hoy.getMonth() + 1).padStart(2, '0') + '-' + String(hoy.getDate()).padStart(2, '0');

            // Descripción legible del filtro para el PDF
            var descRango = { mes: 'Este mes', semana: 'Esta semana', todos: 'Todos', custom: 'Personalizado' }[rango] || rango;
            var desdeVal = rango === 'custom' ? (document.getElementById('c-desde').value || '') : '';
            var hastaVal = rango === 'custom' ? (document.getElementById('c-hasta').value || '') : '';
            if (rango === 'custom' && (desdeVal || hastaVal)) descRango = (desdeVal || 'inicio') + ' → ' + (hastaVal || 'hoy');
            _filtroDescripcion = 'Rango: ' + descRango + (estado ? ' | Estado: ' + estado : '') + (serv ? ' | Servicio: ' + serv : '');

            var data = _citas.filter(function (c) {
                if (!c.Fecha) return false;

                // ── Filtro de fecha ──────────────────────────────────────────
                if (rango === 'mes') {
                    var mesActual = hoy.getFullYear() + '-' + String(hoy.getMonth() + 1).padStart(2, '0');
                    if (!c.Fecha.startsWith(mesActual)) return false;

                } else if (rango === 'semana') {
                    // Comparación directa de strings yyyy-mm-dd, sin new Date() para evitar UTC
                    var hace7 = new Date(hoy); hace7.setDate(hoy.getDate() - 7);
                    var hace7Str = hace7.getFullYear() + '-' + String(hace7.getMonth() + 1).padStart(2, '0') + '-' + String(hace7.getDate()).padStart(2, '0');
                    if (c.Fecha < hace7Str || c.Fecha > hoyStr) return false;

                } else if (rango === 'custom') {
                    // Comparación de strings: yyyy-mm-dd compara lexicográficamente correcto
                    if (desdeVal && c.Fecha < desdeVal) return false;
                    if (hastaVal && c.Fecha > hastaVal) return false;
                    // Si no se pusieron fechas, muestra todo (igual que "todos")
                }
                // rango === 'todos': no filtra por fecha

                // ── Filtro de estado ─────────────────────────────────────────
                if (estado && c.Estado !== estado) return false;

                // ── Filtro de servicio ───────────────────────────────────────
                if (serv && c.ServicioNombre !== serv) return false;

                return true;
            });

            // Guardar para PDF
            _citasFiltradas = data;

            var fin = data.filter(function (c) { return c.Estado === 'Finalizada'; }).length;
            var pend = data.filter(function (c) { return c.Estado === 'Pendiente'; }).length;
            var conf = data.filter(function (c) { return c.Estado === 'Confirmada'; }).length;
            var canc = data.filter(function (c) { return c.Estado === 'Cancelada'; }).length;

            setEl('c-total', data.length);
            setEl('c-pend', pend);
            setEl('c-conf', conf);
            setEl('c-canc', canc);
            setEl('c-fin', fin);

            // ── KPIs de ingresos del filtro ──────────────────────────────────
            var ingresos = data.reduce(function (s, c) { return s + (c.Estado === 'Finalizada' ? (c.Precio || 0) : 0); }, 0);
            var ticket = fin > 0 ? Math.round(ingresos / fin) : 0;
            var tasa = data.length > 0 ? (fin / data.length * 100).toFixed(1) : '0.0';

            setEl('c-ingresos', '$' + ingresos.toLocaleString('es-CO'));
            setEl('c-ticket', '$' + ticket.toLocaleString('es-CO'));
            setEl('c-tasa', tasa + '%');

            var subEl = document.getElementById('c-ingresos-sub');
            if (subEl) subEl.textContent = _filtroDescripcion.replace('Rango: ', '');

            mkChart('c-chart-estado', 'bar', {
                labels: ['Pendiente', 'Confirmada', 'Cancelada', 'Finalizada'],
                datasets: [{
                    data: [pend, conf, canc, fin],
                    backgroundColor: ['#d97706', '#2563eb', '#dc2626', '#059669'], borderRadius: 6, borderSkipped: false
                }]
            }, { plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } }, y: { grid: { color: '#f3f4f6' } } } });

            // Evolución diaria — todos los días del rango, no solo 14
            var dmap = {};
            data.forEach(function (c) { if (c.Fecha) dmap[c.Fecha] = (dmap[c.Fecha] || 0) + 1; });
            var dias = Object.keys(dmap).sort();
            mkChart('c-chart-evol', 'line', {
                labels: dias.map(function (d) { var p = d.split('-'); return p[2] + ' ' + MESES_ES[parseInt(p[1]) - 1].substring(0, 3); }),
                datasets: [{
                    label: 'Citas', data: dias.map(function (d) { return dmap[d]; }),
                    borderColor: '#e8006b', backgroundColor: 'rgba(232,0,107,0.08)', tension: 0.4, fill: true,
                    pointBackgroundColor: '#e8006b', pointRadius: 4
                }]
            }, { scales: { y: { grid: { color: '#f3f4f6' }, ticks: { stepSize: 1 } }, x: { grid: { display: false } } } });

            // Tabla
            var tbody = document.getElementById('c-tbody');
            tbody.innerHTML = data.length === 0
                ? '<tr><td colspan="6" style="text-align:center;color:#9ca3af;padding:28px">Sin resultados para este filtro</td></tr>'
                : data.slice().sort(function (a, b) { return (b.Fecha || '').localeCompare(a.Fecha || ''); }).map(function (c) {
                    return '<tr><td class="td-bold">' + (c.NombreCliente || '—') + '</td>' +
                        '<td>' + (c.ServicioNombre || '—') + '</td>' +
                        '<td>' + (c.Fecha || '—') + '</td>' +
                        '<td>' + (c.HoraInicio || '—') + '</td>' +
                        '<td style="font-family:monospace">$' + Number(c.Precio || 0).toLocaleString('es-CO') + '</td>' +
                        '<td><span class="badge badge-' + badgeCls(c.Estado) + '">' + c.Estado + '</span></td></tr>';
                }).join('');
        }

        // ════════════════════════════════════════
        // COMPARATIVA
        // ════════════════════════════════════════
        function renderComparativa() {
            var mmap = {};
            _citas.forEach(function (c) {
                if (!c.Fecha) return;
                var m = c.Fecha.substring(0, 7);
                if (!mmap[m]) mmap[m] = { total: 0, fin: 0, canc: 0 };
                mmap[m].total++;
                if (c.Estado === 'Finalizada') mmap[m].fin++;
                if (c.Estado === 'Cancelada') mmap[m].canc++;
            });
            var meses = Object.keys(mmap).sort();

            // KPIs
            if (meses.length >= 2) {
                var ult = mmap[meses[meses.length - 1]], ant = mmap[meses[meses.length - 2]];
                var crec = ant.total > 0 ? ((ult.total - ant.total) / ant.total * 100) : 0;
                setEl('comp-crecimiento', (crec >= 0 ? '+' : '') + crec.toFixed(1) + '%');
                document.getElementById('comp-crecimiento').style.color = crec >= 0 ? '#059669' : '#dc2626';
            }
            var tot = _citas.length, fin2 = _citas.filter(function (c) { return c.Estado === 'Finalizada'; }).length;
            var canc2 = _citas.filter(function (c) { return c.Estado === 'Cancelada'; }).length;
            setEl('comp-asist', tot > 0 ? (fin2 / tot * 100).toFixed(1) + '%' : '0%');
            setEl('comp-canc', tot > 0 ? (canc2 / tot * 100).toFixed(1) + '%' : '0%');

            mkChart('comp-chart-mensual', 'line', {
                labels: meses.map(function (m) { return MESES_ES[parseInt(m.split('-')[1]) - 1]; }),
                datasets: [
                    { label: 'Total', data: meses.map(function (m) { return mmap[m].total; }), borderColor: '#e8006b', tension: 0.4, pointRadius: 5, backgroundColor: 'rgba(232,0,107,0.05)', fill: true },
                    { label: 'Finalizadas', data: meses.map(function (m) { return mmap[m].fin; }), borderColor: '#059669', tension: 0.4, pointRadius: 4, borderDash: [4, 3] },
                    { label: 'Canceladas', data: meses.map(function (m) { return mmap[m].canc; }), borderColor: '#dc2626', tension: 0.4, pointRadius: 4, borderDash: [4, 3] },
                ]
            }, { scales: { y: { grid: { color: '#f3f4f6' } }, x: { grid: { display: false } } } });

            mkChart('comp-chart-reservas', 'bar', {
                labels: meses.map(function (m) { return MESES_ES[parseInt(m.split('-')[1]) - 1]; }),
                datasets: [{ label: 'Total', data: meses.map(function (m) { return mmap[m].total; }), backgroundColor: '#e8006b', borderRadius: 8, borderSkipped: false }]
            }, { plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } }, y: { grid: { color: '#f3f4f6' } } } });

            mkChart('comp-chart-fin', 'bar', {
                labels: meses.map(function (m) { return MESES_ES[parseInt(m.split('-')[1]) - 1]; }),
                datasets: [{ label: 'Finalizadas', data: meses.map(function (m) { return mmap[m].fin; }), backgroundColor: '#059669', borderRadius: 8, borderSkipped: false }]
            }, { plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } }, y: { grid: { color: '#f3f4f6' } } } });

            // Tabla
            document.getElementById('comp-tbody').innerHTML = meses.map(function (m, i) {
                var d = mmap[m], t2 = d.total;
                var ant2 = i > 0 ? mmap[meses[i - 1]].total : null;
                var var2 = ant2 ? ((t2 - ant2) / ant2 * 100) : 0;
                return '<tr><td class="td-bold">' + MESES_ES[parseInt(m.split('-')[1]) - 1] + ' ' + m.split('-')[0] + '</td>' +
                    '<td>' + t2 + '</td><td>' + d.fin + '</td><td>' + d.canc + '</td>' +
                    '<td class="trend-up">' + (t2 > 0 ? (d.fin / t2 * 100).toFixed(1) + '%' : '0%') + '</td>' +
                    '<td class="trend-down">' + (t2 > 0 ? (d.canc / t2 * 100).toFixed(1) + '%' : '0%') + '</td>' +
                    '<td class="' + (var2 >= 0 ? 'trend-up' : 'trend-down') + '">' + (var2 >= 0 ? '↑' : '↓') + Math.abs(var2).toFixed(1) + '%</td></tr>';
            }).join('');

            // Temporadas
            var sorted = meses.slice().sort(function (a, b) { return mmap[b].total - mmap[a].total; });
            var alta = sorted[0], baja = sorted[sorted.length - 1];
            document.getElementById('comp-temporadas').innerHTML =
                '<div class="stat-card" style="background:linear-gradient(135deg,#059669,#047857)">' +
                '<div class="stat-card-label">Temporada Alta</div>' +
                '<div class="stat-card-value">' + MESES_ES[parseInt(alta.split('-')[1]) - 1] + ' ' + alta.split('-')[0] + '</div>' +
                '<div class="stat-card-sub">' + mmap[alta].total + ' citas registradas · Mayor demanda</div>' +
                '</div>' +
                '<div class="stat-card" style="background:linear-gradient(135deg,#2563eb,#7c3aed)">' +
                '<div class="stat-card-label">📉 Temporada Baja</div>' +
                '<div class="stat-card-value">' + MESES_ES[parseInt(baja.split('-')[1]) - 1] + ' ' + baja.split('-')[0] + '</div>' +
                '<div class="stat-card-sub">' + mmap[baja].total + ' citas registradas · Menor demanda</div>' +
                '</div>';
        }

        // ════════════════════════════════════════
        // SERVICIOS
        // ════════════════════════════════════════
        function renderServicios() {
            var smap = {};
            _citas.forEach(function (c) {
                var n = c.ServicioNombre || 'Sin nombre';
                if (!smap[n]) smap[n] = { cant: 0, ing: 0 };
                smap[n].cant++;
                if (c.Estado === 'Finalizada') smap[n].ing += (c.Precio || 0);
            });
            var lista = Object.entries(smap).map(function (e, i) {
                return { nombre: e[0], cant: e[1].cant, ing: e[1].ing, color: COLORES[i % COLORES.length] };
            }).sort(function (a, b) { return b.cant - a.cant; });

            var totCant = lista.reduce(function (s, x) { return s + x.cant; }, 0);
            var totIng = lista.reduce(function (s, x) { return s + x.ing; }, 0);
            var topDem = lista[0] || { nombre: '—', cant: 0 };
            var topRent = lista.slice().sort(function (a, b) { return b.ing - a.ing; })[0] || { nombre: '—', ing: 0 };

            setEl('serv-top-dem', topDem.nombre);
            setEl('serv-top-dem-sub', topDem.cant + ' reservas (' + Math.round(topDem.cant / totCant * 100) + '%)');
            setEl('serv-top-rent', topRent.nombre);
            setEl('serv-top-rent-sub', '$' + (topRent.ing / 1000).toFixed(0) + 'K generados');
            setEl('serv-ing-total', '$' + (totIng / 1000).toFixed(0) + 'K');

            mkChart('serv-chart-pastel', 'doughnut', {
                labels: lista.map(function (x) { return x.nombre + ': ' + Math.round(x.cant / totCant * 100) + '%'; }),
                datasets: [{ data: lista.map(function (x) { return x.cant; }), backgroundColor: lista.map(function (x) { return x.color; }), borderWidth: 0, hoverOffset: 8 }]
            }, { plugins: { legend: { position: 'right', labels: { font: { size: 10 }, boxWidth: 10 } } } });

            mkChart('serv-chart-ranking', 'bar', {
                labels: lista.map(function (x) { return x.nombre; }),
                datasets: [{ data: lista.map(function (x) { return x.cant; }), backgroundColor: lista.map(function (x) { return x.color; }), borderRadius: 6, borderSkipped: false }]
            }, { indexAxis: 'y', plugins: { legend: { display: false } }, scales: { x: { grid: { color: '#f3f4f6' } }, y: { grid: { display: false } } } });

            mkChart('serv-chart-ingresos', 'bar', {
                labels: lista.map(function (x) { return x.nombre; }),
                datasets: [{ data: lista.map(function (x) { return x.ing; }), backgroundColor: lista.map(function (x) { return x.color; }), borderRadius: 8, borderSkipped: false }]
            }, { plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } }, y: { ticks: { callback: function (v) { return '$' + (v / 1000).toFixed(0) + 'K'; } }, grid: { color: '#f3f4f6' } } } });

            document.getElementById('serv-tbody').innerHTML = lista.map(function (s, i) {
                var pct = totCant > 0 ? Math.round(s.cant / totCant * 100) : 0;
                var prom = s.cant > 0 ? Math.round(s.ing / s.cant) : 0;
                return '<tr>' +
                    '<td><span style="display:inline-flex;width:22px;height:22px;border-radius:6px;background:' + s.color + ';color:#fff;align-items:center;justify-content:center;font-size:11px;font-weight:700;">' + (i + 1) + '</span></td>' +
                    '<td class="td-bold">' + s.nombre + '</td>' +
                    '<td>' + s.cant + '</td>' +
                    '<td><div style="display:flex;align-items:center;gap:8px">' +
                    '<div class="inline-bar" style="width:80px;flex-shrink:0"><div class="inline-bar-fill" style="width:' + pct + '%;background:' + s.color + '"></div></div>' +
                    '<span>' + pct + '%</span></div></td>' +
                    '<td style="color:#059669;font-weight:600">$' + s.ing.toLocaleString('es-CO') + '</td>' +
                    '<td>$' + prom.toLocaleString('es-CO') + '</td></tr>';
            }).join('');
        }

        // ════════════════════════════════════════
        // GANANCIAS
        // ════════════════════════════════════════
        function renderGanancias() {
            var mmap = {};
            _citas.forEach(function (c) {
                if (!c.Fecha) return;
                var m = c.Fecha.substring(0, 7);
                if (!mmap[m]) mmap[m] = { ing: 0, fin: 0 };
                if (c.Estado === 'Finalizada') { mmap[m].ing += (c.Precio || 0); mmap[m].fin++; }
            });
            var meses = Object.keys(mmap).sort();
            if (!meses.length) return;

            var ult = mmap[meses[meses.length - 1]];
            var ant = meses.length > 1 ? mmap[meses[meses.length - 2]] : { ing: 0 };
            var crec = ant.ing > 0 ? ((ult.ing - ant.ing) / ant.ing * 100) : 0;
            var totIng = meses.reduce(function (s, m) { return s + mmap[m].ing; }, 0);
            var totFin = meses.reduce(function (s, m) { return s + mmap[m].fin; }, 0);
            var ticket = totFin > 0 ? Math.round(totIng / totFin) : 0;
            var mejorMes = meses.slice().sort(function (a, b) { return mmap[b].ing - mmap[a].ing; })[0];

            setEl('gan-mejor', '$' + (ult.ing / 1000).toFixed(0) + 'K');
            setEl('gan-crec', (crec >= 0 ? '+' : '') + crec.toFixed(1) + '%');
            document.getElementById('gan-crec').style.color = crec >= 0 ? '#059669' : '#dc2626';
            setEl('gan-ticket', '$' + (ticket / 1000).toFixed(1) + 'K');
            setEl('gan-total', '$' + (totIng / 1000).toFixed(0) + 'K');
            setEl('gan-top-mes', '$' + (mmap[mejorMes].ing / 1000).toFixed(0) + 'K');
            setEl('gan-top-mes-sub', MESES_ES[parseInt(mejorMes.split('-')[1]) - 1] + ' ' + mejorMes.split('-')[0]);

            // Mejor servicio
            var smap = {};
            _citas.forEach(function (c) { if (c.Estado === 'Finalizada' && c.ServicioNombre) smap[c.ServicioNombre] = (smap[c.ServicioNombre] || 0) + (c.Precio || 0); });
            var topServ = Object.entries(smap).sort(function (a, b) { return b[1] - a[1]; })[0] || ['—', 0];
            setEl('gan-top-serv', topServ[0]);
            setEl('gan-top-serv-sub', '$' + (topServ[1] / 1000).toFixed(0) + 'K generados');

            mkChart('gan-chart-evol', 'line', {
                labels: meses.map(function (m) { return MESES_ES[parseInt(m.split('-')[1]) - 1]; }),
                datasets: [{
                    label: 'Ingresos', data: meses.map(function (m) { return mmap[m].ing; }),
                    borderColor: '#059669', backgroundColor: 'rgba(5,150,105,0.08)', tension: 0.4, fill: true,
                    pointBackgroundColor: '#059669', pointRadius: 5
                }]
            }, { scales: { y: { ticks: { callback: function (v) { return '$' + (v / 1000).toFixed(0) + 'K'; } }, grid: { color: '#f3f4f6' } }, x: { grid: { display: false } } } });

            mkChart('gan-chart-comp', 'bar', {
                labels: meses.map(function (m) { return MESES_ES[parseInt(m.split('-')[1]) - 1]; }),
                datasets: [{
                    data: meses.map(function (m) { return mmap[m].ing; }),
                    backgroundColor: meses.map(function (m, i) { return i === meses.length - 1 ? '#e8006b' : '#059669'; }),
                    borderRadius: 8, borderSkipped: false
                }]
            }, { plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } }, y: { ticks: { callback: function (v) { return '$' + (v / 1000).toFixed(0) + 'K'; } }, grid: { color: '#f3f4f6' } } } });

            // Ingresos por servicio
            var smap2 = {};
            _citas.forEach(function (c) { if (c.Estado === 'Finalizada' && c.ServicioNombre) smap2[c.ServicioNombre] = (smap2[c.ServicioNombre] || 0) + (c.Precio || 0); });
            var svList = Object.entries(smap2).sort(function (a, b) { return b[1] - a[1]; });
            mkChart('gan-chart-serv', 'bar', {
                labels: svList.map(function (x) { return x[0]; }),
                datasets: [{
                    data: svList.map(function (x) { return x[1]; }),
                    backgroundColor: svList.map(function (_, i) { return COLORES[i % COLORES.length]; }),
                    borderRadius: 8, borderSkipped: false
                }]
            }, { plugins: { legend: { display: false } }, scales: { x: { grid: { display: false } }, y: { ticks: { callback: function (v) { return '$' + (v / 1000).toFixed(0) + 'K'; } }, grid: { color: '#f3f4f6' } } } });

            document.getElementById('gan-tbody').innerHTML = meses.map(function (m, i) {
                var d = mmap[m], ant2 = i > 0 ? mmap[meses[i - 1]].ing : null;
                var var2 = ant2 ? ((d.ing - ant2) / ant2 * 100) : 0;
                var tk = d.fin > 0 ? Math.round(d.ing / d.fin) : 0;
                return '<tr><td class="td-bold">' + MESES_ES[parseInt(m.split('-')[1]) - 1] + ' ' + m.split('-')[0] + '</td>' +
                    '<td style="color:#059669;font-weight:600">$' + d.ing.toLocaleString('es-CO') + '</td>' +
                    '<td>' + d.fin + '</td>' +
                    '<td>$' + tk.toLocaleString('es-CO') + '</td>' +
                    '<td class="' + (var2 >= 0 ? 'trend-up' : 'trend-down') + '">' + (ant2 ? (var2 >= 0 ? '↑ ' : '↓ ') + Math.abs(var2).toFixed(1) + '%' : '—') + '</td></tr>';
            }).join('') + '<tr style="background:#f9fafb;font-weight:700"><td>TOTAL</td>' +
                '<td style="color:#059669">$' + totIng.toLocaleString('es-CO') + '</td>' +
                '<td>' + totFin + '</td><td>$' + ticket.toLocaleString('es-CO') + '</td><td>—</td></tr>';
        }

        // ════════════════════════════════════════
        // PRÓXIMAS
        // ════════════════════════════════════════
        function proximasFiltrar() {
            var estado = document.getElementById('prox-estado').value;
            var hoyS = fmtF(new Date()), manS = fmtF(new Date(Date.now() + 86400000));

            var data = _citas
                .filter(function (c) { return c.Estado === 'Pendiente' || c.Estado === 'Confirmada'; })
                .filter(function (c) { return !estado || c.Estado === estado; })
                .sort(function (a, b) { return (a.Fecha + a.HoraInicio).localeCompare(b.Fecha + b.HoraInicio); });

            var urg = data.filter(function (c) { return c.Fecha === hoyS || c.Fecha === manS; });
            setEl('prox-total', data.length);
            setEl('prox-conf', data.filter(function (c) { return c.Estado === 'Confirmada'; }).length);
            setEl('prox-pend', data.filter(function (c) { return c.Estado === 'Pendiente'; }).length);
            setEl('prox-urgentes', urg.length);

            var list = document.getElementById('prox-list');
            if (!data.length) {
                list.innerHTML = '<div class="empty"><svg fill="none" stroke="currentColor" stroke-width="1.2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg><p>No hay próximas citas.</p></div>';
                return;
            }

            list.innerHTML = data.map(function (c) {
                var esUrg = c.Fecha === hoyS || c.Fecha === manS;
                return '<div class="card" style="margin-bottom:10px;' + (esUrg ? 'border-left:3px solid #f97316;background:#fff7ed' : '') + '">' +
                    (esUrg ? '<div class="urgente-tag" style="margin-bottom:8px">⏰ URGENTE · Cita en las próximas 24 horas</div>' : '') +
                    '<div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px">' +
                    '<div>' +
                    '<div style="font-size:15px;font-weight:700;color:var(--ink)">' + (c.NombreCliente || 'Desconocido') + '</div>' +
                    '<div style="font-size:12px;color:var(--ink3);margin-top:2px">' + (c.ServicioNombre || '—') + '</div>' +
                    '<div style="display:flex;gap:16px;margin-top:8px;font-size:12px;color:var(--ink2)">' +
                    '<span>' + (c.Fecha || '—') + ' · ' + (c.HoraInicio || '—') + '</span>' +
                    '</div>' +
                    '</div>' +
                    '<span class="badge badge-' + (c.Estado === 'Confirmada' ? 'conf' : 'pend') + '">' + (c.Estado || '—') + '</span>' +
                    '</div>' +
                    '<div style="margin-top:10px;display:flex;justify-content:space-between;align-items:center">' +
                    '<div style="font-size:13px;font-weight:600;color:var(--pink)">$' + Number(c.Precio || 0).toLocaleString('es-CO') + '</div>' +
                    '</div>' +
                    '</div>';
            }).join('');
        }

        // ════════════════════════════════════════
        // CLIENTES
        // ════════════════════════════════════════
        function poblarClienteSelect() {
            var sel = document.getElementById('cli-select');
            if (sel.options.length > 1) return; // ya poblado
            var clientes = [];
            _usuarios.filter(function (u) { return u.Role === 'Cliente' || !u.Role; }).forEach(function (u) {
                if (u.Nombre && clientes.indexOf(u.Nombre) === -1) clientes.push(u.Nombre);
            });
            clientes.sort().forEach(function (n) {
                var o = document.createElement('option'); o.value = o.textContent = n; sel.appendChild(o);
            });
        }

