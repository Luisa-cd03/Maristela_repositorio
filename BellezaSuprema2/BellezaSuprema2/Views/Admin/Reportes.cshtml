        // ════════════════════════════════════════
        // EXPORTAR PDF
        // ════════════════════════════════════════
        function exportarPDF() {
            var btn = document.getElementById('btn-pdf-main');
            btn.textContent = '⏳ Generando...'; btn.disabled = true;
            setTimeout(function () {
                try { _buildPDF(); } catch (e) { toast('Error PDF: ' + e.message, 'err'); }
                btn.innerHTML = '<svg width="13" height="13" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg> Exportar PDF';
                btn.disabled = false;
            }, 150);
        }

        function _buildPDF() {
            var doc = new window.jspdf.jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
            var W = 210, H = 297, M = 14; // margen 14mm
            var ahora = new Date();
            var fechaLeg = ahora.toLocaleDateString('es-CO', { day: '2-digit', month: 'long', year: 'numeric' });
            var pageNames = {
                dashboard: 'Dashboard General', citas: 'Citas Agendadas',
                comparativa: 'Comparativa de Reservas', servicios: 'Reporte de Servicios',
                ganancias: 'Reporte de Ganancias', proximas: 'Próximas Citas', clientes: 'Clientes'
            };
            var pNombre = pageNames[_paginaActual] || 'Reporte';
            var datosReporte = (_paginaActual === 'citas') ? _citasFiltradas : _citas;

            // ── Helpers internos ─────────────────────────────────────────────
            function hdrPage(titulo, pgNum) {
                doc.setFillColor(232, 0, 107); doc.rect(0, 0, W, 18, 'F');
                doc.setFontSize(9); doc.setFont('helvetica', 'bold'); doc.setTextColor(255, 255, 255);
                doc.text('Belleza Suprema · ' + pNombre, M, 11);
                doc.text('Página ' + pgNum, W - M, 11, { align: 'right' });
                doc.setFillColor(232, 0, 107); doc.rect(0, H - 12, W, 12, 'F');
                doc.setFontSize(7.5); doc.setFont('helvetica', 'normal'); doc.setTextColor(255, 210, 230);
                doc.text('Generado el ' + fechaLeg + ' · Confidencial', W / 2, H - 5, { align: 'center' });
            }
            function secTitle(txt, y) {
                doc.setFontSize(11); doc.setFont('helvetica', 'bold'); doc.setTextColor(17, 24, 39);
                doc.text(txt, M, y);
                doc.setFillColor(232, 0, 107); doc.rect(M, y + 2, 18, 0.8, 'F');
            }
            function kpiBox(x, y, bw, bh, valor, etiqueta, colorVal) {
                doc.setFillColor(255, 255, 255); doc.setDrawColor(220, 215, 235); doc.setLineWidth(0.3);
                doc.roundedRect(x, y, bw, bh, 3, 3, 'FD');
                var fs = String(valor).length > 9 ? 11 : String(valor).length > 6 ? 13 : 16;
                doc.setFontSize(fs); doc.setFont('helvetica', 'bold'); doc.setTextColor(colorVal[0], colorVal[1], colorVal[2]);
                doc.text(String(valor), x + bw / 2, y + bh * 0.52, { align: 'center' });
                doc.setFontSize(7); doc.setFont('helvetica', 'normal'); doc.setTextColor(130, 120, 140);
                doc.text(etiqueta, x + bw / 2, y + bh * 0.82, { align: 'center' });
            }
            function addChart(canvasId, x, y, iw, ih) {
                var el = document.getElementById(canvasId); if (!el) return;
                try {
                    var img = el.toDataURL('image/png', 1);
                    doc.setFillColor(255, 255, 255); doc.setDrawColor(220, 215, 235); doc.setLineWidth(0.3);
                    doc.roundedRect(x, y, iw + 4, ih + 4, 3, 3, 'FD');
                    doc.addImage(img, 'PNG', x + 2, y + 2, iw, ih);
                } catch (e) { }
            }

            // ════════════════════════════════════════════════════════════════
            // PÁG 1 — PORTADA
            // ════════════════════════════════════════════════════════════════
            // Header degradado
            doc.setFillColor(232, 0, 107); doc.rect(0, 0, W, 80, 'F');
            doc.setFillColor(180, 0, 85); doc.rect(0, 54, W, 26, 'F');

            // Logo badge
            doc.setFillColor(255, 255, 255); doc.setDrawColor(255, 255, 255); doc.setLineWidth(0);
            doc.roundedRect(M, 14, 26, 26, 4, 4, 'F');
            doc.setFontSize(14); doc.setFont('helvetica', 'bold'); doc.setTextColor(232, 0, 107);
            doc.text('BS', M + 13, 30, { align: 'center' });

            // Título
            doc.setFontSize(22); doc.setFont('helvetica', 'bold'); doc.setTextColor(255, 255, 255);
            doc.text('Belleza Suprema', M + 34, 24);
            doc.setFontSize(9); doc.setFont('helvetica', 'normal'); doc.setTextColor(255, 200, 220);
            doc.text('Sistema de Reportes Administrativos', M + 34, 32);
            doc.setDrawColor(255, 255, 255); doc.setLineWidth(0.3); doc.line(M, 38, W - M, 38);
            doc.setFontSize(18); doc.setFont('helvetica', 'bold'); doc.setTextColor(255, 255, 255);
            doc.text(pNombre, M, 52);
            doc.setFontSize(8.5); doc.setFont('helvetica', 'normal'); doc.setTextColor(255, 220, 235);
            doc.text('Generado el ' + fechaLeg, M, 62);
            if (_paginaActual === 'citas' && _filtroDescripcion) {
                doc.setFontSize(8); doc.setTextColor(255, 235, 245);
                doc.text('Filtros: ' + _filtroDescripcion, M, 72);
            }

            // Fondo cuerpo
            doc.setFillColor(247, 245, 250); doc.rect(0, 80, W, H - 80, 'F');

            // ── KPIs portada ──────────────────────────────────────
            var finP, pendP, confP, cancP, ingP, tickP, tasaP;
            finP = datosReporte.filter(function (c) { return c.Estado === 'Finalizada'; }).length;
            pendP = datosReporte.filter(function (c) { return c.Estado === 'Pendiente'; }).length;
            confP = datosReporte.filter(function (c) { return c.Estado === 'Confirmada'; }).length;
            cancP = datosReporte.filter(function (c) { return c.Estado === 'Cancelada'; }).length;
            ingP = datosReporte.reduce(function (s, c) { return s + (c.Estado === 'Finalizada' ? (c.Precio || 0) : 0); }, 0);
            tickP = finP > 0 ? Math.round(ingP / finP) : 0;
            tasaP = datosReporte.length > 0 ? (finP / datosReporte.length * 100).toFixed(1) + '%' : '0%';

            secTitle('Indicadores del Período', 92);
            var bw = (W - M * 2 - 12) / 4, bh = 30, by = 98;
            kpiBox(M, by, bw, bh, datosReporte.length, 'Total Citas', [37, 99, 235]);
            kpiBox(M + bw + 4, by, bw, bh, finP, 'Finalizadas', [5, 150, 105]);
            kpiBox(M + bw * 2 + 8, by, bw, bh, cancP, 'Canceladas', [220, 38, 38]);
            kpiBox(M + bw * 3 + 12, by, bw, bh, pendP, 'Pendientes', [217, 119, 6]);

            var bw2 = (W - M * 2 - 8) / 3, by2 = by + bh + 6;
            kpiBox(M, by2, bw2, bh, '$' + ingP.toLocaleString('es-CO'), 'Ingresos Totales', [5, 150, 105]);
            kpiBox(M + bw2 + 4, by2, bw2, bh, '$' + tickP.toLocaleString('es-CO'), 'Ticket Promedio', [124, 58, 237]);
            kpiBox(M + bw2 * 2 + 8, by2, bw2, bh, tasaP, 'Tasa Completado', [232, 0, 107]);

            // ── Resumen por mes en portada ─────────────────────────────────
            var mmap = {};
            datosReporte.forEach(function (c) {
                if (!c.Fecha) return;
                var m = c.Fecha.substring(0, 7);
                if (!mmap[m]) mmap[m] = { tot: 0, fin: 0, canc: 0, ing: 0 };
                mmap[m].tot++;
                if (c.Estado === 'Finalizada') { mmap[m].fin++; mmap[m].ing += (c.Precio || 0); }
                if (c.Estado === 'Cancelada') mmap[m].canc++;
            });
            var meses = Object.keys(mmap).sort();

            var tyMes = by2 + bh + 12;
            secTitle('Resumen por Mes', tyMes);
            doc.autoTable({
                startY: tyMes + 6,
                head: [['Mes', 'Total Citas', 'Finalizadas', 'Canceladas', 'Ingresos', 'Ticket Prom.']],
                body: meses.map(function (m) {
                    var d = mmap[m], tick = d.fin > 0 ? Math.round(d.ing / d.fin) : 0;
                    var label = MESES_ES[parseInt(m.split('-')[1]) - 1] + ' ' + m.split('-')[0];
                    return [label, d.tot, d.fin, d.canc,
                        '$' + d.ing.toLocaleString('es-CO'),
                        '$' + tick.toLocaleString('es-CO')];
                }),
                styles: { font: 'helvetica', fontSize: 8.5, cellPadding: 4, lineColor: [220, 215, 235], lineWidth: 0.25 },
                headStyles: { fillColor: [232, 0, 107], textColor: [255, 255, 255], fontStyle: 'bold', fontSize: 8.5, halign: 'center' },
                alternateRowStyles: { fillColor: [250, 247, 253] },
                columnStyles: { 0: { fontStyle: 'bold', cellWidth: 38 }, 1: { halign: 'center' }, 2: { halign: 'center', textColor: [5, 150, 105] }, 3: { halign: 'center', textColor: [220, 38, 38] }, 4: { halign: 'right', textColor: [5, 100, 80] }, 5: { halign: 'right' } },
                margin: { left: M, right: M, bottom: 18 },
                didDrawPage: function (d) { if (d.pageNumber > 1) { hdrPage(pNombre, d.pageNumber); } }
            });

            // Pie pág 1
            doc.setFillColor(232, 0, 107); doc.rect(0, H - 12, W, 12, 'F');
            doc.setFontSize(7.5); doc.setFont('helvetica', 'normal'); doc.setTextColor(255, 210, 230);
            doc.text('Generado el ' + fechaLeg + ' · Confidencial', W / 2, H - 5, { align: 'center' });

            // ════════════════════════════════════════════════════════════════
            // PÁG 2 — GRÁFICAS LADO A LADO
            // ════════════════════════════════════════════════════════════════
            doc.addPage();
            hdrPage(pNombre, 2);

            var canvasMap = {
                dashboard: ['d-chart-estados', 'd-chart-servicios', 'd-chart-ingresos'],
                citas: ['c-chart-estado', 'c-chart-evol'],
                comparativa: ['comp-chart-mensual', 'comp-chart-reservas'],
                servicios: ['serv-chart-pastel', 'serv-chart-ingresos'],
                ganancias: ['gan-chart-evol', 'gan-chart-comp'],
                proximas: [], clientes: []
            };
            var charts = canvasMap[_paginaActual] || [];
            var chartTitles = {
                'c-chart-estado': 'Citas por Estado', 'c-chart-evol': 'Evolución Diaria de Citas',
                'd-chart-estados': 'Estado de Citas', 'd-chart-servicios': 'Servicios Más Solicitados',
                'd-chart-ingresos': 'Evolución de Ingresos',
                'comp-chart-mensual': 'Evolución Mensual', 'comp-chart-reservas': 'Reservas por Mes',
                'serv-chart-pastel': 'Distribución', 'serv-chart-ingresos': 'Ingresos por Servicio',
                'gan-chart-evol': 'Evolución Ingresos', 'gan-chart-comp': 'Comparativa'
            };

            var gy = 26, gcols = 2, gpad = 6;
            var gw = Math.floor((W - M * 2 - (gcols - 1) * gpad) / gcols);
            var gh = 62;
            charts.forEach(function (id, idx) {
                var col = idx % gcols, row = Math.floor(idx / gcols);
                var gx = M + col * (gw + gpad), gyy = gy + row * (gh + gpad + 10);
                // título de la gráfica
                doc.setFontSize(8.5); doc.setFont('helvetica', 'bold'); doc.setTextColor(60, 50, 70);
                doc.text(chartTitles[id] || id, gx, gyy + 8);
                addChart(id, gx, gyy + 10, gw, gh);
            });

            // Si dashboard tiene 3 gráficas, la tercera ocupa ancho completo
            if (charts.length === 3) {
                var gyy3 = gy + (gh + gpad + 10) * 1;
                // si los dos primeros en row 0, el tercero en row 1 centrado
                gyy3 = gy + (gh + gpad + 10);
                var el3 = document.getElementById(charts[2]); if (el3) {
                    doc.setFontSize(8.5); doc.setFont('helvetica', 'bold'); doc.setTextColor(60, 50, 70);
                    doc.text(chartTitles[charts[2]] || charts[2], M, gyy3 + 8);
                    addChart(charts[2], M, gyy3 + 10, W - M * 2, gh + 10);
                }
            }

            // ── Resumen por día (tabla debajo de gráficas) ─────────────────
            var dmap2 = {};
            datosReporte.forEach(function (c) {
                if (!c.Fecha) return;
                if (!dmap2[c.Fecha]) dmap2[c.Fecha] = { tot: 0, fin: 0, canc: 0, pend: 0, ing: 0 };
                dmap2[c.Fecha].tot++;
                if (c.Estado === 'Finalizada') { dmap2[c.Fecha].fin++; dmap2[c.Fecha].ing += (c.Precio || 0); }
                if (c.Estado === 'Cancelada') dmap2[c.Fecha].canc++;
                if (c.Estado === 'Pendiente') dmap2[c.Fecha].pend++;
            });
            var diasList = Object.keys(dmap2).sort();
            var tyDia = 26 + (Math.ceil(Math.max(charts.length, 2) / 2)) * (gh + gpad + 10) + 14;

            secTitle('Resumen por Día', tyDia);
            doc.autoTable({
                startY: tyDia + 6,
                head: [['Fecha', 'Total', 'Finalizadas', 'Canceladas', 'Pendientes', 'Ingresos del Día']],
                body: diasList.map(function (d) {
                    var r = dmap2[d];
                    return [d, r.tot, r.fin, r.canc, r.pend, '$' + r.ing.toLocaleString('es-CO')];
                }),
                styles: { font: 'helvetica', fontSize: 8.5, cellPadding: 4, lineColor: [220, 215, 235], lineWidth: 0.25 },
                headStyles: { fillColor: [124, 58, 237], textColor: [255, 255, 255], fontStyle: 'bold', fontSize: 8.5, halign: 'center' },
                alternateRowStyles: { fillColor: [250, 247, 255] },
                columnStyles: { 0: { fontStyle: 'bold', cellWidth: 34 }, 1: { halign: 'center' }, 2: { halign: 'center', textColor: [5, 150, 105] }, 3: { halign: 'center', textColor: [220, 38, 38] }, 4: { halign: 'center', textColor: [217, 119, 6] }, 5: { halign: 'right', textColor: [5, 100, 80] } },
                margin: { left: M, right: M, bottom: 18 },
                didDrawPage: function (d) { hdrPage(pNombre, d.pageNumber + 1); }
            });

            // ════════════════════════════════════════════════════════════════
            // PÁG SIGUIENTE — DETALLE COMPLETO DE CITAS
            // ════════════════════════════════════════════════════════════════
            doc.addPage();
            var pgDetalle = doc.internal.getNumberOfPages();
            hdrPage(pNombre, pgDetalle);

            secTitle('Detalle Completo de Citas', 26);

            var tData;
            if (_paginaActual === 'citas') {
                tData = {
                    cols: ['Cliente', 'Servicio', 'Fecha', 'Hora Inicio', 'Hora Fin', 'Precio', 'Estado'],
                    rows: datosReporte.slice().sort(function (a, b) { return (b.Fecha || '').localeCompare(a.Fecha || ''); })
                        .map(function (c) {
                            return [
                                c.NombreCliente || '—', c.ServicioNombre || '—', c.Fecha || '—',
                                c.HoraInicio || '—', c.HoraFin || '—',
                                '$' + Number(c.Precio || 0).toLocaleString('es-CO'), c.Estado || '—'
                            ];
                        })
                };
            } else {
                tData = _getTablaData(_paginaActual);
            }

            if (tData.rows.length) {
                doc.autoTable({
                    startY: 33,
                    head: [tData.cols],
                    body: tData.rows,
                    styles: { font: 'helvetica', fontSize: 8.5, cellPadding: 4.5, lineColor: [220, 215, 235], lineWidth: 0.25 },
                    headStyles: { fillColor: [232, 0, 107], textColor: [255, 255, 255], fontStyle: 'bold', fontSize: 8.5, halign: 'center' },
                    alternateRowStyles: { fillColor: [249, 247, 252] },
                    columnStyles: { 0: { fontStyle: 'bold' } },
                    margin: { top: 22, bottom: 18, left: M, right: M },
                    didDrawPage: function () {
                        hdrPage(pNombre, doc.internal.getNumberOfPages());
                    }
                });
            } else {
                doc.setFontSize(10); doc.setTextColor(150, 140, 160);
                doc.text('Sin datos para el filtro seleccionado.', W / 2, 50, { align: 'center' });
            }

            doc.save('BeautySalon_' + pNombre.replace(/ /g, '_') + '_' + fmtF(ahora) + '.pdf');
            toast('✅ PDF generado correctamente', 'ok');
        }

        function _getTablaData(p) {
            switch (p) {
                case 'citas': case 'dashboard':
                    return {
                        cols: ['Cliente', 'Servicio', 'Fecha', 'Hora', 'Precio', 'Estado'],
                        rows: _citas.map(function (c) { return [c.NombreCliente || '—', c.ServicioNombre || '—', c.Fecha || '—', c.HoraInicio || '—', '$' + Number(c.Precio || 0).toLocaleString('es-CO'), c.Estado || '—']; })
                    };
                case 'servicios': {
                    var smap = {};
                    _citas.forEach(function (c) { var n = c.ServicioNombre || '—'; if (!smap[n]) smap[n] = { c: 0, i: 0 }; smap[n].c++; if (c.Estado === 'Finalizada') smap[n].i += (c.Precio || 0); });
                    var tot = Object.values(smap).reduce(function (s, x) { return s + x.c; }, 0);
                    return {
                        cols: ['Servicio', 'Citas', 'Ingresos', '% Part.'],
                        rows: Object.entries(smap).sort(function (a, b) { return b[1].c - a[1].c; }).map(function (e) {
                            return [e[0], e[1].c, '$' + e[1].i.toLocaleString('es-CO'), tot > 0 ? (e[1].c / tot * 100).toFixed(1) + '%' : '0%'];
                        })
                    };
                }
                case 'ganancias': {
                    var mmap = {};
                    _citas.forEach(function (c) { if (!c.Fecha) return; var m = c.Fecha.substring(0, 7); if (!mmap[m]) mmap[m] = { i: 0, f: 0 }; if (c.Estado === 'Finalizada') { mmap[m].i += (c.Precio || 0); mmap[m].f++; } });
                    return {
                        cols: ['Mes', 'Ingresos', 'Citas', 'Ticket'],
                        rows: Object.keys(mmap).sort().map(function (m) { var d = mmap[m]; return [MESES_ES[parseInt(m.split('-')[1]) - 1] + ' ' + m.split('-')[0], '$' + d.i.toLocaleString('es-CO'), d.f, '$' + (d.f > 0 ? Math.round(d.i / d.f) : 0).toLocaleString('es-CO')]; })
                    };
                }
                default:
                    return { cols: ['Campo', 'Valor'], rows: [['Sin datos', '—']] };
            }
        }

        // ════════════════════════════════════════
        // UTILS
        // ════════════════════════════════════════
        function mkChart(id, tipo, data, options) {
            if (_charts[id]) { _charts[id].destroy(); }
            var el = document.getElementById(id); if (!el) return;
            var base = {
                responsive: true, maintainAspectRatio: false,
                plugins: { legend: { labels: { font: { family: "'DM Sans'", size: 11 }, boxWidth: 12 } } },
                scales: tipo !== 'doughnut' && tipo !== 'pie' ? {
                    x: { grid: { color: '#f3f4f6', lineWidth: .8 }, ticks: { font: { family: "'DM Sans'", size: 11 } } },
                    y: { grid: { color: '#f3f4f6', lineWidth: .8 }, ticks: { font: { family: "'DM Sans'", size: 11 } } }
                } : undefined
            };
            var merged = mergeDeep(base, options || {});
            _charts[id] = new Chart(el, { type: tipo, data: data, options: merged });
        }

        function mergeDeep(target, source) {
            var out = Object.assign({}, target);
            if (isObj(target) && isObj(source)) {
                Object.keys(source).forEach(function (k) {
                    if (isObj(source[k])) { if (!target[k]) out[k] = {}; out[k] = mergeDeep(target[k], source[k]); }
                    else out[k] = source[k];
                });
            }
            return out;
        }
        function isObj(o) { return o && typeof o === 'object' && !Array.isArray(o); }
        function setEl(id, v) { var el = document.getElementById(id); if (el) el.textContent = v; }
        function badgeCls(e) { return { Pendiente: 'pend', Confirmada: 'conf', Finalizada: 'fin', Cancelada: 'canc' }[e] || 'pend'; }
        function fmtF(d) { return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0'); }
        function toast(msg, tipo) { var t = document.getElementById('rep-toast'); t.textContent = msg; t.className = 'rep-toast ' + (tipo || 'ok'); t.style.display = 'block'; clearTimeout(t._t); t._t = setTimeout(function () { t.style.display = 'none'; }, 3500); }

        // Arrancar
        window.addEventListener('DOMContentLoaded', cargarTodo);
    </script>
</body>
</html>
