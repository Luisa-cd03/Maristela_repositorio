                '<tbody>' + citas.sort(function (a, b) { return b.Fecha.localeCompare(a.Fecha); }).map(function (c) {
                    return '<tr><td>' + c.Fecha + '</td><td>' + c.ServicioNombre + '</td>' +
                        '<td><span class="badge badge-' + badgeCls(c.Estado) + '">' + c.Estado + '</span></td>' +
                        '<td>$' + Number(c.Precio || 0).toLocaleString('es-CO') + '</td></tr>';
                }).join('') +
