    // ════════════════════════════════════════════════════
    // REPORTE 2 — TEMPORADAS
    // ════════════════════════════════════════════════════
    function repRenderTemporadas(meses) {
        if (!meses || !meses.length) return;
        var sorted = meses.slice().sort(function (a, b) { return b.citas - a.citas; });
        var maxC = sorted[0].citas, minC = sorted[sorted.length - 1].citas;
        var midC = (maxC + minC) / 2;
        document.getElementById('rep-temporadas-list').innerHTML = sorted.slice(0, 8).map(function (m) {
            var nivel = m.citas >= midC * 1.1 ? 'Alta' : m.citas <= midC * 0.9 ? 'Baja' : 'Media';
            var color = nivel === 'Alta' ? '#059669' : nivel === 'Baja' ? '#dc2626' : '#d97706';
            return '<div style="display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:1px solid #e8eaf0;">' +
                '<div style="width:8px;height:8px;border-radius:50%;background:' + color + ';flex-shrink:0;"></div>' +
                '<div style="flex:1;font-size:13px;font-weight:500;">' + m.mes + '</div>' +
                '<div style="font-size:12px;color:#8b90a7;">' + m.citas + ' citas</div>' +
                '<div style="font-size:11px;font-weight:700;color:' + color + ';background:' + color + '18;padding:2px 8px;border-radius:20px;">' + nivel + '</div>' +
                '</div>';
        }).join('');
    }

    // ════════════════════════════════════════════════════
    // REPORTE 5 — PRÓXIMAS CITAS
    // ════════════════════════════════════════════════════
    function repRenderProximas(todasCitas) {
        var hoy = new Date();
        var hoyS = repFmtFecha(hoy);
        var manS = repFmtFecha(new Date(hoy.getTime() + 86400000));
        var sem7S = repFmtFecha(new Date(hoy.getTime() + 7 * 86400000));

        var prox = todasCitas
            .filter(function (c) { return c.Estado === 'Pendiente' || c.Estado === 'Confirmada'; })
            .sort(function (a, b) { return (a.Fecha + a.HoraInicio).localeCompare(b.Fecha + b.HoraInicio); });

        repSetKPI('kpi-prox-urgentes', prox.filter(function (c) { return c.Fecha === hoyS || c.Fecha === manS; }).length);
        repSetKPI('kpi-prox-semana', prox.filter(function (c) { return c.Fecha >= hoyS && c.Fecha <= sem7S; }).length);
        repSetKPI('kpi-prox-total', prox.length);
        repSetKPI('kpi-prox-conf', prox.filter(function (c) { return c.Estado === 'Confirmada'; }).length);

        var tbody = document.getElementById('rep-tbody-proximas');
        if (!prox.length) {
            tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#8b90a7;padding:28px">No hay citas próximas</td></tr>';
            return;
        }
        tbody.innerHTML = prox.map(function (c) {
            var urg = c.Fecha === hoyS || c.Fecha === manS;
