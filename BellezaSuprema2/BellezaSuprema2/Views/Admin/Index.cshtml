    .rep-td-bold  { font-weight:600; }
    .rep-td-muted { color:var(--rep-muted); font-size:12px; }

    /* ── BADGES ── */
    .rep-badge { border-radius:20px; padding:3px 10px; font-size:11px; font-weight:600; display:inline-block; white-space:nowrap; }
    .rep-badge-pend { background:#fef3c7; color:#92400e; border:1px solid #fbbf24; }
    .rep-badge-conf { background:#dbeafe; color:#1e40af; border:1px solid #93c5fd; }
    .rep-badge-fin  { background:#d1fae5; color:#065f46; border:1px solid #6ee7b7; }
    .rep-badge-canc { background:#fee2e2; color:#991b1b; border:1px solid #fca5a5; }
    .rep-badge-venc { background:#f3f4f6; color:#374151; border:1px solid #d1d5db; }

    /* ── URGENTE ── */
    .rep-urgente { background:#fff7ed; border-left:3px solid #f97316; }

    /* ── CHART ── */
    .rep-chart-box    { position:relative; height:220px; }
    .rep-chart-box-lg { position:relative; height:280px; }

    /* ── RANKING ── */
    .rep-ranking-item { display:flex; align-items:center; gap:11px; padding:11px 0; border-bottom:1px solid var(--rep-border); }
    .rep-ranking-item:last-child { border-bottom:none; }
    .rep-rank-num {
      width:26px; height:26px; border-radius:7px; flex-shrink:0;
