    // ════════════════════════════════════════════════════
    // REPORTE 6 — HISTORIAL POR CLIENTE
    // ════════════════════════════════════════════════════
    function repBuscarCliente(q) {
        if (!q || q.length < 2) return;
        var txt = q.toLowerCase().trim();
        var usuario = null;
        for (var i = 0; i < _repUsuarios.length; i++) {
            if (_repUsuarios[i].Nombre && _repUsuarios[i].Nombre.toLowerCase().indexOf(txt) !== -1) {
                usuario = _repUsuarios[i]; break;
            }
        }
        var cont = document.getElementById('rep-cliente-perfil');
        if (!usuario) {
            cont.innerHTML = '<div class="rep-empty"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg><p>No se encontró "<strong>' + q + '</strong>"</p></div>';
            return;
        }

        var citas = _repCitas.filter(function (c) {
            return c.NombreCliente && c.NombreCliente.toLowerCase() === usuario.Nombre.toLowerCase();
        });

        var totalGast = citas.filter(function (c) { return c.Estado === 'Finalizada'; })
            .reduce(function (s, c) { return s + (c.Precio || 0); }, 0);
        var gastProm = citas.length > 0 ? Math.round(totalGast / citas.length) : 0;
        var cancels = citas.filter(function (c) { return c.Estado === 'Cancelada'; }).length;
        var citasOrd = citas.filter(function (c) { return c.Estado === 'Finalizada'; })
            .sort(function (a, b) { return b.Fecha.localeCompare(a.Fecha); });
        var ultVisita = citasOrd.length ? citasOrd[0].Fecha : 'N/A';

        var smap2 = {};
        citas.forEach(function (c) { if (c.ServicioNombre) smap2[c.ServicioNombre] = (smap2[c.ServicioNombre] || 0) + 1; });
        var favKeys = Object.keys(smap2).sort(function (a, b) { return smap2[b] - smap2[a]; });
        var favServ = favKeys.length ? favKeys[0] : '—';

        var fidel = citas.length >= 8 ? 'Alta' : citas.length >= 3 ? 'Media' : 'Baja';
        var valor = totalGast >= 500000 ? 'Alto' : totalGast >= 150000 ? 'Medio' : 'Bajo';
        var recompra = citas.length >= 5 ? '90%' : citas.length >= 2 ? '65%' : '30%';

        var histRows = citas.sort(function (a, b) { return b.Fecha.localeCompare(a.Fecha); }).map(function (h) {
            return '<tr>' +
                '<td>' + (h.Fecha || '—') + '</td>' +
                '<td>' + (h.HoraInicio || '—') + '</td>' +
                '<td>' + (h.ServicioNombre || '—') + '</td>' +
                '<td><span class="rep-badge rep-badge-' + repBadge(h.Estado) + '">' + h.Estado + '</span></td>' +
                '<td style="font-family:monospace;font-size:12px;">$' + Number(h.Precio || 0).toLocaleString('es-CO') + '</td>' +
                '</tr>';
        }).join('') || '<tr><td colspan="5" style="text-align:center;color:#8b90a7;padding:24px">Sin historial</td></tr>';

        cont.innerHTML =
            '<div class="rep-cliente-header">' +
            '<div class="rep-avatar">' + usuario.Nombre[0].toUpperCase() + '</div>' +
            '<div>' +
            '<div class="rep-cliente-name">' + usuario.Nombre + '</div>' +
            '<div class="rep-cliente-meta">' +
            '<span>📱 ' + (usuario.Telefono || 'N/A') + '</span>' +
            '<span>✉️ ' + (usuario.Email || 'N/A') + '</span>' +
            '<span>🎭 ' + (usuario.Role || 'Cliente') + '</span>' +
            '</div>' +
            '<div class="rep-fidelizacion">⭐ Fidelización: ' + fidel + ' · 💎 Valor: ' + valor + ' · 📈 Recompra: ' + recompra + '</div>' +
            '</div>' +
            '</div>' +
            '<div class="rep-kpi-grid">' +
            '<div class="rep-kpi-card" style="--kpi-color:#7c3aed"><div class="rep-kpi-label">Total Citas</div><div class="rep-kpi-value">' + citas.length + '</div><div class="rep-kpi-desc">' + cancels + ' cancelaciones</div></div>' +
            '<div class="rep-kpi-card" style="--kpi-color:#059669"><div class="rep-kpi-label">Total Gastado</div><div class="rep-kpi-value" style="font-size:18px;">$' + totalGast.toLocaleString('es-CO') + '</div></div>' +
            '<div class="rep-kpi-card" style="--kpi-color:#2563eb"><div class="rep-kpi-label">Gasto Promedio</div><div class="rep-kpi-value" style="font-size:18px;">$' + gastProm.toLocaleString('es-CO') + '</div></div>' +
            '<div class="rep-kpi-card" style="--kpi-color:#d97706"><div class="rep-kpi-label">Servicio Favorito</div><div class="rep-kpi-value" style="font-size:14px;">' + favServ + '</div><div class="rep-kpi-desc">Última visita: ' + ultVisita + '</div></div>' +
            '</div>' +
            '<div class="rep-card">' +
            '<div class="rep-card-header"><div><div class="rep-card-title">Historial de Citas</div></div></div>' +
            '<div class="rep-table-wrap">' +
            '<table class="rep-table"><thead><tr><th>Fecha</th><th>Hora</th><th>Servicio</th><th>Estado</th><th>Precio</th></tr></thead>' +
            '<tbody>' + histRows + '</tbody></table>' +
            '</div>' +
            '</div>';
    }

    // ════════════════════════════════════════════════════
    // GRÁFICOS (Chart.js — CDN en el Index.cshtml ya incluido)
    // ════════════════════════════════════════════════════
    var repCharts = {};   // guarda instancias para poder destruirlas si se recargan

    function repInitCharts() {
        var CD = {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { labels: { font: { family: "'Segoe UI'", size: 11 }, boxWidth: 12 } } },
            scales: {
                x: { grid: { color: '#f0f0f8' }, ticks: { font: { family: "'Segoe UI'", size: 11 } } },
                y: { grid: { color: '#f0f0f8' }, ticks: { font: { family: "'Segoe UI'", size: 11 } } }
            }
        };
        function mkChart(id, cfg) {
            if (repCharts[id]) repCharts[id].destroy();
            var el = document.getElementById(id);
            if (el) repCharts[id] = new Chart(el, cfg);
        }

        // Estados
        var kpi = _repKPI || {};
        var conf = Math.max(0, (kpi.TotalCitas || 0) - (kpi.CitasPendientes || 0) - (kpi.CitasCanceladas || 0) - (kpi.CitasFinalizadas || 0));
        mkChart('rep-chart-estados', {
            type: 'bar',
            data: {
                labels: ['Finalizada', 'Confirmada', 'Pendiente', 'Cancelada'],
                datasets: [{
                    label: 'Citas', data: [kpi.CitasFinalizadas || 0, conf, kpi.CitasPendientes || 0, kpi.CitasCanceladas || 0],
                    backgroundColor: ['#059669', '#2563eb', '#d97706', '#dc2626'], borderRadius: 8, borderSkipped: false
                }]
            },
            options: Object.assign({}, CD, { plugins: { legend: { display: false } } })
        });

