    // ════════════════════════════════════════════════════
    // EXPORTAR CSV
    // ════════════════════════════════════════════════════
    function repExportarCSV() {
        if (!_repCitas.length) { alert('Sin datos para exportar'); return; }
        var cab = ['NombreCliente', 'ServicioNombre', 'Fecha', 'HoraInicio', 'Precio', 'Estado'];
        var rows = _repCitas.map(function (c) {
            return [c.NombreCliente, c.ServicioNombre, c.Fecha, c.HoraInicio, c.Precio, c.Estado]
                .map(function (v) { return '"' + (v || '') + '"'; }).join(',');
        });
        var csv = [cab.join(',')].concat(rows).join('\n');
        var blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url; a.download = 'Citas_BellezaSuprema.csv'; a.click();
        URL.revokeObjectURL(url);
    }

