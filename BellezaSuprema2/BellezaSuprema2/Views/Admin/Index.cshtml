    .rep-down { color:#dc2626; font-weight:700; }

    /* ── EMPTY ── */
    .rep-empty { text-align:center; padding:40px; color:var(--rep-muted); }
    .rep-empty svg { width:36px; height:36px; margin-bottom:10px; opacity:.3; }


