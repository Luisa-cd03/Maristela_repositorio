    }
    .rep-btn-export:hover { background:#7c3aed; color:#fff; }

    /* ── TABLA ── */
    .rep-table-wrap { overflow-x:auto; border-radius:10px; border:1px solid var(--rep-border); }
    .rep-table { width:100%; border-collapse:collapse; font-size:13px; }
    .rep-table thead th {
      background:#f8f6ff; padding:10px 13px; text-align:left;
      font-size:10px; font-weight:700; color:var(--rep-muted);
      text-transform:uppercase; letter-spacing:.5px;
