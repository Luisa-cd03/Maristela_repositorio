@* ════════════════════════════════════════════════════════════
     LIBRERÍAS CDN
     jsPDF      – construye el documento PDF en el navegador.
     autoTable  – extiende jsPDF para dibujar tablas.
    ════════════════════════════════════════════════════════════ *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>

<script>

    // ════════════════════════════════════════════════════════════
    // VARIABLES GLOBALES
    // ════════════════════════════════════════════════════════════

    var tabActivo = null;       // Pestaña actualmente visible
    var estadoSeleccionado = 'Todos';    // Filtro de estado en Agenda
    var fechaSeleccionada = null;       // Fecha seleccionada en el calendario (YYYY-MM-DD)
    var calAnio = new Date().getFullYear();
    var calMes = new Date().getMonth();   // 0-based
    var fechasConCitas = [];         // Fechas con ≥1 cita: ["2025-03-05", ...]
    var todosLosUsuarios = [];         // Cache de usuarios para filtro en memoria
    var tipoPeriodo = 'mes';      // 'mes' | 'rango'

    // Nombres de meses en inglés → encabezado del calendario
    var nombresMeses = ['January', 'February', 'March', 'April', 'May', 'June',
        'July', 'August', 'September', 'October', 'November', 'December'];

    // Nombres de meses en español → título del PDF
    var mesesEs = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
        'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];


    // ════════════════════════════════════════════════════════════
    // IIFE DE INICIALIZACIÓN
    // Se ejecuta una sola vez al cargar la página.
    //
    // Establece los límites de los inputs de fecha para que el
    // usuario NO pueda seleccionar:
    //   • Fechas anteriores a enero 2025 (inicio del aplicativo)
    //   • Fechas futuras al mes/día actual
    // ════════════════════════════════════════════════════════════
    (function () {
        var hoy = new Date();
        var anio = hoy.getFullYear();
        var mes = String(hoy.getMonth() + 1).padStart(2, '0');
        var dia = String(hoy.getDate()).padStart(2, '0');
        var mesActual = anio + '-' + mes;       // Ej: "2025-03"
        var hoyISO = anio + '-' + mes + '-' + dia; // Ej: "2025-03-04"

        // ── input[type="month"] (filtro por mes) ──
        // Valor inicial: mes en curso
        // Mínimo: enero 2025 (creación del aplicativo)
        // Máximo: mes en curso (sin reportes futuros)
        var inputMes = document.getElementById('input-mes');
        inputMes.value = mesActual;
        inputMes.setAttribute('min', '2025-01');
        inputMes.setAttribute('max', mesActual);

        // ── input[type="date"] desde (filtro por rango) ──
        // Mínimo: 1 enero 2025
        document.getElementById('input-desde').setAttribute('min', '2025-01-01');

        // ── input[type="date"] hasta (filtro por rango) ──
        // Máximo: hoy (sin fechas futuras)
        document.getElementById('input-hasta').setAttribute('max', hoyISO);
    })();


    // ════════════════════════════════════════════════════════════
    // FUNCIÓN: cambiarTab(tab)
    // Muestra la sección correspondiente y oculta las demás.
    // Si se pulsa la pestaña ya activa, se cierra (toggle).
    // ════════════════════════════════════════════════════════════
    function cambiarTab(tab) {
        if (tabActivo === tab) {
            // Segunda pulsación sobre la misma pestaña → cerrar
            tabActivo = null;
            document.querySelectorAll('.section').forEach(function (s) { s.style.display = 'none'; });
            document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
            return;
        }
        tabActivo = tab;
        document.querySelectorAll('.section').forEach(function (s) { s.style.display = 'none'; });
        document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
        document.getElementById('section-' + tab).style.display = 'block';
        document.getElementById('tab-' + tab).classList.add('active');

        // Disparar carga de datos según la sección
        if (tab === 'Agenda') cargarFechasConCitas();
        if (tab === 'Usuarios') cargarUsuarios();
        if (tab === 'Reportes') cargarReportes();
    }


    // ════════════════════════════════════════════════════════════
    // CALENDARIO
    // ════════════════════════════════════════════════════════════

    /**
     * Solicita al servidor los días del mes/año activos que
     * tienen al menos una cita y luego renderiza el calendario.
     * Endpoint: GET /Admin/GetFechas → string[]
     */
    function cargarFechasConCitas() {
        fetch('/Admin/GetFechas')
            .then(function (r) { return r.json(); })
            .then(function (data) {
                fechasConCitas = data;
                renderizarCalendario();
            });
    }

    /**
     * Construye la cuadrícula de días del mes/año actuales.
     * Marca: día de hoy, día seleccionado y días con citas (•).
     */
    function renderizarCalendario() {
        document.getElementById('cal-titulo').textContent = nombresMeses[calMes] + ' ' + calAnio;

        var hoy = new Date();
        var hoyStr = formatearFecha(hoy.getFullYear(), hoy.getMonth(), hoy.getDate());
        var diasEnMes = new Date(calAnio, calMes + 1, 0).getDate();
        var primerDia = new Date(calAnio, calMes, 1).getDay(); // 0 = Domingo

        var grid = document.getElementById('cal-dias');
        grid.innerHTML = '';

        // Celdas vacías para alinear el primer día de la semana
        for (var i = 0; i < primerDia; i++) {
            grid.appendChild(document.createElement('div'));
        }

        // Celda por cada día del mes
        for (var d = 1; d <= diasEnMes; d++) {
            var diaStr = formatearFecha(calAnio, calMes, d);
            var diaDiv = document.createElement('div');
            diaDiv.className = 'cal-day';
            diaDiv.textContent = d;

            if (diaStr === hoyStr) diaDiv.classList.add('today');
            if (diaStr === fechaSeleccionada) diaDiv.classList.add('selected');

            // Punto indicador si el día tiene citas
            if (fechasConCitas.indexOf(diaStr) !== -1) {
                var dot = document.createElement('div');
                dot.className = 'dot';
                diaDiv.appendChild(dot);
            }

            // IIFE para capturar el valor correcto de diaStr en cada iteración
            diaDiv.onclick = (function (f) { return function () { seleccionarDia(f); }; })(diaStr);
            grid.appendChild(diaDiv);
        }
    }

    /** Avanza o retrocede un mes en el calendario. delta: +1 o -1 */
    function cambiarMes(delta) {
        calMes += delta;
        if (calMes > 11) { calMes = 0; calAnio++; }
        if (calMes < 0) { calMes = 11; calAnio--; }
        renderizarCalendario();
    }

    /**
     * Selecciona o deselecciona un día.
     * Al seleccionar, dispara la carga de citas de ese día.
     */
    function seleccionarDia(fecha) {
        if (fechaSeleccionada === fecha) {
            fechaSeleccionada = null;
            document.getElementById('fecha-titulo').textContent = '';
        } else {
            fechaSeleccionada = fecha;
            document.getElementById('fecha-titulo').textContent = '— ' + fecha;
        }
        renderizarCalendario();
        cargarCitas();
    }


    // ════════════════════════════════════════════════════════════
    // CITAS
    // ════════════════════════════════════════════════════════════

    /**
     * Solicita citas al servidor aplicando los filtros activos
     * (fecha seleccionada y/o estado).
     * Endpoint: GET /Admin/GetCitas?fecha=&estado=
     */
    function cargarCitas() {
        var url = '/Admin/GetCitas?';
        if (fechaSeleccionada) url += 'fecha=' + fechaSeleccionada + '&';
        if (estadoSeleccionado && estadoSeleccionado !== 'Todos') url += 'estado=' + estadoSeleccionado;

        fetch(url)
            .then(function (r) { return r.json(); })
            .then(function (citas) { renderizarTablaCitas(citas); })
            .catch(function () {
                document.getElementById('citas-container').innerHTML =
                    '<div class="no-citas">Error al cargar las citas</div>';
            });
    }

    /** Construye la tabla HTML con el array de citas recibido. */
    function renderizarTablaCitas(citas) {
        var contenedor = document.getElementById('citas-container');

        if (citas.length === 0) {
            contenedor.innerHTML = '<div class="no-citas">No hay citas para esta selección</div>';
            return;
        }

        var html = '<table><thead><tr>';
        html += '<th>Cliente</th><th>Servicio</th><th>Fecha</th><th>Hora</th><th>Precio</th><th>Estado</th>';
        html += '</tr></thead><tbody>';

        citas.forEach(function (c) {
            html += '<tr>';
            html += '<td>' + (c.NombreCliente || 'Desconocido') + '</td>';
            html += '<td>' + (c.ServicioNombre || '') + '</td>';
            html += '<td>' + (c.Fecha || '') + '</td>';
            html += '<td>' + (c.HoraInicio || '') + '</td>';
            html += '<td>$' + (c.Precio ? c.Precio.toLocaleString() : '0') + '</td>';
            html += '<td><span class="badge badge-' + c.Estado + '">' + c.Estado + '</span></td>';
            html += '</tr>';
        });

        html += '</tbody></table>';
        contenedor.innerHTML = html;
    }


    // ════════════════════════════════════════════════════════════
    // DROPDOWN FILTRO ESTADO
    // ════════════════════════════════════════════════════════════

    /** Abre o cierra el dropdown de filtro de estado de la Agenda. */
    function toggleDropdown() {
        var dd = document.getElementById('estado-dropdown');
        dd.style.display = dd.style.display === 'block' ? 'none' : 'block';
    }

    /** Aplica el filtro seleccionado y recarga la tabla de citas. */
    function seleccionarEstado(valor, etiqueta) {
        estadoSeleccionado = valor;
        document.getElementById('estado-texto').textContent = etiqueta;
        document.getElementById('estado-dropdown').style.display = 'none';
        cargarCitas();
    }


    // ════════════════════════════════════════════════════════════
    // USUARIOS
    // ════════════════════════════════════════════════════════════

    /**
     * Carga todos los usuarios y los almacena en todosLosUsuarios
     * para poder filtrar en memoria sin nuevas peticiones.
     * Endpoint: GET /Admin/GetTodosUsuarios
     */
    function cargarUsuarios() {
        fetch('/Admin/GetTodosUsuarios')
            .then(function (r) { return r.json(); })
            .then(function (usuarios) {
                todosLosUsuarios = usuarios;
                renderizarTablaUsuarios(usuarios);
            });
    }

    /**
     * Filtra el array en memoria por nombre (case-insensitive)
     * y vuelve a renderizar la tabla sin petición al servidor.
     */
    function filtrarUsuarios(texto) {
        var q = texto.toLowerCase().trim();
        if (!q) { renderizarTablaUsuarios(todosLosUsuarios); return; }
        renderizarTablaUsuarios(
            todosLosUsuarios.filter(function (u) {
                return u.Nombre.toLowerCase().indexOf(q) !== -1;
            })
        );
    }

    /** Construye la tabla HTML con el array de usuarios recibido. */
    function renderizarTablaUsuarios(usuarios) {
        var contenedor = document.getElementById('usuarios-container');

        if (usuarios.length === 0) {
            contenedor.innerHTML = '<div class="no-citas">No se encontraron usuarios</div>';
            return;
        }

        var html = '<table><thead><tr>';
        html += '<th>Nombre</th><th>Teléfono</th><th>Correo</th><th>Rol</th>';
        html += '</tr></thead><tbody>';

        usuarios.forEach(function (u) {
            var esAdmin = u.Role === 'Administrador';
            var badge = esAdmin
                ? 'background:#111;color:#fff;border-radius:20px;padding:3px 14px;font-size:12px;font-weight:700;'
                : 'background:#e5e7eb;color:#374151;border-radius:20px;padding:3px 14px;font-size:12px;font-weight:600;';
            html += '<tr>';
            html += '<td style="font-weight:700;color:#111;">' + u.Nombre + '</td>';
            html += '<td style="color:#555;">' + (u.Telefono || 'N/A') + '</td>';
            html += '<td style="color:#555;">' + u.Email + '</td>';
            html += '<td><span style="' + badge + '">' + u.Role + '</span></td>';
            html += '</tr>';
        });

        html += '</tbody></table>';
        contenedor.innerHTML = html;
    }


    // ════════════════════════════════════════════════════════════
    // REPORTES — TARJETAS KPI
    // ════════════════════════════════════════════════════════════

    /**
     * Pide las estadísticas generales al servidor y renderiza
     * las 6 tarjetas KPI del panel de reportes.
     * Endpoint: GET /Admin/GetReportes → { TotalCitas, CitasPendientes, ... }
     */
    function cargarReportes() {
        fetch('/Admin/GetReportes')
            .then(function (r) { return r.json(); })
            .then(function (d) {
                var html = '<div class="reportes-grid">';
                html += mkCard('Total de Citas', d.TotalCitas, 'r-morado', 'Todas las citas registradas');
                html += mkCard('Citas Pendientes', d.CitasPendientes, 'r-verde', 'Próximas citas programadas');
                html += mkCard('Citas Canceladas', d.CitasCanceladas, 'r-rojo', 'Citas que fueron canceladas');
                html += mkCard('Citas Finalizadas', d.CitasFinalizadas, 'r-azul', 'Servicios completados');
                html += mkCard('Total de Usuarios', d.TotalUsuarios, 'r-morado', 'Usuarios registrados');
                html += '<div class="reporte-card">'
                    + '<div class="r-label">Ingresos Estimados</div>'
                    + '<div class="r-numero r-verde">$ ' + d.IngresosEstimados.toLocaleString('es-CO') + '</div>'
                    + '<div class="r-desc">De citas finalizadas</div>'
                    + '</div>';
                html += '</div>';
                document.getElementById('reportes-container').innerHTML = html;
            })
            .catch(function () {
                document.getElementById('reportes-container').innerHTML =
                    '<div class="no-citas">Error al cargar los reportes</div>';
            });
    }

    /** Genera el HTML de una tarjeta KPI individual. */
    function mkCard(label, numero, colorClass, desc) {
        return '<div class="reporte-card">'
            + '<div class="r-label">' + label + '</div>'
            + '<div class="r-numero ' + colorClass + '">' + numero + '</div>'
            + '<div class="r-desc">' + desc + '</div>'
            + '</div>';
    }


    // ════════════════════════════════════════════════════════════
    // TIPO DE FILTRO PDF
    // Alterna entre "Por mes" y "Por rango de fechas".
    // ════════════════════════════════════════════════════════════
    function cambiarTipo(tipo) {
        tipoPeriodo = tipo;
        document.getElementById('btn-mes').classList.toggle('activo', tipo === 'mes');
        document.getElementById('btn-rango').classList.toggle('activo', tipo === 'rango');
        document.getElementById('filtro-mes').style.display = tipo === 'mes' ? 'block' : 'none';
        document.getElementById('filtro-rango').style.display = tipo === 'rango' ? 'block' : 'none';
    }


    // ════════════════════════════════════════════════════════════
    // GENERAR PDF
    // Flujo:
    //   1. Determinar rango (mes completo o fechas libres).
    //   2. Pedir TODAS las citas al servidor (GET /Admin/GetCitas).
    //   3. Filtrar por el rango elegido en el cliente.
    //   4. VALIDACIÓN → si citas.length === 0:
    //        mostrar alerta y ABORTAR (no generar PDF vacío).
    //   5. Si hay datos → construirPDF().
    // ════════════════════════════════════════════════════════════
    function generarPDF() {
        var desde, hasta, titulo;

        // ── Paso 1: determinar rango según el tipo de filtro ──
        if (tipoPeriodo === 'mes') {
            var mes = document.getElementById('input-mes').value;
            if (!mes) { alert('Selecciona un mes.'); return; }

            var partes = mes.split('-');
            var anio = parseInt(partes[0]);
            var numMes = parseInt(partes[1]);

            desde = mes + '-01';
            // Último día del mes seleccionado
            hasta = mes + '-' + String(new Date(anio, numMes, 0).getDate()).padStart(2, '0');
            titulo = 'Reporte de ' + mesesEs[numMes - 1] + ' ' + anio;

        } else {
            desde = document.getElementById('input-desde').value;
            hasta = document.getElementById('input-hasta').value;
            if (!desde || !hasta) { alert('Selecciona las fechas de inicio y fin.'); return; }
            if (desde > hasta) { alert('La fecha de inicio no puede ser mayor a la de fin.'); return; }
            titulo = 'Reporte del ' + desde + ' al ' + hasta;
        }

        // ── Paso 2 y 3: obtener citas y filtrar por rango ──
        fetch('/Admin/GetCitas?estado=Todos')
            .then(function (r) { return r.json(); })
            .then(function (todas) {
                var citas = todas.filter(function (c) {
                    return c.Fecha >= desde && c.Fecha <= hasta;
                });

                // ── Paso 4: VALIDACIÓN sin datos ──────────────
                // Si no hay citas en el período, mostrar alerta
                // estilizada y NO generar un PDF vacío.
                if (citas.length === 0) {
                    mostrarMensajeSinDatos(titulo);
                    return;
                }

                // ── Paso 5: construir y descargar el PDF ──────
                construirPDF(titulo, desde, hasta, citas);
            })
            .catch(function () {
                alert('Error al obtener datos. Intenta de nuevo.');
            });
    }


    // ════════════════════════════════════════════════════════════
    // MOSTRAR MENSAJE SIN DATOS
    // Inserta una alerta estilizada debajo del panel PDF cuando
    // no existen citas para el período seleccionado.
    //
    // Comportamiento:
    //   • Elimina una alerta previa si todavía está visible.
    //   • Aparece con animación fadeInUp.
    //   • Se cierra manualmente con el botón "×".
    //   • Se elimina automáticamente a los 6 segundos.
    // ════════════════════════════════════════════════════════════
    function mostrarMensajeSinDatos(titulo) {
        // Limpiar alerta anterior si existe
        var anterior = document.getElementById('alerta-sin-datos');
        if (anterior) anterior.remove();

        // Crear el elemento de alerta
        var alerta = document.createElement('div');
        alerta.id = 'alerta-sin-datos';
        alerta.className = 'alerta-sin-datos';

        alerta.innerHTML =
            // Ícono de advertencia
            '<div class="alerta-icono">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="#e879f9" stroke-width="2" ' +
            'stroke-linecap="round" stroke-linejoin="round" width="24" height="24">' +
            '<circle cx="12" cy="12" r="10"/>' +
            '<line x1="12" y1="8"  x2="12"    y2="12"/>' +
            '<line x1="12" y1="16" x2="12.01" y2="16"/>' +
            '</svg>' +
            '</div>' +
            // Textos
            '<div>' +
            '<div class="alerta-titulo">Sin datos para este período</div>' +
            '<div class="alerta-texto">' +
            'No se encontraron citas en <strong>' + titulo + '</strong>. ' +
            'Intenta con otro mes o rango de fechas.' +
            '</div>' +
            '</div>' +
            // Botón cerrar
            '<button class="alerta-cerrar" onclick="this.parentElement.remove()" title="Cerrar">×</button>';

        // Insertar justo después del panel PDF
        document.getElementById('pdf-panel').after(alerta);

        // Auto-eliminar a los 6 segundos
        setTimeout(function () {
            if (alerta.parentElement) alerta.remove();
        }, 6000);
    }


    // ════════════════════════════════════════════════════════════
    // CONSTRUIR PDF con jsPDF + autoTable
    //
    // Estructura del documento A4:
    //   ┌─ Encabezado morado (nombre + fecha de generación)
    //   ├─ Bloque de título y período
    //   ├─ Sección 1 – Resumen (6 tarjetas en 2 columnas)
    //   ├─ Sección 2 – Servicios más solicitados (tabla)
    //   ├─ Sección 3 – Detalle de citas (tabla)
    //   └─ Pie de página en todas las páginas
    // ════════════════════════════════════════════════════════════
    function construirPDF(titulo, desde, hasta, citas) {
        var doc = new window.jspdf.jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
        var pw = doc.internal.pageSize.getWidth();   // 210 mm
        var ph = doc.internal.pageSize.getHeight();  // 297 mm
        var y = 0;                                  // Cursor vertical

        // ── Encabezado morado ──
        doc.setFillColor(192, 38, 211);
        doc.rect(0, 0, pw, 28, 'F');
        doc.setTextColor(255, 255, 255);
        doc.setFontSize(16); doc.setFont('helvetica', 'bold');
        doc.text('Belleza Suprema', 14, 12);
        doc.setFontSize(10); doc.setFont('helvetica', 'normal');
        doc.text('Panel de Administrador', 14, 19);
        doc.text('Generado: ' + new Date().toLocaleDateString('es-CO'), pw - 14, 19, { align: 'right' });
        y = 38;

        // ── Título y período ──
        doc.setTextColor(50, 50, 50);
        doc.setFontSize(14); doc.setFont('helvetica', 'bold');
        doc.text(titulo, 14, y); y += 6;
        doc.setFontSize(10); doc.setFont('helvetica', 'normal'); doc.setTextColor(120, 120, 120);
        doc.text('Período: ' + desde + ' al ' + hasta, 14, y); y += 10;
        doc.setDrawColor(220, 220, 220);
        doc.line(14, y, pw - 14, y); y += 10;

        // ── Sección 1: Resumen estadístico ──
        doc.setTextColor(192, 38, 211);
        doc.setFontSize(11); doc.setFont('helvetica', 'bold');
        doc.text('1. Resumen del período', 14, y); y += 8;

        // Calcular métricas del período filtrado
        var total = citas.length;
        var pend = citas.filter(function (c) { return c.Estado === 'Pendiente'; }).length;
        var fin = citas.filter(function (c) { return c.Estado === 'Finalizada'; }).length;
        var canc = citas.filter(function (c) { return c.Estado === 'Cancelada'; }).length;
        var venc = citas.filter(function (c) { return c.Estado === 'Vencida'; }).length;
        var ingresos = citas.filter(function (c) { return c.Estado === 'Finalizada'; })
            .reduce(function (s, c) { return s + (c.Precio || 0); }, 0);

        var stats = [
            { l: 'Total de Citas', v: total, col: [192, 38, 211] },
            { l: 'Ingresos Estimados', v: '$ ' + ingresos.toLocaleString('es-CO'), col: [22, 163, 74] },
            { l: 'Citas Pendientes', v: pend, col: [22, 163, 74] },
            { l: 'Citas Canceladas', v: canc, col: [220, 38, 38] },
            { l: 'Citas Finalizadas', v: fin, col: [37, 99, 235] },
            { l: 'Citas Vencidas', v: venc, col: [107, 114, 128] }
        ];

        // Dibujar tarjetas en 2 columnas × 3 filas
        var colW = (pw - 28 - 8) / 2;
        stats.forEach(function (s, i) {
            var col = i % 2;
            var row = Math.floor(i / 2);
            var x = 14 + col * (colW + 8);
            var cy = y + row * 22;

            doc.setFillColor(248, 248, 248);
            doc.roundedRect(x, cy, colW, 18, 3, 3, 'F');
            // Barra de color izquierda
            doc.setFillColor(s.col[0], s.col[1], s.col[2]);
            doc.rect(x, cy, 3, 18, 'F');
            // Etiqueta y valor
            doc.setTextColor(100, 100, 100); doc.setFontSize(8); doc.setFont('helvetica', 'normal');
            doc.text(s.l, x + 7, cy + 6);
            doc.setTextColor(s.col[0], s.col[1], s.col[2]); doc.setFontSize(14); doc.setFont('helvetica', 'bold');
            doc.text(String(s.v), x + 7, cy + 14);
        });
        y += Math.ceil(stats.length / 2) * 22 + 12;

        // ── Sección 2: Servicios más solicitados ──
        doc.setDrawColor(220, 220, 220);
        doc.line(14, y, pw - 14, y); y += 8;
        doc.setTextColor(192, 38, 211);
        doc.setFontSize(11); doc.setFont('helvetica', 'bold');
        doc.text('2. Servicios más solicitados', 14, y); y += 4;

        // Agrupar citas por nombre de servicio
        var smap = {};
        citas.forEach(function (c) {
            var n = c.ServicioNombre || 'Sin nombre';
            if (!smap[n]) smap[n] = { cantidad: 0, ingresos: 0 };
            smap[n].cantidad++;
            if (c.Estado === 'Finalizada') smap[n].ingresos += (c.Precio || 0);
        });

        var sarr = Object.keys(smap).map(function (k) {
            return { nombre: k, cantidad: smap[k].cantidad, ingresos: smap[k].ingresos };
        }).sort(function (a, b) { return b.cantidad - a.cantidad; });

        if (!sarr.length) {
            doc.setTextColor(150, 150, 150); doc.setFontSize(9); doc.setFont('helvetica', 'normal');
            doc.text('No hay servicios en este período.', 14, y + 6); y += 14;
        } else {
            doc.autoTable({
                startY: y,
                head: [['Servicio', 'Citas', 'Ingresos (COP)']],
                body: sarr.map(function (s) {
                    return [s.nombre, s.cantidad, '$ ' + s.ingresos.toLocaleString('es-CO')];
                }),
                styles: { fontSize: 9, cellPadding: 4 },
                headStyles: { fillColor: [192, 38, 211], textColor: 255, fontStyle: 'bold' },
                alternateRowStyles: { fillColor: [250, 245, 255] },
                columnStyles: { 1: { halign: 'center' }, 2: { halign: 'right' } },
                margin: { left: 14, right: 14 },
                theme: 'striped'
            });
            y = doc.lastAutoTable.finalY + 12;
        }

        // ── Sección 3: Detalle de citas ──
        doc.setDrawColor(220, 220, 220);
        doc.line(14, y, pw - 14, y); y += 8;
        doc.setTextColor(192, 38, 211);
        doc.setFontSize(11); doc.setFont('helvetica', 'bold');
        doc.text('3. Detalle de citas del período', 14, y); y += 4;

        doc.autoTable({
            startY: y,
            head: [['Cliente', 'Servicio', 'Fecha', 'Hora', 'Precio', 'Estado']],
            body: citas.map(function (c) {
                return [
                    c.NombreCliente || 'Desconocido',
                    c.ServicioNombre || '',
                    c.Fecha || '',
                    c.HoraInicio || '',
                    '$ ' + (c.Precio ? c.Precio.toLocaleString('es-CO') : '0'),
                    c.Estado || ''
                ];
            }),
            styles: { fontSize: 8, cellPadding: 3 },
            headStyles: { fillColor: [124, 58, 237], textColor: 255, fontStyle: 'bold' },
            alternateRowStyles: { fillColor: [248, 248, 255] },
            columnStyles: { 4: { halign: 'right' }, 5: { halign: 'center', fontStyle: 'bold' } },
            margin: { left: 14, right: 14 },
            theme: 'striped'
        });

        // ── Pie de página en todas las páginas ──
        var totalPaginas = doc.internal.getNumberOfPages();
        for (var p = 1; p <= totalPaginas; p++) {
            doc.setPage(p);
            doc.setFillColor(245, 245, 245);
            doc.rect(0, ph - 12, pw, 12, 'F');
            doc.setTextColor(150, 150, 150); doc.setFontSize(8); doc.setFont('helvetica', 'normal');
            doc.text('Belleza Suprema - ' + titulo, 14, ph - 4);
            doc.text('Página ' + p + ' de ' + totalPaginas, pw - 14, ph - 4, { align: 'right' });
        }

        // ── Descarga ──
        doc.save('Reporte_BellezaSuprema_' + desde + '_' + hasta + '.pdf');
    }


    // ════════════════════════════════════════════════════════════
    // UTILIDADES
    // ════════════════════════════════════════════════════════════

    /**
     * Formatea año, mes (0-based) y día a string "YYYY-MM-DD".
     * Ejemplo: formatearFecha(2025, 2, 5) → "2025-03-05"
     */
    function formatearFecha(anio, mes, dia) {
        return anio + '-' + String(mes + 1).padStart(2, '0') + '-' + String(dia).padStart(2, '0');
    }


    // ════════════════════════════════════════════════════════════
    // CHAT FLOTANTE
    // ════════════════════════════════════════════════════════════

    function abrirChat() {
        document.getElementById('chat-window').style.display = 'flex';
        document.getElementById('chat-toggle-btn').style.display = 'none';
    }

    function cerrarChat() {
        document.getElementById('chat-window').style.display = 'none';
        document.getElementById('chat-toggle-btn').style.display = 'flex';
    }

    function enviarMensaje() {
        var input = document.getElementById('chat-input');
        var texto = input.value.trim();
        if (!texto) return;

        agregarMensaje(texto, 'user');
        input.value = '';

        // Respuestas automáticas de ejemplo (reemplazar por lógica real si aplica)
        setTimeout(function () {
            var resp = [
                'Puedo ayudarte con información sobre nuestros servicios.',
                'Las citas se pueden agendar de lunes a sábado de 8am a 7pm.',
                'Contamos con servicios de cabello, uñas, maquillaje y tratamientos.',
                'Para cancelar una cita, avísanos con 24 horas de anticipación.',
                '¡Por supuesto! Estoy aquí para ayudarte.'
            ];
            agregarMensaje(resp[Math.floor(Math.random() * resp.length)], 'bot');
        }, 600);
    }

    function agregarMensaje(texto, tipo) {
        var msgs = document.getElementById('chat-messages');
        var hora = new Date().toLocaleTimeString('es-CO', { hour: '2-digit', minute: '2-digit' });
        var div = document.createElement('div');
        div.className = tipo === 'user' ? 'msg-user' : 'msg-bot';
        div.innerHTML = texto + '<div class="msg-time">' + hora + '</div>';
        msgs.appendChild(div);
        msgs.scrollTop = msgs.scrollHeight;
    }

    //esto lo hizo el efrain, no lo borres porfa, es para el chat
    // ════════════════════════════════════════════════════════════
    // CIERRE AUTOMÁTICO DEL DROPDOWN DE ESTADO
    // Cierra el dropdown si el usuario hace clic fuera de él.
    // ════════════════════════════════════════════════════════════
    document.addEventListener('click', function (e) {
        var dd = document.getElementById('estado-dropdown');
        var btn = document.querySelector('.estado-btn');
        if (dd && btn && !btn.contains(e.target) && !dd.contains(e.target))
            dd.style.display = 'none';
    });

</script>
