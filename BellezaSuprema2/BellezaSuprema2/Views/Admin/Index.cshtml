    .rep-card-title  { font-size:14px; font-weight:700; color:#1a1d2e; }
    .rep-card-sub    { font-size:12px; color:var(--rep-muted); margin-top:2px; }

    /* ── GRIDS ── */
    .rep-grid-2 { display:grid; grid-template-columns:1fr 1fr; gap:18px; }
    media(max-width:900px){ .rep-grid-2 { grid-template-columns:1fr; } }

    /* ── FILTROS ── */
    .rep-filters {
      background:#fff; border:1px solid var(--rep-border); border-radius:var(--rep-r);
      padding:14px 18px; display:flex; gap:12px; align-items:flex-end;
