    /**
     * Formatea año, mes (0-based) y día a string "YYYY-MM-DD".
     * Ejemplo: formatearFecha(2025, 2, 5) → "2025-03-05"
     */
    function formatearFecha(anio, mes, dia) {
        return anio + '-' + String(mes + 1).padStart(2, '0') + '-' + String(dia).padStart(2, '0');
    }


