            data: {
                labels: gm.map(function (m) { return m.mes; }),
                datasets: [{
                    label: 'Ingresos', data: gm.map(function (m) { return m.ingresos; }),
                    backgroundColor: gm.map(function (_, i) { return i === gm.length - 1 ? '#c026d3' : '#7c3aed'; }),
                    borderRadius: 8, borderSkipped: false
                }]
            },
