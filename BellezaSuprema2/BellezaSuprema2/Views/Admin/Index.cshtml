        }
        tbody.innerHTML = data.map(function (c) {
            return '<tr>' +
                '<td class="rep-td-bold">' + (c.NombreCliente || 'Desconocido') + '</td>' +
                '<td>' + (c.ServicioNombre || '—') + '</td>' +
                '<td>' + (c.Fecha || '—') + '</td>' +
                '<td>' + (c.HoraInicio || '—') + '</td>' +
                '<td style="font-family:monospace;font-size:12px;">$' + Number(c.Precio || 0).toLocaleString('es-CO') + '</td>' +
                '<td><span class="rep-badge rep-badge-' + repBadge(c.Estado) + '">' + (c.Estado || '—') + '</span></td>' +
                '</tr>';
        }).join('');
    }

    function repFiltrarCitas() {
        var desde = document.getElementById('rep-f1-desde').value;
        var hasta = document.getElementById('rep-f1-hasta').value;
        var estado = document.getElementById('rep-f1-estado').value;
        var serv = document.getElementById('rep-f1-serv').value;
        repRenderCitas(_repCitas.filter(function (c) {
            return (!desde || c.Fecha >= desde) &&
                (!hasta || c.Fecha <= hasta) &&
                (!estado || c.Estado === estado) &&
                (!serv || c.ServicioNombre === serv);
        }));
    }

    // ════════════════════════════════════════════════════
    // REPORTE 2 — KPIs GLOBALES (ReportesViewModel)
    // ════════════════════════════════════════════════════
    function repRenderKPIs(d) {
        if (!d) return;
        var conf = Math.max(0, d.TotalCitas - d.CitasPendientes - d.CitasCanceladas - d.CitasFinalizadas);
        repSetKPI('kpi-total', d.TotalCitas);
        repSetKPI('kpi-fin', d.CitasFinalizadas);
        repSetKPI('kpi-conf', conf);
        repSetKPI('kpi-pend', d.CitasPendientes);
        repSetKPI('kpi-canc', d.CitasCanceladas);
        repSetKPI('kpi-comp-total', d.TotalCitas);
        var t = d.TotalCitas;
        repSetKPI('kpi-comp-tasa-canc', t > 0 ? (d.CitasCanceladas / t * 100).toFixed(1) + '%' : '0%');
        repSetKPI('kpi-comp-tasa-asist', t > 0 ? ((t - d.CitasCanceladas) / t * 100).toFixed(1) + '%' : '0%');
        repSetKPI('kpi-ing-total', '$' + Number(d.IngresosEstimados).toLocaleString('es-CO'));

        // Resumen ejecutivo
        var pct = t > 0 ? Math.round(d.CitasFinalizadas / t * 100) : 0;
        var res = document.getElementById('rep-resumen-txt');
        if (res) res.textContent =
            'El sistema registra ' + t + ' citas en total. ' +
            d.CitasFinalizadas + ' fueron completadas (' + pct + '%), ' +
            d.CitasPendientes + ' están pendientes y ' +
            d.CitasCanceladas + ' fueron canceladas. ' +
            'Ingresos estimados: $' + Number(d.IngresosEstimados).toLocaleString('es-CO') + ' COP.';
    }

    // ════════════════════════════════════════════════════
    // DERIVADOS — Servicios, Ganancias, Temporadas
    // ════════════════════════════════════════════════════
    function repCalcDerivados(citas) {
        // ── Por servicio ──
        var smap = {};
        citas.forEach(function (c) {
            var n = c.ServicioNombre || 'Sin nombre';
            if (!smap[n]) smap[n] = { cantidad: 0, ingresos: 0 };
            smap[n].cantidad++;
            if (c.Estado === 'Finalizada') smap[n].ingresos += (c.Precio || 0);
        });
        _repServicios = Object.keys(smap).map(function (nombre, i) {
            return {
                nombre: nombre, cantidad: smap[nombre].cantidad, ingresos: smap[nombre].ingresos,
                color: REP_COLORES[i % REP_COLORES.length]
            };
        }).sort(function (a, b) { return b.cantidad - a.cantidad; });

        repRenderRanking(_repServicios);

        if (_repServicios.length) {
            var tot = _repServicios.reduce(function (s, sv) { return s + sv.cantidad; }, 0);
            var masRent = _repServicios.slice().sort(function (a, b) { return b.ingresos - a.ingresos; })[0];
            repSetKPI('kpi-serv-top', _repServicios[0].nombre);
            repSetKPI('kpi-serv-rentable', masRent.nombre);
            repSetKPI('kpi-serv-total', _repServicios.length);
        }

        // ── Por mes ──
        var mmap = {};
        citas.forEach(function (c) {
            if (!c.Fecha) return;
            var m = c.Fecha.substring(0, 7);
            if (!mmap[m]) mmap[m] = { citas: 0, ingresos: 0 };
            mmap[m].citas++;
            if (c.Estado === 'Finalizada') mmap[m].ingresos += (c.Precio || 0);
        });
        var meses = Object.keys(mmap).sort();
        _repGanMes = meses.map(function (m, i) {
            var prev = i > 0 ? mmap[meses[i - 1]].ingresos : null;
            var vsAnt = prev ? ((mmap[m].ingresos - prev) / prev * 100) : 0;
            var ticket = mmap[m].citas > 0 ? Math.round(mmap[m].ingresos / mmap[m].citas) : 0;
            var sTop = {};
            citas.forEach(function (c) {
                if (c.Fecha && c.Fecha.startsWith(m) && c.ServicioNombre)
                    sTop[c.ServicioNombre] = (sTop[c.ServicioNombre] || 0) + 1;
            });
            var topNom = Object.keys(sTop).length
                ? Object.keys(sTop).sort(function (a, b) { return sTop[b] - sTop[a]; })[0] : '—';
            return {
                mes: REP_MESES[parseInt(m.split('-')[1]) - 1] || m,
                citas: mmap[m].citas, ingresos: mmap[m].ingresos,
                ticket: ticket, vsAnt: vsAnt, top: topNom
            };
        });

        repRenderGanancias(_repGanMes);
        repRenderTemporadas(_repGanMes);

        if (_repGanMes.length) {
            var totIng = _repGanMes.reduce(function (s, m) { return s + m.ingresos; }, 0);
            var totCits = _repGanMes.reduce(function (s, m) { return s + m.citas; }, 0);
            var ticket = totCits > 0 ? Math.round(totIng / totCits) : 0;
            var mejor = _repGanMes.slice().sort(function (a, b) { return b.ingresos - a.ingresos; })[0];
            repSetKPI('kpi-ing-total', '$' + totIng.toLocaleString('es-CO'));
            repSetKPI('kpi-ing-mejor', '$' + mejor.ingresos.toLocaleString('es-CO'));
            repSetKPI('kpi-ing-ticket', '$' + ticket.toLocaleString('es-CO'));
        }
    }

    // ════════════════════════════════════════════════════
    // REPORTE 3 — RANKING SERVICIOS
    // ════════════════════════════════════════════════════
    function repRenderRanking(servicios) {
        var max = servicios.length ? servicios[0].cantidad : 1;
        var tot = servicios.reduce(function (s, sv) { return s + sv.cantidad; }, 0);
        document.getElementById('rep-ranking-servicios').innerHTML = servicios.map(function (s, i) {
            return '<div class="rep-ranking-item">' +
                '<div class="rep-rank-num ' + (i === 1 ? 'silver' : i === 2 ? 'bronze' : '') + '">' + (i + 1) + '</div>' +
                '<div class="rep-rank-info">' +
                '<div class="rep-rank-name">' + s.nombre + '</div>' +
                '<div class="rep-rank-detail">' + s.cantidad + ' citas · $' + s.ingresos.toLocaleString('es-CO') + '</div>' +
                '</div>' +
                '<div class="rep-rank-bar-wrap"><div class="rep-rank-bar-bg">' +
                '<div class="rep-rank-bar-fill" style="width:' + Math.round(s.cantidad / max * 100) + '%;background:' + s.color + '"></div>' +
                '</div></div>' +
                '<div class="rep-rank-value" style="color:' + s.color + '">' +
                (tot > 0 ? Math.round(s.cantidad / tot * 100) : 0) + '%' +
                '</div>' +
                '</div>';
        }).join('');
    }

    // ════════════════════════════════════════════════════
    // REPORTE 4 — GANANCIAS TABLA
    // ════════════════════════════════════════════════════
    function repRenderGanancias(meses) {
        var tbody = document.getElementById('rep-tbody-ganancias');
        if (!meses || !meses.length) {
            tbody.innerHTML = '<tr><td colspan="6" style="text-align:center;color:#8b90a7;padding:28px">Sin datos</td></tr>';
