    // ════════════════════════════════════════════════════════════════
    // SERVICIOS — pestaña 5
    //
    // ENDPOINTS:
    //   GET  /Admin/GetServicios                                    → ServicioModel[]
    //   POST /Admin/GuardarServicio  (nombre,descripcion,          → { ok, mensaje }
    //                                 duracionMin,precioBase,
    //                                 activo,imagenUrl)
    //   POST /Admin/EditarServicio   (id + mismos campos)           → { ok, mensaje }
    //   POST /Admin/EliminarServicio (id)                           → { ok, mensaje }
    //
    // NOTA sobre imagenUrl: el controller actual no tiene ese campo
    //   todavía. Ver ServicioModel.cs entregado por separado.
    // ════════════════════════════════════════════════════════════════

    var _todosServicios = [];   // cache local
    var _servIdEliminar = null; // id pendiente de confirmar

    // ── Carga inicial al abrir la pestaña ────────────────────────
    function cargarServicios() {
        fetch('/Admin/GetServicios')
            .then(function (r) { return r.json(); })
            .then(function (data) {
                _todosServicios = data;
                servRenderGrid(data);
            })
            .catch(function () {
                document.getElementById('serv-grid').innerHTML =
                    '<div class="no-citas">Error al cargar servicios.</div>';
            });
    }

    // ── Renderizar grid de tarjetas ──────────────────────────────
    function servRenderGrid(lista) {
        var grid = document.getElementById('serv-grid');
        var counter = document.getElementById('serv-contador');
        if (counter) counter.textContent = lista.length + ' servicios encontrados';

        if (!lista.length) {
            grid.innerHTML = '<div class="no-citas">No hay servicios registrados.</div>';
            return;
        }

        grid.innerHTML = lista.map(function (s) {
            var imgHtml = s.ImagenUrl
                ? '<img src="' + escHtml(s.ImagenUrl) + '" alt="' + escHtml(s.Nombre) + '" ' +
                'onerror="this.style.display=\'none\';this.parentElement.innerHTML=\'✂️\'">'
                : '✂️';
            var activoBadge = s.Activo
                ? '<span class="serv-badge-activo si">Activo</span>'
                : '<span class="serv-badge-activo no">Inactivo</span>';
            return '<div class="serv-card">' +
                '<div class="serv-card-img">' + imgHtml + '</div>' +
                '<div class="serv-card-body">' +
                '<div class="serv-card-nombre">' + escHtml(s.Nombre) + '</div>' +
                '<div class="serv-card-desc">' + escHtml(s.Descripcion || '') + '</div>' +
                '<div class="serv-card-meta">' +
                '<div class="serv-meta-item">' +
                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>' +
                '</svg>' +
                (s.DuracionMin || 0) + ' min' +
                '</div>' +
                '<div class="serv-meta-item">' +
                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<line x1="12" y1="1" x2="12" y2="23"/>' +
                '<path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>' +
                '</svg>' +
                '$' + Number(s.PrecioBase || 0).toLocaleString('es-CO') +
                '</div>' +
                activoBadge +
                '</div>' +
                '<div class="serv-card-actions">' +
                '<button class="serv-btn-editar" onclick="servAbrirEditar(' + s.Id + ')">' +
                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>' +
                '<path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>' +
                '</svg> Editar' +
                '</button>' +
                '<button class="serv-btn-eliminar" onclick="servPedirEliminar(' + s.Id + ',\'' + escHtml(s.Nombre) + '\')">' +
                '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">' +
                '<polyline points="3 6 5 6 21 6"/>' +
                '<path d="M19 6l-1 14H6L5 6"/>' +
                '<path d="M10 11v6"/><path d="M14 11v6"/>' +
                '<path d="M9 6V4h6v2"/>' +
                '</svg> Eliminar' +
                '</button>' +
                '</div>' +
                '</div>' +
                '</div>';
        }).join('');
    }

    // ── Filtro en memoria ────────────────────────────────────────
    function servFiltrar(q) {
        var txt = q.toLowerCase().trim();
        servRenderGrid(txt
            ? _todosServicios.filter(function (s) {
                return (s.Nombre || '').toLowerCase().indexOf(txt) !== -1 ||
                    (s.Descripcion || '').toLowerCase().indexOf(txt) !== -1;
            })
            : _todosServicios
        );
    }

    // ── Abrir modal NUEVO ─────────────────────────────────────────
    function servAbrirNuevo() {
        document.getElementById('serv-modal-titulo').textContent = 'Nuevo Servicio';
        document.getElementById('serv-f-id').value = '';
        document.getElementById('serv-f-nombre').value = '';
        document.getElementById('serv-f-desc').value = '';
        document.getElementById('serv-f-duracion').value = '';
        document.getElementById('serv-f-precio').value = '';
        document.getElementById('serv-f-activo').checked = true;
        document.getElementById('serv-f-imagen').value = '';
        servPreviewImagen('');
        document.getElementById('serv-btn-guardar').disabled = false;
        document.getElementById('serv-modal-overlay').classList.add('open');
        setTimeout(function () { document.getElementById('serv-f-nombre').focus(); }, 100);
    }

    // ── Abrir modal EDITAR ────────────────────────────────────────
    function servAbrirEditar(id) {
        var s = _todosServicios.find(function (x) { return x.Id === id; });
        if (!s) return;
        document.getElementById('serv-modal-titulo').textContent = 'Editar Servicio';
        document.getElementById('serv-f-id').value = s.Id;
        document.getElementById('serv-f-nombre').value = s.Nombre || '';
        document.getElementById('serv-f-desc').value = s.Descripcion || '';
        document.getElementById('serv-f-duracion').value = s.DuracionMin || '';
        document.getElementById('serv-f-precio').value = s.PrecioBase || '';
        document.getElementById('serv-f-activo').checked = s.Activo;
        document.getElementById('serv-f-imagen').value = s.ImagenUrl || '';
        servPreviewImagen(s.ImagenUrl || '');
        document.getElementById('serv-btn-guardar').disabled = false;
        document.getElementById('serv-modal-overlay').classList.add('open');
    }

    // ── Cerrar modal ─────────────────────────────────────────────
    function servCerrarModal(e) {
        if (e && e.target !== document.getElementById('serv-modal-overlay')) return;
        document.getElementById('serv-modal-overlay').classList.remove('open');
    }

    // ── Preview de imagen ─────────────────────────────────────────
    function servPreviewImagen(url) {
        var wrap = document.getElementById('serv-preview-wrap');
        var emoji = document.getElementById('serv-preview-emoji');
        if (url && url.startsWith('http')) {
            wrap.innerHTML = '<img src="' + escHtml(url) + '" style="width:100%;height:100%;object-fit:cover;" ' +
                'onerror="this.parentElement.innerHTML=\'<span id=serv-preview-emoji>✂️</span>\'">';
        } else {
            wrap.innerHTML = '<span id="serv-preview-emoji">✂️</span>';
        }
    }

    // ── Guardar (crear o editar) ──────────────────────────────────
    function servGuardar() {
        var id = document.getElementById('serv-f-id').value.trim();
        var nombre = document.getElementById('serv-f-nombre').value.trim();
        var desc = document.getElementById('serv-f-desc').value.trim();
        var duracion = parseInt(document.getElementById('serv-f-duracion').value) || 0;
        var precio = parseInt(document.getElementById('serv-f-precio').value) || 0;
        var activo = document.getElementById('serv-f-activo').checked;
        var imagen = document.getElementById('serv-f-imagen').value.trim();

        if (!nombre) { servToast('El nombre es obligatorio.', 'err'); return; }
        if (duracion <= 0) { servToast('La duración debe ser mayor a 0.', 'err'); return; }
        if (precio <= 0) { servToast('El precio debe ser mayor a 0.', 'err'); return; }

        var btn = document.getElementById('serv-btn-guardar');
        btn.disabled = true;
        btn.textContent = 'Guardando...';

        var url = id ? '/Admin/EditarServicio' : '/Admin/GuardarServicio';
        var params = 'nombre=' + encodeURIComponent(nombre) +
            '&descripcion=' + encodeURIComponent(desc) +
            '&duracionMin=' + duracion +
            '&precioBase=' + precio +
            '&activo=' + activo +
            '&imagenUrl=' + encodeURIComponent(imagen);
        if (id) params += '&id=' + id;

        fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: params
        })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                if (res.ok) {
                    servCerrarModal();
                    servToast(res.mensaje || 'Guardado correctamente', 'ok');
                    cargarServicios();  // refrescar grid
                } else {
                    servToast(res.mensaje || 'Error al guardar', 'err');
                    btn.disabled = false;
                    btn.textContent = 'Guardar';
                }
            })
            .catch(function () {
                servToast('Error de conexión con el servidor.', 'err');
                btn.disabled = false;
                btn.textContent = 'Guardar';
            });
    }

    // ── Pedir confirmación de eliminación ────────────────────────
    function servPedirEliminar(id, nombre) {
        _servIdEliminar = id;
        document.getElementById('serv-confirm-nombre').textContent =
            '¿Eliminar "' + nombre + '"? Esta acción no se puede deshacer.';
        document.getElementById('serv-confirm-overlay').classList.add('open');
    }

    function servCerrarConfirm() {
        _servIdEliminar = null;
        document.getElementById('serv-confirm-overlay').classList.remove('open');
    }

    function servConfirmarEliminar() {
        if (!_servIdEliminar) return;
        fetch('/Admin/EliminarServicio', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'id=' + _servIdEliminar
        })
            .then(function (r) { return r.json(); })
            .then(function (res) {
                servCerrarConfirm();
                if (res.ok) {
                    servToast(res.mensaje || 'Servicio eliminado.', 'ok');
                    cargarServicios();
                } else {
                    servToast(res.mensaje || 'Error al eliminar.', 'err');
                }
            })
            .catch(function () {
                servToast('Error de conexión.', 'err');
                servCerrarConfirm();
            });
    }

    // ── Toast ────────────────────────────────────────────────────
    function servToast(msg, tipo) {
        var t = document.getElementById('serv-toast');
        t.textContent = msg;
        t.className = 'serv-toast ' + (tipo || 'ok');
        t.style.display = 'block';
        clearTimeout(t._timer);
        t._timer = setTimeout(function () { t.style.display = 'none'; }, 3500);
    }

    // ── Utilidad: escapar HTML ────────────────────────────────────
    function escHtml(str) {
        return String(str || '')
            .replace(/&/g, '&amp;').replace(/</g, '&lt;')
            .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
    }




    // ════════════════════════════════════════════════════════════════
    // GENERADOR DE PDF PROFESIONAL — Belleza Suprema
    // Usa jsPDF + jsPDF-AutoTable (ya incluidos en el Index)
    // Captura los gráficos del reporte activo con canvas.toDataURL()
    // Incluye: portada, KPIs, gráficas y tabla de datos
    // ════════════════════════════════════════════════════════════════

    function repGenerarPDF() {
        var btn = document.getElementById('rep-btn-pdf');
        btn.disabled = true;
        btn.textContent = '⏳ Generando...';

        setTimeout(function () {
            try {
                _repGenerarPDFInterno();
            } catch (e) {
                console.error('Error PDF:', e);
                servToast('Error al generar PDF: ' + e.message, 'err');
            }
            btn.disabled = false;
            btn.innerHTML = '<svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg> PDF';
        }, 100);
    }

    function _repGenerarPDFInterno() {
        // Detectar qué reporte está activo
        var tabActivo = 0;
        document.querySelectorAll('.rtab').forEach(function (b, i) {
            if (b.classList.contains('active')) tabActivo = i;
        });

        var reporteNames = ['Citas Agendadas', 'Comparativa de Reservas', 'Top Servicios', 'Ganancias Mensuales', 'Próximas Citas', 'Historial por Cliente'];
        var reporteNombre = reporteNames[tabActivo] || 'Reporte';

        var doc = new window.jspdf.jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
        var W = 210, H = 297;
        var ahora = new Date();
        var fechaHoy = ahora.toLocaleDateString('es-CO', { day: '2-digit', month: 'long', year: 'numeric' });

        // ── PALETA ──────────────────────────────────────────────
        var MORADO = [124, 58, 237];
        var FUCSIA = [192, 38, 211];
        var BLANCO = [255, 255, 255];
        var GRIS_L = [248, 246, 255];
        var GRIS_T = [139, 144, 167];
        var NEGRO = [26, 29, 46];
        var VERDE = [5, 150, 105];
        var ROJO = [220, 38, 38];
        var AMBAR = [217, 119, 6];
        var AZUL = [37, 99, 235];

        // ════════════════════════════════════════
        // PORTADA
        // ════════════════════════════════════════

        // Fondo degradado simulado con rectángulos
        doc.setFillColor(124, 58, 237);
        doc.rect(0, 0, W, 80, 'F');
        doc.setFillColor(160, 50, 230);
        doc.rect(0, 40, W, 40, 'F');
        doc.setFillColor(192, 38, 211);
        doc.rect(0, 55, W, 25, 'F');

        // Decoración geométrica
        doc.setFillColor(255, 255, 255);
        doc.setGlobalAlpha(0.06);
        doc.circle(185, 15, 35, 'F');
        doc.circle(20, 70, 25, 'F');
        doc.setGlobalAlpha(1);

        // Logo ✿ simulado con círculo + texto
        doc.setFillColor(255, 255, 255);
        doc.setGlobalAlpha(0.15);
        doc.roundedRect(14, 12, 22, 22, 4, 4, 'F');
        doc.setGlobalAlpha(1);
        doc.setFontSize(14);
        doc.setTextColor(255, 255, 255);
        doc.setFont('helvetica', 'bold');
        doc.text('BS', 25, 26, { align: 'center' });

        // Nombre de la empresa
        doc.setFontSize(22);
        doc.setTextColor(255, 255, 255);
        doc.setFont('helvetica', 'bold');
        doc.text('Belleza Suprema', 42, 24);

        doc.setFontSize(9);
        doc.setFont('helvetica', 'normal');
        doc.setTextColor(230, 200, 255);
        doc.text('Centro de estética y bienestar integral', 42, 31);

        // Línea separadora blanca semitransparente
        doc.setDrawColor(255, 255, 255);
        doc.setGlobalAlpha(0.3);
        doc.line(14, 36, W - 14, 36);
        doc.setGlobalAlpha(1);

        // Título del reporte
        doc.setFontSize(26);
        doc.setTextColor(255, 255, 255);
        doc.setFont('helvetica', 'bold');
        doc.text('Reporte:', 14, 54);

        doc.setFontSize(20);
        doc.setTextColor(240, 200, 255);
        doc.text(reporteNombre, 14, 66);

        // Fecha
        doc.setFontSize(9);
        doc.setFont('helvetica', 'normal');
        doc.setTextColor(200, 180, 240);
        doc.text('Generado el ' + fechaHoy, 14, 75);

        // ── BANDA DECORATIVA INFERIOR PORTADA ──
        doc.setFillColor(248, 246, 255);
        doc.rect(0, 80, W, H - 80, 'F');

        // ── RECUADRO RESUMEN KPIs en portada ──
        doc.setFillColor(255, 255, 255);
        doc.setDrawColor(230, 220, 255);
        doc.setLineWidth(0.5);
        doc.roundedRect(14, 90, W - 28, 44, 4, 4, 'FD');

        // KPIs de portada según reporte activo
        var kpiData = _repGetKPIsParaPDF(tabActivo);
        var colW = (W - 28) / kpiData.length;
        kpiData.forEach(function (kpi, i) {
            var x = 14 + (i * colW) + colW / 2;
            // Valor
            doc.setFontSize(18);
            doc.setFont('helvetica', 'bold');
            doc.setTextColor(kpi.color[0], kpi.color[1], kpi.color[2]);
            doc.text(String(kpi.valor), x, 108, { align: 'center' });
            // Label
            doc.setFontSize(8);
            doc.setFont('helvetica', 'normal');
            doc.setTextColor(GRIS_T[0], GRIS_T[1], GRIS_T[2]);
            doc.text(kpi.label, x, 115, { align: 'center' });
            // Separador vertical
            if (i < kpiData.length - 1) {
                doc.setDrawColor(220, 210, 250);
                doc.line(14 + (i + 1) * colW, 94, 14 + (i + 1) * colW, 130);
            }
        });

        // ── ETIQUETA TIPO DOCUMENTO ──
        doc.setFillColor(MORADO[0], MORADO[1], MORADO[2]);
        doc.roundedRect(14, 142, 60, 8, 2, 2, 'F');
        doc.setFontSize(8);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(255, 255, 255);
        doc.text('INFORME ANALÍTICO', 44, 147.5, { align: 'center' });

        // ── DESCRIPCIÓN ──
        doc.setFontSize(11);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(NEGRO[0], NEGRO[1], NEGRO[2]);
        doc.text('Descripción del Reporte', 14, 162);
        doc.setFontSize(9);
        doc.setFont('helvetica', 'normal');
        doc.setTextColor(GRIS_T[0], GRIS_T[1], GRIS_T[2]);
        var descTextos = {
            0: 'Este reporte muestra el consolidado de todas las citas registradas en el sistema, incluyendo estados (Finalizada, Confirmada, Pendiente, Cancelada), análisis por servicios y evolución temporal.',
            1: 'Análisis comparativo entre el año actual y el año anterior. Incluye variaciones mensuales, tasas de cancelación y asistencia, y clasificación de temporadas (Alta, Media, Baja).',
            2: 'Ranking de los servicios más solicitados por los clientes, con análisis de participación porcentual, ingresos generados y comparativa de rentabilidad entre servicios.',
            3: 'Evolución de los ingresos estimados mes a mes basados en citas finalizadas. Incluye ticket promedio, mejor mes del período y tendencia financiera general.',
            4: 'Listado de citas pendientes y confirmadas ordenadas por fecha. Las marcadas como urgentes corresponden a citas programadas para hoy o mañana.',
            5: 'Historial completo de un cliente específico incluyendo total de citas, gasto acumulado, servicio favorito, nivel de fidelización y valor como cliente.'
        };
        var descLines = doc.splitTextToSize(descTextos[tabActivo] || descTextos[0], W - 28);
        doc.text(descLines, 14, 170);

        // ── PIE DE PORTADA ──
        doc.setFillColor(MORADO[0], MORADO[1], MORADO[2]);
        doc.rect(0, H - 18, W, 18, 'F');
        doc.setFontSize(8);
        doc.setFont('helvetica', 'normal');
        doc.setTextColor(200, 180, 255);
        doc.text('Belleza Suprema · Panel Administrativo · Confidencial', W / 2, H - 10, { align: 'center' });
        doc.setTextColor(240, 230, 255);
        doc.text('Página 1', W - 14, H - 10, { align: 'right' });

        // ════════════════════════════════════════
        // PÁGINA 2 — GRÁFICAS
        // ════════════════════════════════════════
        doc.addPage();

        // Header página 2
        doc.setFillColor(MORADO[0], MORADO[1], MORADO[2]);
        doc.rect(0, 0, W, 16, 'F');
        doc.setFontSize(9);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(255, 255, 255);
        doc.text('Belleza Suprema  ·  ' + reporteNombre, 14, 10);
        doc.text('Página 2', W - 14, 10, { align: 'right' });

        // Título sección gráficas
        doc.setFontSize(14);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(NEGRO[0], NEGRO[1], NEGRO[2]);
        doc.text('Análisis Visual', 14, 28);
        doc.setFillColor(MORADO[0], MORADO[1], MORADO[2]);
        doc.rect(14, 30, 30, 1, 'F');

        // Capturar gráficas del reporte activo
        var canvasIds = _repGetCanvasIds(tabActivo);
        var yPos = 36;
        var graficasAgregadas = 0;

        canvasIds.forEach(function (canvasId) {
            var canvas = document.getElementById(canvasId);
            if (!canvas) return;
            try {
                var imgData = canvas.toDataURL('image/png', 0.95);
                if (imgData === 'data:,') return;

                // Calcular dimensiones manteniendo ratio
                var cW = canvas.width, cH = canvas.height;
                var maxW = W - 28;
                var maxH = 75;
                var ratio = Math.min(maxW / cW, maxH / cH);
                var imgW = cW * ratio;
                var imgH = cH * ratio;

                // Card contenedor
                doc.setFillColor(255, 255, 255);
                doc.setDrawColor(230, 220, 250);
                doc.setLineWidth(0.4);
                doc.roundedRect(14, yPos, W - 28, imgH + 12, 3, 3, 'FD');

                // Título del gráfico
                doc.setFontSize(8);
                doc.setFont('helvetica', 'bold');
                doc.setTextColor(MORADO[0], MORADO[1], MORADO[2]);
                var chartTitles = {
                    'rep-chart-estados': 'Distribución por Estado',
                    'rep-chart-evolucion': 'Evolución Mensual de Citas',
                    'rep-chart-comparativa': 'Comparativa Año Actual vs Anterior',
                    'rep-chart-variacion': 'Variación Porcentual Mensual',
                    'rep-chart-pastel': 'Participación por Servicio',
                    'rep-chart-ingresos-serv': 'Ingresos por Servicio',
                    'rep-chart-ganancias': 'Ingresos Mensuales',
                    'rep-chart-prof': 'Distribución de Ingresos',
                    'rep-chart-evol-fin': 'Evolución Financiera'
                };
                doc.text(chartTitles[canvasId] || canvasId, 20, yPos + 7);

                // Imagen del gráfico
                doc.addImage(imgData, 'PNG', 14 + (W - 28 - imgW) / 2, yPos + 10, imgW, imgH);
                yPos += imgH + 18;
                graficasAgregadas++;

                // Nueva página si no hay espacio
                if (yPos > H - 40 && graficasAgregadas < canvasIds.length) {
                    doc.addPage();
                    doc.setFillColor(MORADO[0], MORADO[1], MORADO[2]);
                    doc.rect(0, 0, W, 16, 'F');
                    doc.setFontSize(9);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(255, 255, 255);
                    doc.text('Belleza Suprema  ·  ' + reporteNombre + '  (continuación)', 14, 10);
                    var pgNum = doc.internal.getNumberOfPages();
                    doc.text('Página ' + pgNum, W - 14, 10, { align: 'right' });
                    yPos = 24;
                }
            } catch (err) {
                console.warn('No se pudo capturar gráfica:', canvasId, err);
            }
        });

        if (graficasAgregadas === 0) {
            doc.setFontSize(11);
            doc.setTextColor(GRIS_T[0], GRIS_T[1], GRIS_T[2]);
            doc.text('Las gráficas se generan al cargar los datos del servidor.', W / 2, 80, { align: 'center' });
            doc.text('Abre el reporte primero para que las gráficas aparezcan en el PDF.', W / 2, 90, { align: 'center' });
        }

        // Pie página 2
        doc.setFillColor(MORADO[0], MORADO[1], MORADO[2]);
        doc.rect(0, H - 18, W, 18, 'F');
        doc.setFontSize(8);
        doc.setTextColor(200, 180, 255);
        doc.text('Belleza Suprema · Panel Administrativo · Confidencial', W / 2, H - 10, { align: 'center' });
        doc.setTextColor(240, 230, 255);
        doc.text('Página 2', W - 14, H - 10, { align: 'right' });

        // ════════════════════════════════════════
        // PÁGINA 3 — TABLA DE DATOS
        // ════════════════════════════════════════
        doc.addPage();

        // Header página 3
        doc.setFillColor(MORADO[0], MORADO[1], MORADO[2]);
        doc.rect(0, 0, W, 16, 'F');
        doc.setFontSize(9);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(255, 255, 255);
        doc.text('Belleza Suprema  ·  ' + reporteNombre, 14, 10);
        doc.text('Página 3', W - 14, 10, { align: 'right' });

        doc.setFontSize(14);
        doc.setFont('helvetica', 'bold');
        doc.setTextColor(NEGRO[0], NEGRO[1], NEGRO[2]);
        doc.text('Detalle de Datos', 14, 28);
        doc.setFillColor(MORADO[0], MORADO[1], MORADO[2]);
        doc.rect(14, 30, 30, 1, 'F');

        // Obtener tabla según reporte activo
        var tablaData = _repGetTablaParaPDF(tabActivo);

        if (tablaData.rows.length === 0) {
            doc.setFontSize(11);
            doc.setTextColor(GRIS_T[0], GRIS_T[1], GRIS_T[2]);
            doc.text('No hay datos disponibles para este reporte.', W / 2, 60, { align: 'center' });
            doc.text('Carga los datos desde el servidor antes de generar el PDF.', W / 2, 70, { align: 'center' });
        } else {
            doc.autoTable({
                startY: 36,
                head: [tablaData.cols],
                body: tablaData.rows,
                styles: {
                    font: 'helvetica',
                    fontSize: 8,
                    cellPadding: 4,
                    textColor: [26, 29, 46],
                    lineColor: [220, 210, 250],
                    lineWidth: 0.3,
                },
                headStyles: {
                    fillColor: [124, 58, 237],
                    textColor: [255, 255, 255],
                    fontStyle: 'bold',
                    fontSize: 8.5,
                    halign: 'center',
                },
                alternateRowStyles: {
                    fillColor: [248, 246, 255],
                },
                columnStyles: {
                    0: { halign: 'left', fontStyle: 'bold' },
                },
                margin: { left: 14, right: 14 },
                didDrawPage: function (d) {
                    // Header en cada página extra de la tabla
                    doc.setFillColor(MORADO[0], MORADO[1], MORADO[2]);
                    doc.rect(0, 0, W, 16, 'F');
                    doc.setFontSize(9);
                    doc.setFont('helvetica', 'bold');
                    doc.setTextColor(255, 255, 255);
                    doc.text('Belleza Suprema  ·  ' + reporteNombre, 14, 10);
                    var pgN = doc.internal.getNumberOfPages();
                    doc.text('Página ' + pgN, W - 14, 10, { align: 'right' });

                    // Pie
                    doc.setFillColor(MORADO[0], MORADO[1], MORADO[2]);
                    doc.rect(0, H - 18, W, 18, 'F');
                    doc.setFontSize(8);
                    doc.setTextColor(200, 180, 255);
                    doc.text('Belleza Suprema · Panel Administrativo · Confidencial', W / 2, H - 10, { align: 'center' });
                    doc.setTextColor(240, 230, 255);
                    doc.text('Página ' + pgN, W - 14, H - 10, { align: 'right' });
                },
                margin: { top: 22, bottom: 22, left: 14, right: 14 },
            });
        }

        // ── Total registros ──
        var finalY = doc.lastAutoTable ? doc.lastAutoTable.finalY + 8 : 60;
        if (finalY < H - 30) {
            doc.setFontSize(8);
            doc.setFont('helvetica', 'italic');
            doc.setTextColor(GRIS_T[0], GRIS_T[1], GRIS_T[2]);
            doc.text('Total de registros: ' + tablaData.rows.length, 14, finalY);
            doc.text('Generado por Panel Administrativo Belleza Suprema · ' + fechaHoy, W - 14, finalY, { align: 'right' });
        }

        // ── GUARDAR ──
        var nombre = 'Belleza_Suprema_' + reporteNombre.replace(/ /g, '_') + '_' + ahora.toISOString().substring(0, 10) + '.pdf';
        doc.save(nombre);
        servToast('✅ PDF generado: ' + nombre, 'ok');
    }

    // ── Obtener KPIs para la portada según reporte activo ──────────
    function _repGetKPIsParaPDF(tab) {
        var kpi = _repKPI || {};
        var conf = Math.max(0, (kpi.TotalCitas || 0) - (kpi.CitasPendientes || 0) - (kpi.CitasCanceladas || 0) - (kpi.CitasFinalizadas || 0));
        var tot = kpi.TotalCitas || 0;
        switch (tab) {
            case 0: return [
                { label: 'Total Citas', valor: tot, color: [124, 58, 237] },
                { label: 'Finalizadas', valor: kpi.CitasFinalizadas || 0, color: [5, 150, 105] },
                { label: 'Pendientes', valor: kpi.CitasPendientes || 0, color: [217, 119, 6] },
                { label: 'Canceladas', valor: kpi.CitasCanceladas || 0, color: [220, 38, 38] },
            ];
            case 1: return [
                { label: 'Total Citas', valor: tot, color: [124, 58, 237] },
                { label: 'Tasa Cancelación', valor: tot > 0 ? (kpi.CitasCanceladas / tot * 100).toFixed(1) + '%' : '0%', color: [220, 38, 38] },
                { label: 'Tasa Asistencia', valor: tot > 0 ? ((tot - kpi.CitasCanceladas) / tot * 100).toFixed(1) + '%' : '0%', color: [5, 150, 105] },
            ];
            case 2: var sv = _repServicios;
                return [
                    { label: 'Total Servicios', valor: sv.length, color: [124, 58, 237] },
                    { label: 'Servicio Top', valor: sv.length ? sv[0].nombre.substring(0, 12) : '—', color: [192, 38, 211] },
                    { label: 'Mayor Ingreso', valor: sv.length ? '$' + (sv.slice().sort(function (a, b) { return b.ingresos - a.ingresos; })[0].ingresos / 1000).toFixed(0) + 'K' : '—', color: [5, 150, 105] },
                ];
            case 3: var gm = _repGanMes;
                var totIng = gm.reduce(function (s, m) { return s + m.ingresos; }, 0);
                var ticket = gm.reduce(function (s, m) { return s + m.citas; }, 0);
                return [
                    { label: 'Ingresos Totales', valor: '$' + (totIng / 1000000).toFixed(1) + 'M', color: [5, 150, 105] },
                    { label: 'Meses con datos', valor: gm.length, color: [124, 58, 237] },
                    { label: 'Total Citas', valor: ticket, color: [37, 99, 235] },
                ];
            case 4:
                var hoyS2 = repFmtFecha(new Date());
                var manS2 = repFmtFecha(new Date(Date.now() + 86400000));
                var prox2 = _repCitas.filter(function (c) { return c.Estado === 'Pendiente' || c.Estado === 'Confirmada'; });
                return [
                    { label: 'Urgentes (hoy/mañana)', valor: prox2.filter(function (c) { return c.Fecha === hoyS2 || c.Fecha === manS2; }).length, color: [220, 38, 38] },
                    { label: 'Total Pendientes', valor: prox2.length, color: [124, 58, 237] },
                    { label: 'Confirmadas', valor: prox2.filter(function (c) { return c.Estado === 'Confirmada'; }).length, color: [5, 150, 105] },
                ];
            default: return [
                { label: 'Total Citas', valor: tot, color: [124, 58, 237] },
                { label: 'Usuarios', valor: kpi.TotalUsuarios || 0, color: [37, 99, 235] },
                { label: 'Ingresos', valor: '$' + (kpi.IngresosEstimados / 1000000 || 0).toFixed(1) + 'M', color: [5, 150, 105] },
            ];
        }
    }

    // ── IDs de canvas según reporte activo ─────────────────────────
    function _repGetCanvasIds(tab) {
        switch (tab) {
            case 0: return ['rep-chart-estados', 'rep-chart-evolucion'];
            case 1: return ['rep-chart-comparativa', 'rep-chart-variacion'];
            case 2: return ['rep-chart-pastel', 'rep-chart-ingresos-serv'];
            case 3: return ['rep-chart-ganancias', 'rep-chart-evol-fin'];
            case 4: return ['rep-chart-estados'];
            case 5: return [];
            default: return [];
        }
    }

    // ── Datos de la tabla según reporte activo ──────────────────────
    function _repGetTablaParaPDF(tab) {
        switch (tab) {
            case 0: // Citas
                return {
                    cols: ['Cliente', 'Servicio', 'Fecha', 'Hora', 'Precio', 'Estado'],
                    rows: _repCitas.map(function (c) {
                        return [
                            c.NombreCliente || '—', c.ServicioNombre || '—',
                            c.Fecha || '—', c.HoraInicio || '—',
                            '$' + Number(c.Precio || 0).toLocaleString('es-CO'),
                            c.Estado || '—'
                        ];
                    })
                };
            case 1: // Comparativa — muestra evolución mensual
                var anioA = new Date().getFullYear();
                var datA = Array(12).fill(0);
                _repCitas.forEach(function (c) {
                    if (!c.Fecha) return;
                    if (parseInt(c.Fecha.substring(0, 4)) === anioA)
                        datA[parseInt(c.Fecha.substring(5, 7)) - 1]++;
                });
                return {
                    cols: ['Mes', 'Citas ' + anioA, '% del Total'],
                    rows: ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'].map(function (m, i) {
                        var tot2 = datA.reduce(function (s, v) { return s + v; }, 0);
                        return [m, datA[i], tot2 > 0 ? (datA[i] / tot2 * 100).toFixed(1) + '%' : '0%'];
                    }).filter(function (r) { return r[1] > 0; })
                };
            case 2: // Servicios
                return {
                    cols: ['Servicio', 'Citas', 'Ingresos', '% Participación'],
                    rows: (function () {
                        var tot3 = _repServicios.reduce(function (s, sv) { return s + sv.cantidad; }, 0);
                        return _repServicios.map(function (sv) {
                            return [
                                sv.nombre,
                                sv.cantidad,
                                '$' + sv.ingresos.toLocaleString('es-CO'),
                                tot3 > 0 ? (sv.cantidad / tot3 * 100).toFixed(1) + '%' : '0%'
                            ];
                        });
                    })()
                };
            case 3: // Ganancias
                return {
                    cols: ['Mes', 'Citas', 'Ingresos', 'Ticket Prom.', 'vs Mes Ant.', 'Servicio Top'],
                    rows: _repGanMes.map(function (m) {
                        return [
                            m.mes, m.citas,
                            '$' + m.ingresos.toLocaleString('es-CO'),
                            '$' + m.ticket.toLocaleString('es-CO'),
                            (m.vsAnt >= 0 ? '+' : '') + m.vsAnt.toFixed(1) + '%',
                            m.top
                        ];
                    })
                };
            case 4: // Próximas
                var hoyS3 = repFmtFecha(new Date());
                var manS3 = repFmtFecha(new Date(Date.now() + 86400000));
                return {
                    cols: ['Urgente', 'Fecha', 'Hora', 'Cliente', 'Servicio', 'Estado'],
                    rows: _repCitas
                        .filter(function (c) { return c.Estado === 'Pendiente' || c.Estado === 'Confirmada'; })
                        .sort(function (a, b) { return (a.Fecha + a.HoraInicio).localeCompare(b.Fecha + b.HoraInicio); })
                        .map(function (c) {
                            var urg = c.Fecha === hoyS3 || c.Fecha === manS3;
                            return [urg ? '🔴 Urgente' : '🟢 Normal', c.Fecha || '—', c.HoraInicio || '—', c.NombreCliente || '—', c.ServicioNombre || '—', c.Estado || '—'];
                        })
                };
            default:
                return { cols: ['Campo', 'Valor'], rows: [['Sin datos', '—']] };
        }
    }


</script>
