                '<td style="font-family:monospace;font-size:12px;color:#059669;font-weight:600;">$' + m.ingresos.toLocaleString('es-CO') + '</td>' +
                '<td style="font-family:monospace;font-size:12px;">$' + m.ticket.toLocaleString('es-CO') + '</td>' +
                '<td class="' + (m.vsAnt >= 0 ? 'rep-up' : 'rep-down') + '">' + (m.vsAnt >= 0 ? '↑' : '↓') + ' ' + Math.abs(m.vsAnt).toFixed(1) + '%</td>' +
                '<td><span class="rep-badge rep-badge-fin">' + m.top + '</span></td>' +
