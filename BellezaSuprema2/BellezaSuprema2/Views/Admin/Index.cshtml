    .rep-kpi-card::before {
      content:''; position:absolute; top:0; left:0; right:0; height:3px;
      background:var(--kpi-color, var(--rep-grad));
    }
    .rep-kpi-label { font-size:10px; font-weight:700; color:var(--rep-muted); text-transform:uppercase; letter-spacing:.6px; margin-bottom:6px; }
    .rep-kpi-value { font-size:26px; font-weight:800; line-height:1; color:var(--kpi-color,#7c3aed); margin-bottom:3px; }
    .rep-kpi-desc  { font-size:11px; color:var(--rep-muted); }
    .rep-kpi-trend { display:inline-flex; align-items:center; gap:3px; font-size:10px; font-weight:600; margin-top:5px; padding:2px 7px; border-radius:20px; }
    .rep-kpi-trend.up   { background:#d1fae5; color:#059669; }
    .rep-kpi-trend.down { background:#fee2e2; color:#dc2626; }

    /* ── CARDS ── */
    .rep-card {
      background:#fff; border-radius:var(--rep-r); padding:20px;
      border:1px solid var(--rep-border); box-shadow:var(--rep-shadow); margin-bottom:18px;
    }
