    .rep-rank-bar-wrap { flex:1; max-width:110px; }
    .rep-rank-bar-bg   { background:#f0f0f8; border-radius:20px; height:5px; }
    .rep-rank-bar-fill { height:5px; border-radius:20px; background:var(--rep-grad); }
    .rep-rank-value    { font-size:13px; font-weight:700; color:#7c3aed; min-width:44px; text-align:right; }

    /* ── CLIENTE HEADER ── */
    .rep-cliente-header {
      background:linear-gradient(135deg,#c026d3,#7c3aed); border-radius:var(--rep-r);
      padding:22px; display:flex; align-items:center; gap:18px;
