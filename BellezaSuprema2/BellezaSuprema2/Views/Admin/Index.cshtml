    // ════════════════════════════════════════════════════════════
    // GENERAR PDF
    // Flujo:
    //   1. Determinar rango (mes completo o fechas libres).
    //   2. Pedir TODAS las citas al servidor (GET /Admin/GetCitas).
    //   3. Filtrar por el rango elegido en el cliente.
    //   4. VALIDACIÓN → si citas.length === 0:
    //        mostrar alerta y ABORTAR (no generar PDF vacío).
    //   5. Si hay datos → construirPDF().
    // ════════════════════════════════════════════════════════════
    function generarPDF() {
        var desde, hasta, titulo;

        // ── Paso 1: determinar rango según el tipo de filtro ──
        if (tipoPeriodo === 'mes') {
            var mes = document.getElementById('input-mes').value;
            if (!mes) { alert('Selecciona un mes.'); return; }

            var partes = mes.split('-');
            var anio = parseInt(partes[0]);
            var numMes = parseInt(partes[1]);

            desde = mes + '-01';
            // Último día del mes seleccionado
            hasta = mes + '-' + String(new Date(anio, numMes, 0).getDate()).padStart(2, '0');
            titulo = 'Reporte de ' + mesesEs[numMes - 1] + ' ' + anio;

        } else {
            desde = document.getElementById('input-desde').value;
            hasta = document.getElementById('input-hasta').value;
            if (!desde || !hasta) { alert('Selecciona las fechas de inicio y fin.'); return; }
            if (desde > hasta) { alert('La fecha de inicio no puede ser mayor a la de fin.'); return; }
            titulo = 'Reporte del ' + desde + ' al ' + hasta;
        }

        // ── Paso 2 y 3: obtener citas y filtrar por rango ──
        fetch('/Admin/GetCitas?estado=Todos')
            .then(function (r) { return r.json(); })
            .then(function (todas) {
                var citas = todas.filter(function (c) {
                    return c.Fecha >= desde && c.Fecha <= hasta;
                });

                // ── Paso 4: VALIDACIÓN sin datos ──────────────
                // Si no hay citas en el período, mostrar alerta
                // estilizada y NO generar un PDF vacío.
                if (citas.length === 0) {
                    mostrarMensajeSinDatos(titulo);
                    return;
                }

                // ── Paso 5: construir y descargar el PDF ──────
                construirPDF(titulo, desde, hasta, citas);
            })
            .catch(function () {
                alert('Error al obtener datos. Intenta de nuevo.');
            });
    }


    // ════════════════════════════════════════════════════════════
    // MOSTRAR MENSAJE SIN DATOS
    // Inserta una alerta estilizada debajo del panel PDF cuando
    // no existen citas para el período seleccionado.
    //
    // Comportamiento:
    //   • Elimina una alerta previa si todavía está visible.
    //   • Aparece con animación fadeInUp.
    //   • Se cierra manualmente con el botón "×".
    //   • Se elimina automáticamente a los 6 segundos.
    // ════════════════════════════════════════════════════════════
    function mostrarMensajeSinDatos(titulo) {
        // Limpiar alerta anterior si existe
        var anterior = document.getElementById('alerta-sin-datos');
        if (anterior) anterior.remove();

        // Crear el elemento de alerta
        var alerta = document.createElement('div');
        alerta.id = 'alerta-sin-datos';
        alerta.className = 'alerta-sin-datos';

        alerta.innerHTML =
            // Ícono de advertencia
            '<div class="alerta-icono">' +
            '<svg viewBox="0 0 24 24" fill="none" stroke="#e879f9" stroke-width="2" ' +
            'stroke-linecap="round" stroke-linejoin="round" width="24" height="24">' +
            '<circle cx="12" cy="12" r="10"/>' +
            '<line x1="12" y1="8"  x2="12"    y2="12"/>' +
            '<line x1="12" y1="16" x2="12.01" y2="16"/>' +
            '</svg>' +
            '</div>' +
            // Textos
            '<div>' +
            '<div class="alerta-titulo">Sin datos para este período</div>' +
            '<div class="alerta-texto">' +
            'No se encontraron citas en <strong>' + titulo + '</strong>. ' +
            'Intenta con otro mes o rango de fechas.' +
            '</div>' +
            '</div>' +
            // Botón cerrar
            '<button class="alerta-cerrar" onclick="this.parentElement.remove()" title="Cerrar">×</button>';

        // Insertar justo después del panel PDF
        document.getElementById('pdf-panel').after(alerta);

        // Auto-eliminar a los 6 segundos
        setTimeout(function () {
            if (alerta.parentElement) alerta.remove();
        }, 6000);
    }


    // ════════════════════════════════════════════════════════════
    // CONSTRUIR PDF con jsPDF + autoTable
    //
    // Estructura del documento A4:
    //   ┌─ Encabezado morado (nombre + fecha de generación)
    //   ├─ Bloque de título y período
    //   ├─ Sección 1 – Resumen (6 tarjetas en 2 columnas)
    //   ├─ Sección 2 – Servicios más solicitados (tabla)
    //   ├─ Sección 3 – Detalle de citas (tabla)
    //   └─ Pie de página en todas las páginas
    // ════════════════════════════════════════════════════════════
    function construirPDF(titulo, desde, hasta, citas) {
        var doc = new window.jspdf.jsPDF({ orientation: 'portrait', unit: 'mm', format: 'a4' });
        var pw = doc.internal.pageSize.getWidth();   // 210 mm
        var ph = doc.internal.pageSize.getHeight();  // 297 mm
        var y = 0;                                  // Cursor vertical

        // ── Encabezado morado ──
        doc.setFillColor(192, 38, 211);
        doc.rect(0, 0, pw, 28, 'F');
        doc.setTextColor(255, 255, 255);
        doc.setFontSize(16); doc.setFont('helvetica', 'bold');
        doc.text('Belleza Suprema', 14, 12);
        doc.setFontSize(10); doc.setFont('helvetica', 'normal');
        doc.text('Panel de Administrador', 14, 19);
        doc.text('Generado: ' + new Date().toLocaleDateString('es-CO'), pw - 14, 19, { align: 'right' });
        y = 38;

        // ── Título y período ──
        doc.setTextColor(50, 50, 50);
        doc.setFontSize(14); doc.setFont('helvetica', 'bold');
        doc.text(titulo, 14, y); y += 6;
        doc.setFontSize(10); doc.setFont('helvetica', 'normal'); doc.setTextColor(120, 120, 120);
        doc.text('Período: ' + desde + ' al ' + hasta, 14, y); y += 10;
        doc.setDrawColor(220, 220, 220);
        doc.line(14, y, pw - 14, y); y += 10;

        // ── Sección 1: Resumen estadístico ──
        doc.setTextColor(192, 38, 211);
        doc.setFontSize(11); doc.setFont('helvetica', 'bold');
        doc.text('1. Resumen del período', 14, y); y += 8;

        // Calcular métricas del período filtrado
        var total = citas.length;
        var pend = citas.filter(function (c) { return c.Estado === 'Pendiente'; }).length;
        var fin = citas.filter(function (c) { return c.Estado === 'Finalizada'; }).length;
        var canc = citas.filter(function (c) { return c.Estado === 'Cancelada'; }).length;
        var venc = citas.filter(function (c) { return c.Estado === 'Vencida'; }).length;
        var ingresos = citas.filter(function (c) { return c.Estado === 'Finalizada'; })
            .reduce(function (s, c) { return s + (c.Precio || 0); }, 0);

        var stats = [
            { l: 'Total de Citas', v: total, col: [192, 38, 211] },
            { l: 'Ingresos Estimados', v: '$ ' + ingresos.toLocaleString('es-CO'), col: [22, 163, 74] },
            { l: 'Citas Pendientes', v: pend, col: [22, 163, 74] },
            { l: 'Citas Canceladas', v: canc, col: [220, 38, 38] },
            { l: 'Citas Finalizadas', v: fin, col: [37, 99, 235] },
            { l: 'Citas Vencidas', v: venc, col: [107, 114, 128] }
        ];

        // Dibujar tarjetas en 2 columnas × 3 filas
        var colW = (pw - 28 - 8) / 2;
        stats.forEach(function (s, i) {
            var col = i % 2;
            var row = Math.floor(i / 2);
            var x = 14 + col * (colW + 8);
            var cy = y + row * 22;

            doc.setFillColor(248, 248, 248);
            doc.roundedRect(x, cy, colW, 18, 3, 3, 'F');
            // Barra de color izquierda
            doc.setFillColor(s.col[0], s.col[1], s.col[2]);
            doc.rect(x, cy, 3, 18, 'F');
            // Etiqueta y valor
            doc.setTextColor(100, 100, 100); doc.setFontSize(8); doc.setFont('helvetica', 'normal');
            doc.text(s.l, x + 7, cy + 6);
            doc.setTextColor(s.col[0], s.col[1], s.col[2]); doc.setFontSize(14); doc.setFont('helvetica', 'bold');
            doc.text(String(s.v), x + 7, cy + 14);
        });
        y += Math.ceil(stats.length / 2) * 22 + 12;

        // ── Sección 2: Servicios más solicitados ──
        doc.setDrawColor(220, 220, 220);
        doc.line(14, y, pw - 14, y); y += 8;
        doc.setTextColor(192, 38, 211);
        doc.setFontSize(11); doc.setFont('helvetica', 'bold');
        doc.text('2. Servicios más solicitados', 14, y); y += 4;

        // Agrupar citas por nombre de servicio
        var smap = {};
        citas.forEach(function (c) {
            var n = c.ServicioNombre || 'Sin nombre';
            if (!smap[n]) smap[n] = { cantidad: 0, ingresos: 0 };
            smap[n].cantidad++;
            if (c.Estado === 'Finalizada') smap[n].ingresos += (c.Precio || 0);
        });

        var sarr = Object.keys(smap).map(function (k) {
            return { nombre: k, cantidad: smap[k].cantidad, ingresos: smap[k].ingresos };
        }).sort(function (a, b) { return b.cantidad - a.cantidad; });

        if (!sarr.length) {
            doc.setTextColor(150, 150, 150); doc.setFontSize(9); doc.setFont('helvetica', 'normal');
            doc.text('No hay servicios en este período.', 14, y + 6); y += 14;
        } else {
            doc.autoTable({
                startY: y,
                head: [['Servicio', 'Citas', 'Ingresos (COP)']],
                body: sarr.map(function (s) {
                    return [s.nombre, s.cantidad, '$ ' + s.ingresos.toLocaleString('es-CO')];
                }),
                styles: { fontSize: 9, cellPadding: 4 },
                headStyles: { fillColor: [192, 38, 211], textColor: 255, fontStyle: 'bold' },
                alternateRowStyles: { fillColor: [250, 245, 255] },
                columnStyles: { 1: { halign: 'center' }, 2: { halign: 'right' } },
                margin: { left: 14, right: 14 },
                theme: 'striped'
            });
            y = doc.lastAutoTable.finalY + 12;
        }

        // ── Sección 3: Detalle de citas ──
        doc.setDrawColor(220, 220, 220);
        doc.line(14, y, pw - 14, y); y += 8;
        doc.setTextColor(192, 38, 211);
        doc.setFontSize(11); doc.setFont('helvetica', 'bold');
        doc.text('3. Detalle de citas del período', 14, y); y += 4;

        doc.autoTable({
            startY: y,
            head: [['Cliente', 'Servicio', 'Fecha', 'Hora', 'Precio', 'Estado']],
            body: citas.map(function (c) {
                return [
                    c.NombreCliente || 'Desconocido',
                    c.ServicioNombre || '',
                    c.Fecha || '',
                    c.HoraInicio || '',
                    '$ ' + (c.Precio ? c.Precio.toLocaleString('es-CO') : '0'),
                    c.Estado || ''
                ];
            }),
            styles: { fontSize: 8, cellPadding: 3 },
            headStyles: { fillColor: [124, 58, 237], textColor: 255, fontStyle: 'bold' },
            alternateRowStyles: { fillColor: [248, 248, 255] },
            columnStyles: { 4: { halign: 'right' }, 5: { halign: 'center', fontStyle: 'bold' } },
            margin: { left: 14, right: 14 },
            theme: 'striped'
        });

        // ── Pie de página en todas las páginas ──
        var totalPaginas = doc.internal.getNumberOfPages();
        for (var p = 1; p <= totalPaginas; p++) {
            doc.setPage(p);
            doc.setFillColor(245, 245, 245);
            doc.rect(0, ph - 12, pw, 12, 'F');
            doc.setTextColor(150, 150, 150); doc.setFontSize(8); doc.setFont('helvetica', 'normal');
            doc.text('Belleza Suprema - ' + titulo, 14, ph - 4);
            doc.text('Página ' + p + ' de ' + totalPaginas, pw - 14, ph - 4, { align: 'right' });
        }

        // ── Descarga ──
        doc.save('Reporte_BellezaSuprema_' + desde + '_' + hasta + '.pdf');
    }


