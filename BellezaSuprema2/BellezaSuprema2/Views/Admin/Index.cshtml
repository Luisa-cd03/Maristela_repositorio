@* ════════════════════════════════════════════════════════════
     LIBRERÍAS CDN
     jsPDF      – construye el documento PDF en el navegador.
     autoTable  – extiende jsPDF para dibujar tablas.
    ════════════════════════════════════════════════════════════ *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>

<script>

    // ════════════════════════════════════════════════════════════
    // VARIABLES GLOBALES
    // ════════════════════════════════════════════════════════════

    var tabActivo = null;       // Pestaña actualmente visible
    var estadoSeleccionado = 'Todos';    // Filtro de estado en Agenda
    var fechaSeleccionada = null;       // Fecha seleccionada en el calendario (YYYY-MM-DD)
    var calAnio = new Date().getFullYear();
    var calMes = new Date().getMonth();   // 0-based
    var fechasConCitas = [];         // Fechas con ≥1 cita: ["2025-03-05", ...]
    var todosLosUsuarios = [];         // Cache de usuarios para filtro en memoria
    var tipoPeriodo = 'mes';      // 'mes' | 'rango'

    // Nombres de meses en inglés → encabezado del calendario
    var nombresMeses = ['January', 'February', 'March', 'April', 'May', 'June',
        'July', 'August', 'September', 'October', 'November', 'December'];

    // Nombres de meses en español → título del PDF
    var mesesEs = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio',
        'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];


    // ════════════════════════════════════════════════════════════
    // IIFE DE INICIALIZACIÓN
    // Se ejecuta una sola vez al cargar la página.
    //
    // Establece los límites de los inputs de fecha para que el
    // usuario NO pueda seleccionar:
    //   • Fechas anteriores a enero 2025 (inicio del aplicativo)
    //   • Fechas futuras al mes/día actual
    // ════════════════════════════════════════════════════════════
    (function () {
        var hoy = new Date();
        var anio = hoy.getFullYear();
        var mes = String(hoy.getMonth() + 1).padStart(2, '0');
        var dia = String(hoy.getDate()).padStart(2, '0');
        var mesActual = anio + '-' + mes;       // Ej: "2025-03"
        var hoyISO = anio + '-' + mes + '-' + dia; // Ej: "2025-03-04"

        // ── input[type="month"] (filtro por mes) ──
        // Valor inicial: mes en curso
        // Mínimo: enero 2025 (creación del aplicativo)
        // Máximo: mes en curso (sin reportes futuros)
        var inputMes = document.getElementById('input-mes');
        inputMes.value = mesActual;
        inputMes.setAttribute('min', '2025-01');
        inputMes.setAttribute('max', mesActual);

        // ── input[type="date"] desde (filtro por rango) ──
        // Mínimo: 1 enero 2025
        document.getElementById('input-desde').setAttribute('min', '2025-01-01');

        // ── input[type="date"] hasta (filtro por rango) ──
        // Máximo: hoy (sin fechas futuras)
        document.getElementById('input-hasta').setAttribute('max', hoyISO);
    })();


    // ════════════════════════════════════════════════════════════
    // FUNCIÓN: cambiarTab(tab)
    // Muestra la sección correspondiente y oculta las demás.
    // Si se pulsa la pestaña ya activa, se cierra (toggle).
    // ════════════════════════════════════════════════════════════
    function cambiarTab(tab) {
        if (tabActivo === tab) {
            // Segunda pulsación sobre la misma pestaña → cerrar
            tabActivo = null;
            document.querySelectorAll('.section').forEach(function (s) { s.style.display = 'none'; });
            document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
            return;
        }
        tabActivo = tab;
        document.querySelectorAll('.section').forEach(function (s) { s.style.display = 'none'; });
        document.querySelectorAll('.tab-btn').forEach(function (b) { b.classList.remove('active'); });
        document.getElementById('section-' + tab).style.display = 'block';
        document.getElementById('tab-' + tab).classList.add('active');

        // Disparar carga de datos según la sección
        if (tab === 'Agenda') cargarFechasConCitas();
        if (tab === 'Servicios') cargarServicios();
        if (tab === 'Usuarios') cargarUsuarios();
        if (tab === 'Reportes') repCargarDatos();
    }


    // ════════════════════════════════════════════════════════════
    // CALENDARIO
    // ════════════════════════════════════════════════════════════

    /**
     * Solicita al servidor los días del mes/año activos que
     * tienen al menos una cita y luego renderiza el calendario.
     * Endpoint: GET /Admin/GetFechas → string[]
     */
    function cargarFechasConCitas() {
        fetch('/Admin/GetFechas')
            .then(function (r) { return r.json(); })
            .then(function (data) {
                fechasConCitas = data;
                renderizarCalendario();
            });
    }

    /**
     * Construye la cuadrícula de días del mes/año actuales.
     * Marca: día de hoy, día seleccionado y días con citas (•).
     */
    function renderizarCalendario() {
        document.getElementById('cal-titulo').textContent = nombresMeses[calMes] + ' ' + calAnio;

        var hoy = new Date();
        var hoyStr = formatearFecha(hoy.getFullYear(), hoy.getMonth(), hoy.getDate());
        var diasEnMes = new Date(calAnio, calMes + 1, 0).getDate();
        var primerDia = new Date(calAnio, calMes, 1).getDay(); // 0 = Domingo

        var grid = document.getElementById('cal-dias');
        grid.innerHTML = '';

        // Celdas vacías para alinear el primer día de la semana
        for (var i = 0; i < primerDia; i++) {
            grid.appendChild(document.createElement('div'));
        }

        // Celda por cada día del mes
        for (var d = 1; d <= diasEnMes; d++) {
            var diaStr = formatearFecha(calAnio, calMes, d);
            var diaDiv = document.createElement('div');
            diaDiv.className = 'cal-day';
            diaDiv.textContent = d;

            if (diaStr === hoyStr) diaDiv.classList.add('today');
            if (diaStr === fechaSeleccionada) diaDiv.classList.add('selected');

            // Punto indicador si el día tiene citas
            if (fechasConCitas.indexOf(diaStr) !== -1) {
                var dot = document.createElement('div');
                dot.className = 'dot';
                diaDiv.appendChild(dot);
            }

            // IIFE para capturar el valor correcto de diaStr en cada iteración
            diaDiv.onclick = (function (f) { return function () { seleccionarDia(f); }; })(diaStr);
            grid.appendChild(diaDiv);
        }
    }

    /** Avanza o retrocede un mes en el calendario. delta: +1 o -1 */
    function cambiarMes(delta) {
        calMes += delta;
        if (calMes > 11) { calMes = 0; calAnio++; }
        if (calMes < 0) { calMes = 11; calAnio--; }
        renderizarCalendario();
    }

    /**
     * Selecciona o deselecciona un día.
     * Al seleccionar, dispara la carga de citas de ese día.
     */
    function seleccionarDia(fecha) {
        if (fechaSeleccionada === fecha) {
            fechaSeleccionada = null;
            document.getElementById('fecha-titulo').textContent = '';
        } else {
            fechaSeleccionada = fecha;
            document.getElementById('fecha-titulo').textContent = '— ' + fecha;
        }
        renderizarCalendario();
        cargarCitas();
    }


    // ════════════════════════════════════════════════════════════
    // CITAS
    // ════════════════════════════════════════════════════════════

    /**
     * Solicita citas al servidor aplicando los filtros activos
     * (fecha seleccionada y/o estado).
     * Endpoint: GET /Admin/GetCitas?fecha=&estado=
     */
    function cargarCitas() {
        var url = '/Admin/GetCitas?';
        if (fechaSeleccionada) url += 'fecha=' + fechaSeleccionada + '&';
        if (estadoSeleccionado && estadoSeleccionado !== 'Todos') url += 'estado=' + estadoSeleccionado;

        fetch(url)
            .then(function (r) { return r.json(); })
            .then(function (citas) { renderizarTablaCitas(citas); })
            .catch(function () {
                document.getElementById('citas-container').innerHTML =
                    '<div class="no-citas">Error al cargar las citas</div>';
            });
    }

    /** Construye la tabla HTML con el array de citas recibido. */
    function renderizarTablaCitas(citas) {
        var contenedor = document.getElementById('citas-container');

        if (citas.length === 0) {
            contenedor.innerHTML = '<div class="no-citas">No hay citas para esta selección</div>';
            return;
        }

        var html = '<table><thead><tr>';
        html += '<th>Cliente</th><th>Servicio</th><th>Fecha</th><th>Hora</th><th>Precio</th><th>Estado</th>';
        html += '</tr></thead><tbody>';

        citas.forEach(function (c) {
            html += '<tr>';
            html += '<td>' + (c.NombreCliente || 'Desconocido') + '</td>';
            html += '<td>' + (c.ServicioNombre || '') + '</td>';
            html += '<td>' + (c.Fecha || '') + '</td>';
            html += '<td>' + (c.HoraInicio || '') + '</td>';
            html += '<td>$' + (c.Precio ? c.Precio.toLocaleString() : '0') + '</td>';
            html += '<td><span class="badge badge-' + c.Estado + '">' + c.Estado + '</span></td>';
            html += '</tr>';
        });

        html += '</tbody></table>';
        contenedor.innerHTML = html;
    }


    // ════════════════════════════════════════════════════════════
    // DROPDOWN FILTRO ESTADO
    // ════════════════════════════════════════════════════════════

    /** Abre o cierra el dropdown de filtro de estado de la Agenda. */
    function toggleDropdown() {
        var dd = document.getElementById('estado-dropdown');
        dd.style.display = dd.style.display === 'block' ? 'none' : 'block';
    }

    /** Aplica el filtro seleccionado y recarga la tabla de citas. */
    function seleccionarEstado(valor, etiqueta) {
        estadoSeleccionado = valor;
        document.getElementById('estado-texto').textContent = etiqueta;
        document.getElementById('estado-dropdown').style.display = 'none';
        cargarCitas();
    }


    // ════════════════════════════════════════════════════════════
    // USUARIOS
    // ════════════════════════════════════════════════════════════

    /**
     * Carga todos los usuarios y los almacena en todosLosUsuarios
     * para poder filtrar en memoria sin nuevas peticiones.
     * Endpoint: GET /Admin/GetTodosUsuarios
     */
    function cargarUsuarios() {
        fetch('/Admin/GetTodosUsuarios')
            .then(function (r) { return r.json(); })
            .then(function (usuarios) {
                todosLosUsuarios = usuarios;
                renderizarTablaUsuarios(usuarios);
            });
    }

    /**
     * Filtra el array en memoria por nombre (case-insensitive)
     * y vuelve a renderizar la tabla sin petición al servidor.
     */
    function filtrarUsuarios(texto) {
        var q = texto.toLowerCase().trim();
        if (!q) { renderizarTablaUsuarios(todosLosUsuarios); return; }
        renderizarTablaUsuarios(
            todosLosUsuarios.filter(function (u) {
                return u.Nombre.toLowerCase().indexOf(q) !== -1;
            })
        );
    }

    /** Construye la tabla HTML con el array de usuarios recibido. */
    function renderizarTablaUsuarios(usuarios) {
        var contenedor = document.getElementById('usuarios-container');

        if (usuarios.length === 0) {
            contenedor.innerHTML = '<div class="no-citas">No se encontraron usuarios</div>';
            return;
        }

        var html = '<table><thead><tr>';
        html += '<th>Nombre</th><th>Teléfono</th><th>Correo</th><th>Rol</th>';
        html += '</tr></thead><tbody>';

        usuarios.forEach(function (u) {
            var esAdmin = u.Role === 'Administrador';
            var badge = esAdmin
                ? 'background:#111;color:#fff;border-radius:20px;padding:3px 14px;font-size:12px;font-weight:700;'
                : 'background:#e5e7eb;color:#374151;border-radius:20px;padding:3px 14px;font-size:12px;font-weight:600;';
            html += '<tr>';
            html += '<td style="font-weight:700;color:#111;">' + u.Nombre + '</td>';
            html += '<td style="color:#555;">' + (u.Telefono || 'N/A') + '</td>';
            html += '<td style="color:#555;">' + u.Email + '</td>';
            html += '<td><span style="' + badge + '">' + u.Role + '</span></td>';
            html += '</tr>';
        });

        html += '</tbody></table>';
        contenedor.innerHTML = html;
    }


