    // ════════════════════════════════════════════════════
    // REPORTES AVANZADOS — funciones de la pestaña 4
    // ════════════════════════════════════════════════════
    // ════════════════════════════════════════════════════════════════
    // REPORTES AVANZADOS — pestaña 4 del Panel de Administrador
    //
    // ENDPOINTS:
    //   GET /Admin/GetCitas          → { NombreCliente, ServicioNombre, Fecha, HoraInicio, Precio, Estado }[]
    //   GET /Admin/GetTodosUsuarios  → { Nombre, Email, Telefono, Role }[]
    //   GET /Admin/GetReportes       → { TotalCitas, CitasPendientes, CitasCanceladas,
    //                                    CitasFinalizadas, TotalUsuarios, IngresosEstimados }
    //
    // CACHE: los 3 arrays se llenan una sola vez al abrir la pestaña.
    // Todos los filtros operan en memoria sin llamadas extra al servidor.
    // ════════════════════════════════════════════════════════════════

    var _repCitas = [];   // GET /Admin/GetCitas
    var _repUsuarios = [];   // GET /Admin/GetTodosUsuarios
    var _repKPI = null; // GET /Admin/GetReportes
    var _repCargado = false;
    var _repServicios = [];
    var _repGanMes = [];

    var REP_COLORES = ['#7c3aed', '#c026d3', '#2563eb', '#059669', '#d97706', '#dc2626', '#0891b2'];
    var REP_MESES = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];

    // ── Carga al abrir la pestaña (solo la primera vez) ──────────────
    function repCargarDatos() {
        if (_repCargado) return;

        Promise.all([
            fetch('/Admin/GetCitas').then(function (r) { return r.json(); }),
            fetch('/Admin/GetTodosUsuarios').then(function (r) { return r.json(); }),
            fetch('/Admin/GetReportes').then(function (r) { return r.json(); })
        ]).then(function (resultados) {
            _repCitas = resultados[0];
            _repUsuarios = resultados[1];
            _repKPI = resultados[2];
            _repCargado = true;

            repPoblarFiltroServicios();
            repRenderCitas(_repCitas);
            repRenderKPIs(_repKPI);
            repCalcDerivados(_repCitas);
            repRenderProximas(_repCitas);
            repInitCharts();

        }).catch(function (err) {
            console.error('Error reportes:', err);
            document.getElementById('section-Reportes').insertAdjacentHTML('afterbegin',
                '<div style="background:#fee2e2;border:1px solid #fca5a5;border-radius:10px;' +
                'padding:12px 18px;color:#991b1b;font-size:13px;margin-bottom:16px;">' +
                '⚠️ Error al cargar reportes. Verifica que el servidor esté activo.</div>');
        });
    }

    // ── Tabs internos ─────────────────────────────────────────────────
    function repShowTab(idx, btn) {
        document.querySelectorAll('#section-Reportes .report-section')
            .forEach(function (s) { s.classList.remove('active'); });
        document.querySelectorAll('.rtab')
            .forEach(function (b) { b.classList.remove('active'); });
        document.getElementById('rep-' + idx).classList.add('active');
        btn.classList.add('active');
    }

    // ── Poblar select de servicios ────────────────────────────────────
    function repPoblarFiltroServicios() {
        var sel = document.getElementById('rep-f1-serv');
        if (!sel) return;
        var servicios = [];
        _repCitas.forEach(function (c) {
            if (c.ServicioNombre && servicios.indexOf(c.ServicioNombre) === -1)
                servicios.push(c.ServicioNombre);
        });
        servicios.forEach(function (s) {
            var opt = document.createElement('option');
            opt.value = opt.textContent = s;
            sel.appendChild(opt);
        });
    }

    // ════════════════════════════════════════════════════
    // REPORTE 1 — CITAS
    // ════════════════════════════════════════════════════
    function repRenderCitas(data) {
        var tbody = document.getElementById('rep-tbody-citas');
        var countEl = document.getElementById('rep-citas-count');
        if (countEl) countEl.textContent = data.length + ' registros';
