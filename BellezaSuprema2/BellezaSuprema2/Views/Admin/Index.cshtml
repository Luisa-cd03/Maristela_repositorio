                '<td>' + (c.HoraInicio || '—') + '</td>' +
                '<td class="rep-td-bold">' + (c.NombreCliente || 'Desconocido') + '</td>' +
                '<td>' + (c.ServicioNombre || '—') + '</td>' +
                '<td><span class="rep-badge rep-badge-' + repBadge(c.Estado) + '">' + c.Estado + '</span></td>' +
                '<td>' +
                '<button onclick="alert(\'Conectar con endpoint de confirmación\')" ' +
                'style="background:#d1fae5;color:#065f46;border:none;padding:3px 9px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;margin-right:3px;">✓</button>' +
                '<button onclick="alert(\'Conectar con endpoint de cancelación\')" ' +
                'style="background:#fee2e2;color:#991b1b;border:none;padding:3px 9px;border-radius:6px;cursor:pointer;font-size:11px;font-weight:600;">✕</button>' +
                '</td></tr>';
        }).join('');
