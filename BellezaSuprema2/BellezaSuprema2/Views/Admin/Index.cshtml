@* ╔══════════════════════════════════════════════════════════════╗
    ║  ARCHIVO:      Index.cshtml                                  ║
    ║  UBICACIÓN:    Views/Admin/Index.cshtml                      ║
    ║                                                              ║
    ║  DESCRIPCIÓN:  Panel de administración principal.            ║
    ║                Contiene 3 secciones navegables por pestañas: ║
    ║                  1. Agenda   – Calendario + tabla de citas   ║
    ║                  2. Usuarios – Gestión y búsqueda            ║
    ║                  3. Reportes – KPIs + generador de PDF       ║
    ║                                                              ║
    ║  CAMBIOS RECIENTES:                                          ║
    ║    • Input "mes" limitado: mínimo 2025-01, máximo mes actual ║
    ║    • Input "desde" en rango: mínimo 2025-01-01               ║
    ║    • Input "hasta" en rango: máximo fecha de hoy             ║
    ║    • Validación: si no hay citas en el período elegido,      ║
    ║      muestra alerta estilizada en vez de PDF vacío           ║
    ║                                                              ║
    ║  DEPENDENCIAS CDN:                                           ║
    ║    • jsPDF 2.5.1      – Generación de PDF en el navegador    ║
    ║    • jsPDF-AutoTable  – Tablas dentro del PDF                ║
    ║                                                              ║
    ║  ENDPOINTS CONSUMIDOS:                                       ║
    ║    GET /Admin/GetFechas        → string[] (fechas con citas) ║
    ║    GET /Admin/GetCitas         → CitaModel[]                 ║
    ║    GET /Admin/GetTodosUsuarios → UserModel[]                 ║
    ║    GET /Admin/GetReportes      → ReportesViewModel           ║
    ╚══════════════════════════════════════════════════════════════╝ *@

@model BellezaSuprema2.Models.AdminDashboardViewModel

@{
    Layout = "~/Views/Admin/_LayoutAdmin.cshtml";
    ViewBag.Title = "Panel de Administrador";
}

<style>

    /* ── RESET GLOBAL ── */
    * {
        font-family: 'Segoe UI', sans-serif;
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: #f0f0f5;
        min-height: 100vh;
    }

    /* ════════════════════════════════════════════════════════════
       HEADER
       ════════════════════════════════════════════════════════════ */
    .admin-header {
        background: linear-gradient(135deg, #c026d3 0%, #7c3aed 100%);
        padding: 18px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .admin-header .logo-circle {
            width: 48px;
            height: 48px;
            background: rgba(255,255,255,0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 16px;
        }

        .admin-header h1 {
            color: #fff;
            font-size: 22px;
            font-weight: 800;
        }

        .admin-header .subtitle {
            color: rgba(255,255,255,0.8);
            font-size: 13px;
        }

    .header-buttons {
        display: flex;
        gap: 8px;
    }

    .header-btn {
        background: rgba(255,255,255,0.15);
        border: 1px solid rgba(255,255,255,0.3);
        color: #fff;
        cursor: pointer;
        font-size: 13px;
        border-radius: 8px;
        padding: 8px 16px;
        display: flex;
        align-items: center;
        gap: 7px;
        transition: background 0.2s;
    }

        .header-btn:hover {
            background: rgba(255,255,255,0.25);
        }

        .header-btn svg {
            width: 16px;
            height: 16px;
            flex-shrink: 0;
        }

    /* ════════════════════════════════════════════════════════════
       PESTAÑAS
       ════════════════════════════════════════════════════════════ */
    .tabs-container {
        padding: 24px 32px 0;
        display: flex;
        gap: 8px;
    }

    .tab-btn {
        background: transparent;
        border: 1px solid transparent;
        border-radius: 10px;
        padding: 10px 20px;
        font-weight: 500;
        color: #555;
        cursor: pointer;
        font-size: 14px;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 8px;
    }

        .tab-btn svg {
            width: 17px;
            height: 17px;
        }

        /* Pestaña activa */
        .tab-btn.active {
            background: #fff;
            border: 1px solid #ddd;
            font-weight: 700;
            color: #111;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        }

    /* ════════════════════════════════════════════════════════════
       ÁREA DE CONTENIDO
       ════════════════════════════════════════════════════════════ */
    .content-area {
        padding: 24px 32px;
    }

    /* Cada sección se oculta/muestra con JS según la pestaña activa */
    .section {
        display: none;
    }

    /* ════════════════════════════════════════════════════════════
       AGENDA — LAYOUT
       ════════════════════════════════════════════════════════════ */
    .agenda-layout {
        display: flex;
        gap: 24px;
    }

    .card {
        background: #fff;
        border-radius: 16px;
        padding: 20px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    }

    .card-title {
        font-weight: 700;
        font-size: 16px;
        margin-bottom: 16px;
        color: #333;
    }

    /* ── CALENDARIO ── */
    .calendar-wrapper {
        width: 340px;
        flex-shrink: 0;
    }

    .calendar-inner {
        border: 3px solid #c026d3;
        border-radius: 16px;
        padding: 16px;
    }

    .cal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 12px;
    }

        .cal-header button {
            background: none;
            border: none;
            cursor: pointer;
            color: #555;
            padding: 4px 8px;
            border-radius: 6px;
            display: flex;
            align-items: center;
            transition: background 0.15s;
        }

            .cal-header button:hover {
                background: #f3e8ff;
            }

            .cal-header button svg {
                width: 18px;
                height: 18px;
            }

        .cal-header span {
            font-weight: 700;
            font-size: 15px;
        }

    .cal-grid {
        display: grid;
        grid-template-columns: repeat(7, 1fr);
        gap: 2px;
    }

    .cal-day-header {
        text-align: center;
        font-size: 11px;
        color: #999;
        font-weight: 600;
        padding: 4px 0;
        margin-bottom: 4px;
    }

    .cal-day {
        text-align: center;
        padding: 6px 2px;
        border-radius: 8px;
        cursor: pointer;
        font-size: 13px;
        transition: all 0.15s;
        position: relative;
    }

        .cal-day:hover    { background: #f3e8ff; }
        .cal-day.today    { background: #111; color: #fff; font-weight: 700; }
        .cal-day.selected { background: #c026d3; color: #fff; font-weight: 700; }

        /* Punto indicador: ese día tiene al menos una cita */
        .cal-day .dot {
            width: 4px;
            height: 4px;
            background: #c026d3;
            border-radius: 50%;
            margin: 2px auto 0;
        }

        .cal-day.selected .dot,
        .cal-day.today .dot { background: rgba(255,255,255,0.7); }

    /* ── DROPDOWN FILTRO ESTADO ── */
    .estado-select {
        margin-top: 16px;
        position: relative;
    }

    .estado-btn {
        width: 100%;
        background: #f8f8f8;
        border: 1px solid #ddd;
        border-radius: 10px;
        padding: 10px 16px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        cursor: pointer;
        font-size: 14px;
        color: #333;
    }

        .estado-btn svg { width: 16px; height: 16px; transition: transform 0.2s; }

    .estado-dropdown {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 10px;
        z-index: 10;
        box-shadow: 0 4px 16px rgba(0,0,0,0.12);
        overflow: hidden;
    }

        .estado-dropdown div          { padding: 10px 16px; cursor: pointer; font-size: 14px; display: flex; align-items: center; gap: 8px; }
        .estado-dropdown div:hover    { background: #f3e8ff; }
        .estado-dropdown div.selected-opt { background: #f3e8ff; font-weight: 600; }
        .estado-dropdown div svg      { width: 14px; height: 14px; }

    /* ── TABLA DE CITAS ── */
    .citas-table-container { flex: 1; }

    table           { width: 100%; border-collapse: collapse; }
    thead th        { text-align: left; padding: 8px 12px; font-size: 13px; color: #666; font-weight: 600; border-bottom: 2px solid #f0f0f0; }
    tbody td        { padding: 12px 12px; font-size: 14px; border-bottom: 1px solid #f8f8f8; color: #555; }
    tbody td:first-child { font-weight: 600; color: #111; }

    /* ── BADGES DE ESTADO ── */
    .badge            { border-radius: 20px; padding: 3px 12px; font-size: 12px; font-weight: 600; display: inline-block; }
    .badge-Pendiente  { background: #fff3cd; color: #856404; border: 1px solid #ffc107; }
    .badge-Finalizada { background: #d1e7dd; color: #0a3622; border: 1px solid #198754; }
    .badge-Cancelada  { background: #f8d7da; color: #58151c; border: 1px solid #dc3545; }
    .badge-Vencida    { background: #e2e3e5; color: #41464b; border: 1px solid #6c757d; }

    /* Mensaje vacío genérico */
    .no-citas { text-align: center; color: #999; padding: 40px 0; font-size: 15px; }

    /* ════════════════════════════════════════════════════════════
       USUARIOS — BUSCADOR
       ════════════════════════════════════════════════════════════ */
    .buscar-wrapper { position: relative; }

        .buscar-wrapper svg {
            position: absolute;
            left: 14px;
            top: 50%;
            transform: translateY(-50%);
            width: 16px;
            height: 16px;
            pointer-events: none;
        }

    .buscar-input {
        background: linear-gradient(135deg, #c026d3, #7c3aed);
        color: #fff;
        border: none;
        border-radius: 30px;
        padding: 10px 20px 10px 42px;
        font-size: 14px;
        width: 320px;
        outline: none;
    }

        .buscar-input::placeholder { color: rgba(255,255,255,0.75); }

    /* ════════════════════════════════════════════════════════════
       REPORTES — TARJETAS KPI
       ════════════════════════════════════════════════════════════ */
    .reportes-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 24px;
    }

    .reporte-card {
        background: #fff;
        border-radius: 16px;
        padding: 28px 24px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.08);
    }

        .reporte-card .r-label  { font-size: 15px; font-weight: 700; color: #333; margin-bottom: 20px; }
        .reporte-card .r-numero { font-size: 42px; font-weight: 800; line-height: 1; margin-bottom: 10px; }
        .reporte-card .r-desc   { font-size: 13px; color: #888; }

    /* Colores de los valores numéricos */
    .r-morado { color: #c026d3; }
    .r-verde  { color: #16a34a; }
    .r-rojo   { color: #dc2626; }
    .r-azul   { color: #2563eb; }

    /* ════════════════════════════════════════════════════════════
       REPORTES — PANEL GENERAR PDF
       ════════════════════════════════════════════════════════════ */
    .pdf-panel {
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 2px 16px rgba(0,0,0,0.08);
        border-top: 4px solid #c026d3;
    }

        .pdf-panel h3 {
            font-size: 16px;
            font-weight: 700;
            color: #333;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .pdf-panel p {
            font-size: 13px;
            color: #888;
            margin-bottom: 20px;
        }

    .pdf-filtros {
        display: flex;
        gap: 16px;
        align-items: flex-end;
        flex-wrap: wrap;
    }

        .pdf-filtros label {
            font-size: 12px;
            font-weight: 600;
            color: #555;
            display: block;
            margin-bottom: 6px;
        }

        /*
            NOTA: Los atributos min/max de estos inputs
            se asignan dinámicamente en el bloque IIFE de JS.
            - input[type="month"]: min="2025-01"  max="YYYY-MM" (mes actual)
            - input[type="date"]  desde: min="2025-01-01"
            - input[type="date"]  hasta: max="YYYY-MM-DD" (hoy)
        */
        .pdf-filtros input[type="month"],
        .pdf-filtros input[type="date"] {
            border: 1.5px solid #e5e7eb;
            border-radius: 8px;
            padding: 9px 14px;
            font-size: 14px;
            color: #333;
            outline: none;
            transition: border-color 0.2s;
        }

        .pdf-filtros input:focus { border-color: #c026d3; }

    /* Selector tipo de filtro */
    .tipo-selector { display: flex; gap: 8px; }

    .tipo-btn {
        padding: 8px 16px;
        border-radius: 8px;
        border: 1.5px solid #e5e7eb;
        background: #f8f8f8;
        cursor: pointer;
        font-size: 13px;
        font-weight: 500;
        color: #555;
        transition: all 0.2s;
    }

        .tipo-btn.activo {
            background: #f3e8ff;
            border-color: #c026d3;
            color: #c026d3;
            font-weight: 700;
        }

    /* Botón descargar PDF */
    .btn-generar-pdf {
        background: linear-gradient(135deg, #c026d3, #7c3aed);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 24px;
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 8px;
        transition: opacity 0.2s;
        white-space: nowrap;
    }

        .btn-generar-pdf:hover    { opacity: 0.9; }
        .btn-generar-pdf:disabled { opacity: 0.6; cursor: not-allowed; }
        .btn-generar-pdf svg      { width: 16px; height: 16px; }

    /* ════════════════════════════════════════════════════════════
       ALERTA — SIN DATOS EN EL PERÍODO
       Aparece debajo del panel PDF cuando el filtro no arroja
       citas. Se inserta dinámicamente por mostrarMensajeSinDatos()
       y se elimina automáticamente a los 6 segundos.
       ════════════════════════════════════════════════════════════ */
    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .alerta-sin-datos {
        display: flex;
        align-items: center;
        gap: 20px;
        background: linear-gradient(135deg, #1a0a2e, #0f0f1a);
        border: 1px solid rgba(232,121,249,0.25);
        border-radius: 14px;
        padding: 22px 28px;
        margin-top: 16px;
        animation: fadeInUp 0.35s ease;
    }

    .alerta-sin-datos .alerta-icono {
        width: 52px;
        height: 52px;
        background: rgba(192,38,211,0.15);
        border: 1px solid rgba(192,38,211,0.3);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .alerta-sin-datos .alerta-titulo {
        font-size: 15px;
        font-weight: 700;
        color: #fff;
        margin-bottom: 4px;
    }

    .alerta-sin-datos .alerta-texto {
        font-size: 13px;
        color: rgba(255,255,255,0.45);
    }

        .alerta-sin-datos .alerta-texto strong { color: rgba(232,121,249,0.85); }

    .alerta-sin-datos .alerta-cerrar {
        margin-left: auto;
        background: none;
        border: none;
        cursor: pointer;
        color: rgba(255,255,255,0.3);
        font-size: 22px;
        line-height: 1;
        padding: 4px 8px;
        transition: color 0.2s;
        flex-shrink: 0;
    }

        .alerta-sin-datos .alerta-cerrar:hover { color: rgba(255,255,255,0.7); }

    /* ════════════════════════════════════════════════════════════
       CHAT FLOTANTE
       ════════════════════════════════════════════════════════════ */
    .chat-toggle-btn {
        position: fixed;
        bottom: 28px;
        right: 28px;
        background: linear-gradient(135deg, #c026d3, #7c3aed);
        color: #fff;
        border: none;
        border-radius: 50%;
        width: 56px;
        height: 56px;
        cursor: pointer;
        box-shadow: 0 4px 20px rgba(192,38,211,0.4);
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .chat-toggle-btn svg { width: 24px; height: 24px; }

    .chat-window {
        display: none;
        position: fixed;
        bottom: 20px;
        right: 20px;
        width: 360px;
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.18);
        z-index: 200;
        flex-direction: column;
        overflow: hidden;
    }

    .chat-header {
        background: linear-gradient(135deg, #c026d3, #7c3aed);
        padding: 14px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        color: #fff;
        font-weight: 700;
        font-size: 15px;
    }

    .chat-header-left     { display: flex; align-items: center; gap: 8px; }
    .chat-header-left svg { width: 18px; height: 18px; }
    .chat-close-btn       { background: none; border: none; color: #fff; cursor: pointer; display: flex; align-items: center; }
    .chat-close-btn svg   { width: 18px; height: 18px; }

    .chat-messages {
        padding: 16px;
        max-height: 320px;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .msg-bot  { align-self: flex-start; background: #f3f4f6; color: #333; border-radius: 14px; padding: 10px 14px; font-size: 13px; max-width: 80%; }
    .msg-user { align-self: flex-end; background: linear-gradient(135deg, #c026d3, #7c3aed); color: #fff; border-radius: 14px; padding: 10px 14px; font-size: 13px; max-width: 80%; }
    .msg-time { font-size: 10px; opacity: 0.6; margin-top: 4px; }

    .chat-input-area {
        padding: 10px 16px;
        border-top: 1px solid #f0f0f0;
        display: flex;
        gap: 8px;
        align-items: center;
    }

        .chat-input-area input { flex: 1; border: 1px solid #e5e7eb; border-radius: 10px; padding: 8px 14px; font-size: 13px; outline: none; }

    .chat-send-btn { background: linear-gradient(135deg, #c026d3, #7c3aed); color: #fff; border: none; border-radius: 10px; width: 38px; height: 38px; cursor: pointer; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .chat-send-btn svg { width: 16px; height: 16px; }


    /* ── REPORTES AVANZADOS (pestaña 4) ── */

    /* ════════════════════════════════════════════════════════════
       REPORTES AVANZADOS — variables y componentes de la pestaña 4
       ════════════════════════════════════════════════════════════ */
    :root {
      --rep-bg:      #f7f8fc;
      --rep-surface: #ffffff;
      --rep-border:  #e8eaf0;
      --rep-muted:   #8b90a7;
      --rep-accent:  #7c3aed;
      --rep-green:   #059669;
      --rep-red:     #dc2626;
      --rep-amber:   #d97706;
      --rep-blue:    #2563eb;
      --rep-grad:    linear-gradient(135deg, #7c3aed, #c026d3);
      --rep-shadow:  0 2px 20px rgba(124,58,237,0.08);
      --rep-r:       14px;
    }

    /* ── LAYOUT REPORTES ── */
    .rep-app { display:flex; min-height:calc(100vh - 80px); }

    /* ── SIDEBAR ── */
    .rep-sidebar {
      width:220px; flex-shrink:0; background:#fff;
      border-right:1px solid var(--rep-border);
      display:flex; flex-direction:column;
    }
    .rep-sidebar-section {
      padding:14px 12px 4px;
      font-size:10px; font-weight:700; color:var(--rep-muted);
      text-transform:uppercase; letter-spacing:1px;
    }
    .rep-sidebar-item {
      display:flex; align-items:center; gap:10px;
      padding:10px 16px; border-radius:10px; margin:2px 8px;
      cursor:pointer; font-size:13px; font-weight:500; color:var(--rep-muted);
      transition:all .2s; border:none; background:none;
      width:calc(100% - 16px); text-align:left; font-family:'Segoe UI',sans-serif;
    }
    .rep-sidebar-item svg { width:16px; height:16px; flex-shrink:0; }
    .rep-sidebar-item:hover { background:#f3eeff; color:#7c3aed; }
    .rep-sidebar-item.active { background:#f3eeff; color:#7c3aed; font-weight:700; }

    /* ── MAIN REPORTES ── */
    .rep-main { flex:1; padding:24px 28px; overflow-x:hidden; background:var(--rep-bg); }
    .rep-page-header { margin-bottom:22px; }
    .rep-page-header h1 { font-size:20px; font-weight:800; margin-bottom:3px; color:#1a1d2e; }
    .rep-page-header p  { font-size:13px; color:var(--rep-muted); }

    /* ── TABS REPORTES ── */
    .rep-tabs-bar {
      display: flex;
      align-items: center;
      gap: 0;
      background: #fff;
      border: 1px solid var(--rep-border);
      border-radius: 14px;
      padding: 5px;
      margin-bottom: 22px;
      overflow-x: auto;
      scrollbar-width: none;
      box-shadow: 0 2px 12px rgba(124,58,237,0.07);
      -ms-overflow-style: none;
    }
    .rep-tabs-bar::-webkit-scrollbar { display: none; }
    .report-tabs { display:flex; gap:8px; margin-bottom:20px; flex-wrap:wrap; }
    .rtab {
      flex-shrink: 0;
      padding: 9px 18px;
      border-radius: 10px;
      border: none;
      background: transparent;
      cursor: pointer;
      font-size: 13px;
      font-weight: 600;
      color: var(--rep-muted);
      transition: all .2s;
      white-space: nowrap;
      font-family: 'Segoe UI', sans-serif;
      display: flex;
      align-items: center;
      gap: 6px;
      position: relative;
    }
    .rtab.active {
      background: var(--rep-grad);
      color: #fff;
      font-weight: 700;
      box-shadow: 0 4px 14px rgba(124,58,237,0.3);
